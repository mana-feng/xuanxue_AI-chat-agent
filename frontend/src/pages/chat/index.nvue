<template>
	<tm-app>
		<view class="app-shell chat-page-container">
			<yx-nav-header></yx-nav-header>
			<view class="app-main chat-main-layout">
				<chat-panel ref="panelRef" class="chat-panel-wrapper" :disable-auto-restore="shouldDisableRestore" @send="handleSend" />
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { ref, onMounted, nextTick } from 'vue';
import { onLoad } from '@dcloudio/uni-app';
import ChatPanel from '@/chat/ChatPanel.vue';
import { request } from '@/services/api/index';
import { getAccessToken } from '@/utils/tokenStore';
import { API_BASE_URL } from '@/config/config';
import { useUserStore } from '@/store/user';
import { useBaziStore } from '@/store/bazi';
import { useYunStore } from '@/store/yun';
import { useLiuyaoStore } from '@/store/liuyao';
import { buildBaziExportPayload } from '@/utils/baziExport';
import { buildLiuyaoExportPayload } from '@/utils/liuyaoExport';

const panelRef = ref<InstanceType<typeof ChatPanel> | null>(null);
const config = ref<{ provider: string; baseUrl: string; apiKey: string; model: string; extra?: string }>({
	provider: 'openai',
	baseUrl: '',
	apiKey: '',
	model: '',
	extra: ''
});

const userStore = useUserStore();
const baziStore = useBaziStore();
const yunStore = useYunStore();
const liuyaoStore = useLiuyaoStore();
const chatContext = ref<'bazi' | 'liuyao'>('bazi');
let firstSendDone = false;

onLoad((options: any) => {
	if (options?.from === 'liuyao') {
		chatContext.value = 'liuyao';
		shouldDisableRestore.value = true;
	} else if (options?.from === 'bazi') {
		chatContext.value = 'bazi';
		shouldDisableRestore.value = true;
	}
});

// 加载用户额度信息
async function loadQuotaInfo() {
	try {
		const res = await request('/api/llm/quota', {
			method: 'GET',
			needAuth: true,
		});
		if (res?.success && res?.data) {
			// 确保组件已经挂载
			await nextTick();
			if (panelRef.value) {
				panelRef.value.updateQuotaInfo(res.data);
			}
		}
	} catch (err) {
		console.error('加载额度信息失败:', err);
	}
}

// 页面挂载后获取额度信息
onMounted(() => {
	// 延迟一下确保组件完全挂载
	setTimeout(() => {
		loadQuotaInfo();
		if (chatContext.value === 'liuyao') {
			panelRef.value?.appendAssistant('已为您加载六爻排盘结果，您可以让 AI 为您解读卦象。', 'ready');
		}
	}, 100);
});

function handleSend(text: string) {
	sendToLLM(text);
}

// Removed unused loadConfig function

function buildMessages(text: string) {
	const panel = panelRef.value;
	if (!panel) {
		return [{ role: 'user', content: text }];
	}
	
	// 获取历史消息（排除初始欢迎消息）
	const historyMessages = panel.getMessages();
	const messages: Array<{ role: string; content: string }> = [];
	
	// 只在第一次发送时添加系统消息（八字或六爻信息）
	if (!firstSendDone) {
		if (chatContext.value === 'liuyao') {
			const payload = buildLiuyaoExportPayload(liuyaoStore);
			if (payload) {
				messages.push({
					role: 'system',
					content: `User Liuyao result:\n${payload}`
				});
			}
		} else {
			const payload = buildBaziExportPayload(userStore, baziStore, yunStore);
			const baziJson = payload ? JSON.stringify(payload) : null;
			if (baziJson) {
				messages.push({
					role: 'system',
					content: `User Bazi profile (JSON): ${baziJson}`
				});
			}
		}
		firstSendDone = true;
	}
	
	// 添加历史对话（排除初始欢迎消息和等待/流式状态的消息）
	for (const msg of historyMessages) {
		// 跳过初始欢迎消息（id 为 'm-1'）
		if (msg.id === 'm-1') continue;
		// 跳过等待状态和流式状态的消息（这些是临时状态）
		if (msg.status === 'waiting' || msg.status === 'stream') continue;
		// 只添加已完成的消息
		if (msg.text && msg.text.trim()) {
			messages.push({
				role: msg.role === 'user' ? 'user' : 'assistant',
				content: msg.text
			});
		}
	}
	
	// 添加当前用户消息
	messages.push({ role: 'user', content: text });
	
	return messages;
}

async function sendToLLM(text: string) {
	const panel = panelRef.value;
	if (!panel) return;
	panel.setSending(true);
	
	// 立即创建等待状态的助手消息
	panel.createWaitingMessage();

	try {
		// 后端已统一处理配置，前端不需要重新加载
		const messages = buildMessages(text);
		const token = getAccessToken();
		
		// 优先尝试 WebSocket
		if (token) {
			try {
				await sendWithWS(messages, token);
				return;
			} catch (wsErr) {
				console.warn('WebSocket 连接失败，尝试回退到 HTTP', wsErr);
				// 仅在非生产环境提示 WS 错误，避免干扰用户
				// panel.appendAssistant(`(WS连接失败: ${wsErr.message || '未知'}, 转为HTTP)`, 'error');
			}
		}

		// 回退方案
		// #ifdef H5
		// H5 环境下尝试使用 fetch 实现流式
		try {
			await sendWithHttpStream(messages);
		} catch (e) {
			console.warn('HTTP 流式失败，回退到普通请求', e);
			await sendWithHttp(messages);
		}
		// #endif

		// #ifndef H5
		// 非 H5 环境（如小程序）不支持 fetch 流式，只能回退到普通请求
		await sendWithHttp(messages);
		// #endif

	} catch (err: any) {
		console.error('调用大模型接口失败', err);
		// 检查是否是额度错误
		if (err?.error && (err.error.includes('额度') || err.error.includes('用完') || err.error.includes('频繁'))) {
			panel.appendAssistant(`⚠️ ${err.error}`, 'error');
		} else if (err?.statusCode === 429 || err?.error?.includes('额度')) {
			const errorMsg = err?.error || err?.message || '额度已用完';
			panel.appendAssistant(`⚠️ ${errorMsg}`, 'error');
		} else {
			const msg = err?.errMsg || err?.message || err?.error || '调用失败';
			panel.appendAssistant(`调用失败：${msg}`, 'error');
		}
	} finally {
		panel.setSending(false);
	}
}

async function sendWithHttp(messages: Array<{ role: string; content: string }>) {
	const res = await request('/api/llm/chat', {
		method: 'POST',
		needAuth: true,
		data: {
			stream: false,
			messages
		}
	});

	if (!res?.success) {
		// 检查是否是额度错误
		const errorMsg = res?.error || '调用失败';
		if (errorMsg.includes('额度') || errorMsg.includes('用完') || errorMsg.includes('频繁')) {
			throw { error: errorMsg, statusCode: 429 };
		}
		throw new Error(errorMsg);
	}
	
	// 后端已统一返回格式：{ reply: text }
	const reply = res.data?.reply || '';
	if (!reply || reply.trim() === '') {
		panelRef.value?.appendAssistant('回复为空，请检查后端配置', 'error');
		return;
	}
	panelRef.value?.appendAssistant(String(reply), 'ready');
	// 额度更新仅在后端执行，前端通过 API 读取
	setTimeout(() => {
		loadQuotaInfo();
	}, 300);
}

// #ifdef H5
async function sendWithHttpStream(messages: Array<{ role: string; content: string }>) {
	const token = getAccessToken();
	const headers: Record<string, string> = {
		'Content-Type': 'application/json'
	};
	if (token) {
		headers['Authorization'] = `Bearer ${token}`;
	}

	const response = await fetch(`${API_BASE_URL}/api/llm/chat`, {
		method: 'POST',
		headers,
		body: JSON.stringify({
			stream: true,
			messages
		})
	});

	if (!response.ok) {
		const text = await response.text();
		let errorMsg = text;
		try {
			const json = JSON.parse(text);
			errorMsg = json.error || text;
		} catch {
			errorMsg = text;
		}
		throw new Error(errorMsg || `HTTP error ${response.status}`);
	}

	if (!response.body) {
		throw new Error('ReadableStream not supported');
	}

	const reader = response.body.getReader();
	const decoder = new TextDecoder();
	const panel = panelRef.value;
	if (!panel) return;

	let buffer = '';
	
	let done = false;
	while (!done) {
		const result = await reader.read();
		done = result.done;
		const value = result.value;
		if (done) break;
		
		const chunk = decoder.decode(value, { stream: true });
		buffer += chunk;
		
		const lines = buffer.split('\n');
		buffer = lines.pop() || ''; // 保留最后一个可能不完整的行
		
		for (const line of lines) {
			if (!line.trim()) continue;
			if (line.trim() === 'data: [DONE]') continue;
			
			// 解析 SSE 格式
			if (line.startsWith('data: ')) {
				const dataStr = line.slice(6);
				try {
					const data = JSON.parse(dataStr);
					// 处理错误
					if (data.error) {
						panel.appendAssistant(`错误：${data.error}`, 'error');
						continue;
					}
					
					// 兼容 OpenAI 格式
					let text = '';
					if (data.choices && data.choices[0]?.delta?.content) {
						text = data.choices[0].delta.content;
					} else if (data.choices && data.choices[0]?.text) {
						text = data.choices[0].text;
					} else if (data.content) { // Anthropic
						text = data.content;
					} else if (data.candidates) { // Gemini
						text = data.candidates[0]?.content?.parts?.[0]?.text || '';
					}

					if (text) {
						const cleaned = cleanHtml(text);
						if (cleaned) {
							panel.appendAssistant(cleaned, 'stream');
						}
					}
				} catch (e) {
					// 忽略解析错误
				}
			}
		}
	}
	
	panel.finishStreaming();
	setTimeout(() => {
		loadQuotaInfo();
	}, 300);
}
// #endif

function getWsUrl() {
	// 将 HTTP/HTTPS 转换为 WS/WSS
	let wsBase = API_BASE_URL;
	if (wsBase.startsWith('https://')) {
		wsBase = wsBase.replace('https://', 'wss://');
	} else if (wsBase.startsWith('http://')) {
		wsBase = wsBase.replace('http://', 'ws://');
	}
	// 移除末尾的斜杠
	wsBase = wsBase.replace(/\/$/, '');
	return `${wsBase}/api/llm/chat/ws`;
}

function cleanHtml(str: string) {
	if (!str) return '';
	const cleaned = String(str).replace(/<[^>]+>/g, '');
	// 如果清理后为空或只有空白，返回原始内容（可能是纯文本）
	if (!cleaned.trim() && str.trim()) {
		return str;
	}
	return cleaned;
}

function parseOpenAIChunk(line: string) {
	if (!line.startsWith('data:')) return '';
	const payload = line.replace(/^data:\s*/, '');
	if (payload.trim() === '[DONE]') return '';
	try {
		const json = JSON.parse(payload);
		const delta = json.choices?.[0]?.delta || json.choices?.[0];
		const content = delta?.content || delta?.text || '';
		return typeof content === 'string' ? content : '';
	} catch (e) {
		return '';
	}
}

function parseAnthropicChunk(line: string) {
	if (!line.startsWith('data:')) return '';
	const payload = line.replace(/^data:\s*/, '');
	try {
		const json = JSON.parse(payload);
		// message_delta or content_block_delta
		const delta = json.delta || json;
		const text = delta?.text || delta?.content?.[0]?.text || '';
		return typeof text === 'string' ? text : '';
	} catch (e) {
		return '';
	}
}

function parseGeminiChunk(line: string) {
	// Gemini 流返回 JSON，无 data: 前缀
	const payload = line.trim().replace(/^data:\s*/, '');
	try {
		const json = JSON.parse(payload);
		const text = json?.candidates?.[0]?.content?.parts?.[0]?.text || '';
		return typeof text === 'string' ? text : '';
	} catch (e) {
		return '';
	}
}

function parseJsonReply(provider: string, raw: string) {
	try {
		const json = JSON.parse(raw);
		// 严格按照配置的 provider 解析，不自动检测
		return extractReply(provider, json);
	} catch (e) {
		return '';
	}
}

function parseStreamChunk(provider: string, rawChunk: string) {
	// 如果是完整的 JSON 响应（不以 data: 开头），直接解析
	if (rawChunk.trim().startsWith('{') && !rawChunk.includes('data:')) {
		const jsonResult = parseJsonReply(provider, rawChunk);
		if (jsonResult) {
			return jsonResult;
		}
	}
	
	// 流式 SSE 格式解析（严格按照 provider）
	const lines = rawChunk.split('\n').map((l) => l.trim()).filter(Boolean);
	let acc = '';
	for (const line of lines) {
		let piece = '';
		// 严格按照配置的 provider 选择解析方式
		if (provider === 'anthropic') {
			piece = parseAnthropicChunk(line);
		} else if (provider === 'gemini') {
			piece = parseGeminiChunk(line);
		} else {
			// openai / deepseek / qwen 走同一流格式
			piece = parseOpenAIChunk(line);
		}
		if (piece) {
			acc += piece;
		}
	}
	if (acc) {
		const cleaned = cleanHtml(acc);
		return cleaned;
	}
	
	// 如果流式解析失败，尝试作为完整 JSON 解析（兜底）
	if (rawChunk.trim().startsWith('{')) {
		const jsonResult = parseJsonReply(provider, rawChunk);
		if (jsonResult) {
			return jsonResult;
		}
	}
	
	// 最后兜底：如果是纯文本，返回清理后的文本
	const cleaned = cleanHtml(rawChunk);
	return cleaned || rawChunk; // 如果清理后为空，返回原始文本
}

async function sendWithWS(messages: Array<{ role: string; content: string }>, token: string) {
	const wsUrl = `${getWsUrl()}?token=${encodeURIComponent(token)}`;
	return new Promise<void>((resolve, reject) => {
		const panel = panelRef.value;
		if (!panel) return reject(new Error('no panel'));

		let lineBuffer = ''; // 按行缓冲
		let closed = false;
		
		// uni-app WebSocket 连接
		const socketTask = uni.connectSocket({
			url: wsUrl,
			fail: (err: any) => {
				if (!closed) {
					closed = true;
					const errorMsg = err?.errMsg || '连接失败';
					panel.appendAssistant(`连接失败：${errorMsg}`, 'error');
					reject(new Error(errorMsg));
				}
			}
		});

		// 设置超时：如果10分钟内没有收到任何消息，显示错误
		let timeoutId: ReturnType<typeof setTimeout> | null = null;
		let firstMessageReceived = false;
		
		// 监听连接打开
		socketTask.onOpen(() => {
			// 连接成功后发送消息
			socketTask.send({
				data: JSON.stringify({
					stream: true,
					messages
				}),
				success: () => {
					// 设置超时
					timeoutId = setTimeout(() => {
						if (!closed && !firstMessageReceived) {
							closed = true;
							panel.appendAssistant('请求超时，请检查网络连接或稍后重试', 'error');
							panel.setSending(false);
							socketTask.close();
							reject(new Error('请求超时'));
						}
					}, 10 * 60 * 1000); // 10分钟超时
				},
				fail: (err: any) => {
					if (!closed) {
						closed = true;
						const errorMsg = err?.errMsg || '发送失败';
						panel.appendAssistant(`发送失败：${errorMsg}`, 'error');
						if (timeoutId) clearTimeout(timeoutId);
						reject(new Error(errorMsg));
					}
				}
			});
		});

		// 监听消息 - 按行解析 NDJSON
		socketTask.onMessage((evt: any) => {
			if (!firstMessageReceived) {
				firstMessageReceived = true;
				if (timeoutId) {
					clearTimeout(timeoutId);
				}
			}
			
			const chunk = typeof evt?.data === 'string' ? evt.data : '';
			if (!chunk) {
				return;
			}

			// 累积到行缓冲
			lineBuffer += chunk;

			// 按行处理（NDJSON 格式：每行一个 JSON）
			let idx;
			while ((idx = lineBuffer.indexOf('\n')) >= 0) {
				const line = lineBuffer.slice(0, idx).trim();
				lineBuffer = lineBuffer.slice(idx + 1);

				if (!line) continue;

				let msg;
				try {
					msg = JSON.parse(line);
				} catch (err) {
					// 这一行还没收完整，放回去等待下一段
					lineBuffer = line + '\n' + lineBuffer;
					break;
				}

				// 处理不同事件类型
				if (msg.event === 'delta' && msg.text) {
					// 增量文本：使用流式模式追加
					const cleaned = cleanHtml(msg.text);
					if (cleaned) {
						panel.appendAssistant(cleaned, 'stream');
					}
				} else if (msg.event === 'done') {
					// 完成标记：将流式状态改为完成
					panel.finishStreaming();
					// 额度更新仅在后端执行，前端通过 API 读取
					setTimeout(() => {
						loadQuotaInfo();
					}, 300);
				} else if (msg.error) {
					// 错误消息
					const errorMsg = msg.error || '未知错误';
					// 检查是否是额度错误
					if (errorMsg.includes('额度') || errorMsg.includes('用完') || errorMsg.includes('频繁')) {
						panel.appendAssistant(`⚠️ ${errorMsg}`, 'error');
					} else {
						panel.appendAssistant(`错误：${errorMsg}`, 'error');
					}
				}
			}
		});

		// 监听连接关闭
		socketTask.onClose(() => {
			if (closed) return;
			closed = true;
			if (timeoutId) clearTimeout(timeoutId);
			// 处理剩余的 buffer
			if (lineBuffer.trim()) {
				try {
					const msg = JSON.parse(lineBuffer.trim());
					if (msg.event === 'delta' && msg.text) {
						const cleaned = cleanHtml(msg.text);
						if (cleaned) {
							panel.appendAssistant(cleaned, 'stream');
						}
					}
				} catch (e) {
					console.error('Failed to parse message:', e);
				}
			}
			// 将流式状态改为完成
			panel.finishStreaming();
			resolve();
		});

		// 监听错误
		socketTask.onError((err: any) => {
			if (closed) return;
			closed = true;
			if (timeoutId) clearTimeout(timeoutId);
			const errorMsg = err?.errMsg || 'WebSocket 错误';
			// 检查是否是额度错误
			if (errorMsg.includes('额度') || errorMsg.includes('用完') || errorMsg.includes('频繁')) {
				panel.appendAssistant(`⚠️ ${errorMsg}`, 'error');
			} else {
				panel.appendAssistant(`连接错误：${errorMsg}`, 'error');
			}
			reject(new Error(errorMsg));
		});
	});
}

// 注意：extractReply 函数已不再需要，因为后端已统一返回格式
// 保留此函数以防其他地方调用，但实际已不使用
function extractReply(provider: string, data: any) {
	if (!data) {
		return '无响应';
	}

	// 后端已统一返回格式：只返回 { reply: text }
	const text = data?.reply || '';
	if (text) {
		const cleaned = cleanHtml(text);
		return cleaned || text; // 如果清理后为空，返回原始内容
	}
	
	return '无响应';
}
</script>

<style scoped>
.chat-panel-wrapper {
	width: 100%;
	/* max-width: var(--page-max); 移除最大宽度限制，填满屏幕 */
	flex: 1;
	height: 100%;
}

.chat-page-container {
	height: 100vh;
	overflow: hidden;
}

.chat-main-layout {
	/* header-height: 48px (small) + safe-top */
	/* bottom-nav-height: 64px + safe-bottom */
	padding-top: calc(48px + var(--safe-top)) !important;
	padding-bottom: calc(64px + var(--safe-bottom)) !important;
	height: 100%;
	width: 100vw;
	display: flex;
	flex-direction: column;
	box-sizing: border-box;
}

@media (min-width: 640px) {
	.chat-main-layout {
		padding-top: calc(64px + var(--safe-top)) !important;
	}
}

@media (min-width: 900px) {
	.chat-main-layout {
		padding-bottom: calc(72px + var(--safe-bottom)) !important;
	}
}
</style>
