<template>
	<tm-app>
		<view class="page-wrapper theme-page-bg">
			<yx-nav-header></yx-nav-header>

			<view class="page-content theme-container">
				<view class="theme-card">
				<view class="header">
					<tm-text :font-size="36" bold label="公告管理"></tm-text>
					<view class="header-actions">
						<tm-button
							size="small"
							class="btn-gradient"
							color="teal"
							linear="right"
							:round="12"
							:padding="[20, 20]"
							label="返回后台"
							@tap="goBack"
						></tm-button>
					</view>
				</view>

				<tm-sheet :round="16" :padding="[24, 24]" :shadow="2" class="form-card">
					<tm-text :font-size="28" bold label="新增 / 编辑公告"></tm-text>
					<view class="form-grid">
						<tm-input v-model="form.title" label="标题" placeholder="请输入标题"></tm-input>
						<view class="countdown-wrapper">
							<tm-text :font-size="24" color="#666" label="到期时间（倒计时，可留空不过期）"></tm-text>
							<view class="countdown-grid">
								<view class="countdown-input">
									<tm-input
										v-model="formDuration.days"
										type="number"
										label="天"
										placeholder="0"
										:maxlength="3"
									></tm-input>
									<tm-text :font-size="22" color="#999" label="天" class="unit"></tm-text>
								</view>
								<view class="countdown-input">
									<tm-input
										v-model="formDuration.hours"
										type="number"
										label="小时"
										placeholder="0"
										:maxlength="2"
									></tm-input>
									<tm-text :font-size="22" color="#999" label="小时" class="unit"></tm-text>
								</view>
								<view class="countdown-input">
									<tm-input
										v-model="formDuration.minutes"
										type="number"
										label="分钟"
										placeholder="0"
										:maxlength="2"
									></tm-input>
									<tm-text :font-size="22" color="#999" label="分钟" class="unit"></tm-text>
								</view>
							</view>
							<tm-text
								:font-size="22"
								color="#999"
								:label="countdownPreview"
								class="mt-6"
							></tm-text>
						</view>
					</view>
					<tm-input
						v-model="form.content"
						label="内容"
						type="textarea"
						placeholder="请输入公告内容"
						:maxlength="500"
						:show-confirm-bar="true"
					></tm-input>
					<view class="form-actions">
						<tm-button
							class="btn-gradient"
							color="teal"
							linear="right"
							:round="12"
							:padding="[24, 20]"
							:loading="saving"
							@tap="saveAnnouncement"
						>
							{{ form.id ? '保存修改' : '创建公告' }}
						</tm-button>
						<tm-button
							v-if="form.id"
							class="btn-gradient"
							color="teal"
							linear="right"
							:round="12"
							:padding="[24, 20]"
							@tap="resetForm"
						>
							取消编辑
						</tm-button>
					</view>
				</tm-sheet>

				<tm-sheet :round="16" :padding="[24, 24]" :shadow="2" class="list-card">
					<view class="list-header">
						<tm-text :font-size="28" bold label="公告列表"></tm-text>
						<tm-button
							size="small"
							class="btn-gradient"
							color="teal"
							linear="right"
							:round="12"
							:padding="[20, 20]"
							:loading="loading"
							@tap="loadList"
						>
							刷新
						</tm-button>
					</view>
					<view v-if="loading" class="py-10">
						<tm-text label="加载中..." color="#999"></tm-text>
					</view>
					<view v-else-if="list.length === 0" class="py-10">
						<tm-text label="暂无公告" color="#999"></tm-text>
					</view>
					<view v-else>
						<tm-sheet
							v-for="item in list"
							:key="item.id"
							:round="12"
							:padding="[18, 16]"
							:margin="[0, 0, 16, 0]"
							:shadow="1"
						>
							<view class="item-header">
								<tm-text :font-size="28" bold :label="item.title"></tm-text>
								<view class="item-actions">
									<tm-button
										size="mini"
										class="btn-gradient"
										color="teal"
										linear="right"
										:round="12"
										@tap="edit(item)"
									>
										编辑
									</tm-button>
									<tm-button
										size="mini"
										class="btn-gradient"
										color="teal"
										linear="right"
										:round="12"
										@tap="remove(item)"
									>
										删除
									</tm-button>
								</view>
							</view>
							<tm-text :font-size="24" color="#666" class="mt-6" :label="item.content"></tm-text>
							<tm-text
								v-if="item.expiresAt"
								:font-size="22"
								color="#999"
								class="mt-4"
								:label="`到期：${item.expiresAt}（${formatCountdown(item.expiresAt)}）`"
							></tm-text>
							<tm-text
								:font-size="20"
								color="#aaa"
								class="mt-4"
								:label="`更新时间：${item.updatedAt || '-'}`"
							></tm-text>
						</tm-sheet>
					</view>
					<view v-if="error" class="mt-6">
						<tm-text :label="error" color="red"></tm-text>
					</view>
				</tm-sheet>
			</view>
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { ref, onMounted, computed } from 'vue';
import {
	adminListAnnouncements,
	adminCreateAnnouncement,
	adminUpdateAnnouncement,
	adminDeleteAnnouncement,
	Announcement,
} from '@/services/api/announcement';

const loading = ref(false);
const saving = ref(false);
const error = ref('');
const list = ref<Announcement[]>([]);

const form = ref<{ id?: number; title: string; content: string; expiresAt: string | null }>({
	id: undefined,
	title: '',
	content: '',
	expiresAt: null,
});

const formDuration = ref<{ days: string; hours: string; minutes: string }>({
	days: '',
	hours: '',
	minutes: '',
});

const resetDuration = () => {
	formDuration.value = { days: '', hours: '', minutes: '' };
};

const resetForm = () => {
	form.value = { id: undefined, title: '', content: '', expiresAt: null };
	resetDuration();
};

const loadList = async () => {
	loading.value = true;
	error.value = '';
	try {
		const res = await adminListAnnouncements();
		list.value = (res.data as any) || [];
	} catch (e: any) {
		error.value = e?.error || e?.message || '获取公告失败';
	} finally {
		loading.value = false;
	}
};

const saveAnnouncement = async () => {
	if (!form.value.title || !form.value.content) {
		error.value = '标题和内容不能为空';
		return;
	}

	const expiresAtString = buildExpiresAt();
	saving.value = true;
	error.value = '';
	try {
		if (form.value.id) {
			await adminUpdateAnnouncement(form.value.id, {
				title: form.value.title,
				content: form.value.content,
				expiresAt: expiresAtString,
			});
		} else {
			await adminCreateAnnouncement({
				title: form.value.title,
				content: form.value.content,
				expiresAt: expiresAtString,
			});
		}
		resetForm();
		await loadList();
	} catch (e: any) {
		error.value = e?.error || e?.message || '保存失败';
	} finally {
		saving.value = false;
	}
};

const edit = (item: Announcement) => {
	form.value = {
		id: item.id,
		title: item.title,
		content: item.content,
		expiresAt: item.expiresAt || null,
	};
	syncDurationFromExpires(item.expiresAt);
};

const remove = (item: Announcement) => {
	uni.showModal({
		title: '删除确认',
		content: `确定删除公告「${item.title}」吗？`,
		success: async (res) => {
			if (res.confirm) {
				try {
					await adminDeleteAnnouncement(item.id);
					await loadList();
				} catch (e: any) {
					error.value = e?.error || e?.message || '删除失败';
				}
			}
		},
	});
};

const goBack = () => {
	uni.navigateTo({
		url: '/pages/admin/dashboard',
	});
};

const pad = (num: number) => String(num).padStart(2, '0');

const parseDateTime = (input: string | null) => {
	if (!input) return null;
	const normalized = input.replace(' ', 'T');
	const date = new Date(normalized);
	if (Number.isNaN(date.getTime())) return null;
	return date;
};

const formatDateTime = (date: Date) => {
	return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())} ${pad(
		date.getHours()
	)}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`;
};

const syncDurationFromExpires = (expiresAt: string | null) => {
	if (!expiresAt) {
		resetDuration();
		return;
	}
	const target = parseDateTime(expiresAt);
	if (!target) {
		resetDuration();
		return;
	}
	const diff = target.getTime() - Date.now();
	if (diff <= 0) {
		resetDuration();
		return;
	}
	const minutesTotal = Math.floor(diff / (60 * 1000));
	const days = Math.floor(minutesTotal / (24 * 60));
	const hours = Math.floor((minutesTotal - days * 24 * 60) / 60);
	const minutes = minutesTotal - days * 24 * 60 - hours * 60;
	formDuration.value = {
		days: String(days),
		hours: String(hours),
		minutes: String(minutes),
	};
};

const buildExpiresAt = () => {
	const days = Number(formDuration.value.days) || 0;
	const hours = Number(formDuration.value.hours) || 0;
	const minutes = Number(formDuration.value.minutes) || 0;
	const totalMinutes = days * 24 * 60 + hours * 60 + minutes;
	if (totalMinutes <= 0) return null;
	const target = new Date(Date.now() + totalMinutes * 60 * 1000);
	return formatDateTime(target);
};

const formatCountdown = (expiresAt: string | null) => {
	if (!expiresAt) return '不限期';
	const target = parseDateTime(expiresAt);
	if (!target) return '时间格式错误';
	const diff = target.getTime() - Date.now();
	if (diff <= 0) return '已过期';
	const days = Math.floor(diff / (24 * 60 * 60 * 1000));
	const hours = Math.floor((diff % (24 * 60 * 60 * 1000)) / (60 * 60 * 1000));
	const minutes = Math.floor((diff % (60 * 60 * 1000)) / (60 * 1000));
	return `${days}天${hours}小时${minutes}分钟`;
};

const countdownPreview = computed(() => {
	const expiresAt = buildExpiresAt();
	if (!expiresAt) return '不设置则长期有效';
	const remain = formatCountdown(expiresAt);
	return `当前设置将于 ${expiresAt} 到期（${remain}）`;
});

onMounted(() => {
	loadList();
});
</script>

<style scoped>
.page-wrapper {
	padding-bottom: 40rpx;
}
.page-content {
	/* theme-container 负责内边距与宽度 */
}
.theme-card {
	padding: 24px 20px 28px;
}
.header {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 16px;
}
.header-actions {
	display: flex;
	gap: 12px;
}
.form-card,
.list-card {
	margin-top: 16px;
}
.form-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	gap: 12px;
	margin: 12px 0;
}
.countdown-wrapper {
	display: flex;
	flex-direction: column;
	gap: 8px;
}
.countdown-grid {
	display: grid;
	grid-template-columns: repeat(3, minmax(80px, 1fr));
	gap: 10px;
}
.countdown-input {
	display: grid;
	grid-template-columns: 1fr auto;
	align-items: center;
	gap: 6px;
}
.countdown-input .unit {
	white-space: nowrap;
}
.form-actions {
	display: flex;
	gap: 12px;
	margin-top: 12px;
}
.list-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 12px;
}
.item-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 12px;
}
.item-actions {
	display: flex;
	gap: 10px;
}
.mt-6 {
	margin-top: 6px;
}
</style>

