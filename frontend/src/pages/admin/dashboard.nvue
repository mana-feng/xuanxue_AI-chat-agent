<script setup lang="ts">
import { ref, onMounted, computed } from 'vue';
import { useUserStore } from '@/store/user';
import { getAdminStats, type AdminStats } from '@/services/api/admin';

const userStore = useUserStore();
const stats = ref<AdminStats | null>(null);

// navbar 高度（rpx），与 yx-nav-header 中的 navbarHeight 保持一致
const navbarHeight = 40;

// 计算页面内容的 padding-top，避免被 fixed 的 header 遮挡
const pageContentStyle = computed(() => {
	return {
		paddingTop: `${navbarHeight + 20}rpx` // navbar高度 + 原有padding
	};
});

onMounted(() => {
	// 先恢复登录状态
	userStore.restoreAuth();
	
	// 检查是否为管理员
	if (!userStore.isAdmin) {
		uni.reLaunch({
			url: '/pages/auth/auth'
		});
		return;
	}
	
	loadStats();
});

async function loadStats() {
	try {
		const res = await getAdminStats();
		if (res.success && res.data) {
			stats.value = res.data;
		}
	} catch (err) {
		console.error('加载统计数据失败:', err);
		uni.showToast({
			title: '加载失败',
			icon: 'none'
		});
	}
}

function goToUsers() {
	uni.navigateTo({
		url: '/pages/admin/users'
	});
}

function goToRecords() {
	uni.navigateTo({
		url: '/pages/admin/records'
	});
}

function goToAnnouncements() {
	uni.navigateTo({
		url: '/pages/admin/announcements'
	});
}

function goToLLMConfig() {
	uni.navigateTo({
		url: '/pages/admin/llm-config'
	});
}

function goToLLMQuota() {
	uni.navigateTo({
		url: '/pages/admin/llm-quota'
	});
}

function goToEmailConfig() {
	uni.navigateTo({
		url: '/pages/admin/email-config'
	});
}

function goToHome() {
	uni.reLaunch({
		url: '/pages/index/index'
	});
}

function handleLogout() {
	userStore.logout();
	uni.reLaunch({
		url: '/pages/auth/auth'
	});
}
</script>

