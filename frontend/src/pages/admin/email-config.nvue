<template>
	<tm-app>
		<view class="page-wrapper">
			<yx-nav-header></yx-nav-header>

			<view class="page-content" :style="pageContentStyle">
				<view class="header">
					<tm-text :font-size="42" :bold="true" color="#2d3748" label="邮箱服务配置"></tm-text>
					<view class="header-actions">
						<tm-button size="small" type="primary" :round="12" :padding="[20, 24]" label="返回后台" @tap="goBack"></tm-button>
					</view>
				</view>

				<tm-sheet :round="16" :shadow="4" :padding="[32, 28]" class="config-card" :follow-dark="true">
					<view class="status-row">
						<tm-text :font-size="30" :bold="true" color="#2d3748" :label="configured ? '已配置' : '未配置'"></tm-text>
						<tm-tag
							:label="configured ? '可发送验证码' : '未启用'"
							:color="configured ? 'green' : 'grey'"
							size="small"
							:round="8"
						></tm-tag>
					</view>

					<tm-input 
						v-model="form.host" 
						label="SMTP 主机" 
						placeholder="如 smtp.qq.com" 
						:margin="[24, 0, 0, 0]"
						:round="12"
						:border="1"
					/>
					<tm-input
						v-model.number="form.port"
						label="SMTP 端口"
						type="number"
						placeholder="如 465"
						:margin="[24, 0, 0, 0]"
						:round="12"
						:border="1"
					/>
					<tm-input
						v-model="form.user"
						label="SMTP 账号"
						placeholder="邮箱账号"
						:margin="[24, 0, 0, 0]"
						:round="12"
						:border="1"
					/>
					<tm-input
						v-model="form.pass"
						label="SMTP 密码/授权码"
						type="password"
						placeholder="请输入密码或授权码"
						:margin="[24, 0, 0, 0]"
						:round="12"
						:border="1"
					/>
					<tm-input
						v-model="form.from"
						label="发件邮箱地址"
						placeholder="用于邮件 From 邮箱"
						:margin="[24, 0, 0, 0]"
						:round="12"
						:border="1"
					/>
					<tm-input
						v-model="form.fromName"
						label="发件人名称（可选，用于显示）"
						placeholder="如：Ai八字 或 你的姓名"
						:margin="[24, 0, 0, 0]"
						:round="12"
						:border="1"
					/>

					<view class="tip-container">
						<tm-icon name="information-circle" :font-size="24" color="#667eea" :margin="[0, 12, 0, 0]"></tm-icon>
						<tm-text
							:font-size="24"
							color="#718096"
							label="填写后点击保存，密码不会回显；若需更换密码请重新填写。"
						></tm-text>
					</view>

					<tm-button
						type="primary"
						block
						:loading="saving"
						:margin="[40, 0, 0, 0]"
						:round="12"
						:height="96"
						:font-size="32"
						:bold="true"
						label="保存配置"
						@tap="handleSave"
					></tm-button>
				</tm-sheet>
			</view>
		</view>
	</tm-app>
</template>

<script setup lang="ts">
import { onMounted, reactive, ref, computed } from 'vue';
import { useUserStore } from '@/store/user';
import { getAdminEmailConfig, updateAdminEmailConfig } from '@/api/admin';

const userStore = useUserStore();

const configured = ref(false);
const form = reactive({
	host: '',
	port: 0,
	user: '',
	pass: '',
	from: '',
	fromName: ''
});

const loading = ref(false);
const saving = ref(false);

// navbar 高度（rpx），与 yx-nav-header 中的 navbarHeight 保持一致
const navbarHeight = 40;

// 计算页面内容的 padding-top，避免被 fixed 的 header 遮挡
const pageContentStyle = computed(() => {
	return {
		paddingTop: `${navbarHeight + 20}rpx` // navbar高度 + 原有padding
	};
});

onMounted(() => {
	userStore.restoreAuth();
	if (!userStore.isAdmin) {
		uni.reLaunch({
			url: '/pages/auth/auth'
		});
		return;
	}
	loadConfig();
});

async function loadConfig() {
	loading.value = true;
	try {
		const res = await getAdminEmailConfig();
		if (res.success && res.data) {
			const cfg = res.data;
			configured.value = !!cfg.configured;
			form.host = cfg.host || '';
			form.port = cfg.port || 0;
			form.user = cfg.user || '';
			form.from = cfg.from || '';
			form.fromName = cfg.fromName || '';
			form.pass = '';
		}
	} catch (err) {
		console.error('获取邮箱配置失败', err);
		uni.showToast({ title: '加载失败', icon: 'none' });
	} finally {
		loading.value = false;
	}
}

async function handleSave() {
	if (!form.host || !form.port || !form.user || !form.from) {
		uni.showToast({ title: '请填写完整配置', icon: 'none' });
		return;
	}
	if (Number(form.port) <= 0) {
		uni.showToast({ title: '端口必须为正数', icon: 'none' });
		return;
	}
	saving.value = true;
	try {
		await updateAdminEmailConfig({
			host: form.host.trim(),
			port: Number(form.port),
			user: form.user.trim(),
			pass: form.pass,
			from: form.from.trim(),
			fromName: form.fromName.trim()
		});
		uni.showToast({ title: '保存成功', icon: 'success' });
		await loadConfig();
	} catch (err) {
		console.error('保存邮箱配置失败', err);
		const msg = err?.error || '保存失败';
		uni.showToast({ title: msg, icon: 'none' });
	} finally {
		saving.value = false;
	}
}

function goBack() {
	uni.navigateBack({
		fail: () => {
			uni.reLaunch({ url: '/pages/admin/dashboard' });
		}
	});
}
</script>

<style scoped>
.page-wrapper {
	min-height: 100vh;
	/* background-color: #f5f5f5; */ /* 移除硬编码背景色，使用 tm-app 的背景 */
}

.page-content {
	padding: 20rpx;
	/* padding-top 通过 :style 动态设置，与 navbar 高度联动 */
}

.header {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 20rpx;
}

.header-actions {
	display: flex;
	flex-direction: row;
	align-items: center;
}

.status-row {
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
}

.tip-text {
	margin-top: 20rpx;
}
</style>

