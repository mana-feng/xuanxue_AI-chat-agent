}

.actions-row {
	display: flex;
	gap: 12px;
	flex-wrap: nowrap;
	align-items: center;
	justify-content: flex-start;
	overflow-x: auto;
}

.actions-row :deep(.tm-button) {
	display: inline-flex !important;
	width: auto !important;
	min-width: 0 !important;
	flex: 0 0 auto !important;
	max-width: none !important;
	white-space: nowrap;
}

.actions-row :deep(.tm-button__body) {
	display: inline-flex !important;
	width: auto !important;
}

.gua-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	gap: 12px;
}

.gua-card {
	padding: 12px;
	border: 1px solid #e5e7eb;
	border-radius: 12px;
