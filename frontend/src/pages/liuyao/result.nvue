	display: flex;
	align-items: center;
	gap: 8px;
	margin-top: 4px;
	color: #94a3b8;
}

.table-wrapper {
	width: 100%;
	overflow-x: auto;
	box-sizing: border-box;
	scrollbar-width: thin;
}

.yao-table {
	min-width: 860px;
	width: 100%;
	border: 1px solid #e5e7eb;
	border-radius: 12px;
	overflow: hidden;
	background: #fff;
}

.yao-row {
	display: grid;
	/* 列宽（按新顺序）：爻位 | 六神 | 六亲 | 爻 | 伏藏 | 动静/世应 | 变爻 | 变爻动静/世应 */
	grid-template-columns: 70px 120px 1fr 70px 1fr 120px 120px 160px;
	gap: 0;
	align-items: center;
	border-bottom: 1px solid #f1f5f9;
}

.yao-row:last-child {
	border-bottom: none;
