# ================================================================
# Frontend Environment Configuration
# ================================================================
# Copy this file to .env and adjust values for your environment.
# Usage: cp .env.example .env
#
# SCENARIOS:
# - Local Development: Use defaults below (localhost, HTTP)
# - Production: Build-time config, update VITE_API_BASE_URL
# - Docker Deploy: Configure API URLs to backend service
# ================================================================

# ----------------------------------------------------------------
# Development Server Configuration
# ----------------------------------------------------------------
# VITE_DEV_PORT: Port for Vite development server
#   - Default: 3000
#   - Change if port is in use
VITE_DEV_PORT=3000

# ----------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------
# VITE_API_BASE_URL: Base URL for API requests in production
#   - This is used at BUILD time, not dev time
#   - Local dev: Not needed (uses Vite proxy)
#   - Production: https://api.yourdomain.com
#   - Docker: http://backend:3001 (service name)
#   - Note: For H5 builds, this URL is baked into the bundle
VITE_API_BASE_URL=http://localhost:3001

# VITE_API_PROXY_TARGET: Proxy target for Vite dev server
#   - Used only in development mode
#   - Should point to backend server
#   - Default: http://localhost:3001
VITE_API_PROXY_TARGET=http://localhost:3001

# ----------------------------------------------------------------
# API Signature Configuration
# ----------------------------------------------------------------
# VITE_API_SIGNATURE_DISABLED: Disable API signature in requests
#   - false: Enable signature (recommended for production)
#   - true: Disable for local testing only
VITE_API_SIGNATURE_DISABLED=false

# VITE_API_SIGNATURE_SECRET: Secret for API request signing
#   - MUST match API_SIGNATURE_SECRET in backend .env
#   - Used to generate request signatures
#   - Leave empty in production (use backend verification only)
#   - Local dev: Can use same value as backend for testing
VITE_API_SIGNATURE_SECRET=

# ----------------------------------------------------------------
# Content Security Policy (CSP)
# ----------------------------------------------------------------
# VITE_CSP_NONCE: Nonce value for CSP (optional)
#   - Used for inline script/style whitelisting
#   - Leave empty to use default
VITE_CSP_NONCE=

# VITE_CSP_CONNECT_SRC: Additional allowed connection sources
#   - Leave empty for default (self + ws/wss)
#   - Add WebSocket URLs, API endpoints as needed
#   - Example: ws://localhost:3001,wss://api.yourdomain.com
VITE_CSP_CONNECT_SRC=

# VITE_CSP_SCRIPT_HASHES: Allowed script hashes (comma-separated)
#   - For third-party inline scripts
#   - Format: sha256-xxx,sha384-xxx
VITE_CSP_SCRIPT_HASHES=

# VITE_CSP_ALLOW_UNSAFE_INLINE: Allow inline scripts
#   - true: Default for development
#   - false: Recommended for production
VITE_CSP_ALLOW_UNSAFE_INLINE=true

# VITE_CSP_ALLOW_UNSAFE_STYLE_INLINE: Allow inline styles
#   - false: Default
#   - true: May be needed for some component libraries
VITE_CSP_ALLOW_UNSAFE_STYLE_INLINE=false

# VITE_CSP_ALLOW_UNSAFE_EVAL: Allow eval() in scripts
#   - true: Default for development (some libs need it)
#   - false: Recommended for production
VITE_CSP_ALLOW_UNSAFE_EVAL=true
