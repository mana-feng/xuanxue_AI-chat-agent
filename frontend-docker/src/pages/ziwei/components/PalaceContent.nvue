<template>
	<view class="palace-content" :class="{ 'highlight-bg': isHighlighted }">
		<view class="top-gods">
			<text class="god-text">{{ formatGod(palace.boshi12) }}</text>
			<text class="god-text">{{ formatGod(displayJiangqian12) }}</text>
			<text class="god-text">{{ formatGod(displaySuiqian12) }}</text>
		</view>

		<view v-if="dynamicLabels && dynamicLabels.length" class="dynamic-label-grid">
			<text v-for="(label, idx) in dynamicLabels" :key="'label-' + idx" class="dynamic-label" :class="label.type">
				{{ label.text }}
			</text>
		</view>

		<view class="content-grid">
			<view class="stars-col major-col">
				<view v-for="(star, index) in palace.majorStars" :key="'major' + index" class="star-row">
					<text class="star-name major-star" :class="{ 'star-red': star.mutagen }">{{ star.name }}</text>
					<text v-if="star.brightness" class="star-bright">{{ star.brightness }}</text>
					<text v-if="star.mutagen" class="star-mutagen-inline">{{ star.mutagen }}</text>
					<text
						v-for="(tag, tagIndex) in scopeMutagenTags(star.name)"
						:key="'major-tag-' + index + '-' + tagIndex"
						class="scope-mutagen-tag"
						:class="tag.scope"
					>
						{{ tag.label }}
					</text>
				</view>
			</view>

				<view class="center-col">
					<view v-if="dynamicStars && dynamicStars.length" class="dynamic-stars">
						<text v-for="(star, idx) in dynamicStars" :key="'dyn-star-' + idx" class="dynamic-star-tag">{{ star }}</text>
					</view>
					<text class="palace-name">{{ displayPalaceName(palace.name) }}</text>
					<text v-if="palace.isBodyPalace" class="body-palace">身宫</text>
					<text class="palace-life">{{ palace.changsheng12 }}</text>
					<text class="palace-decade">大限{{ palace.decadal.range.join('-') }}</text>
					<text v-if="palace.ages" class="palace-ages">{{ formatAges(palace.ages) }}</text>
				</view>

			<view class="stars-col minor-col">
				<view v-for="(star, index) in palace.minorStars" :key="'minor' + index" class="star-row">
					<text class="star-name minor-star">{{ star.name }}</text>
					<text v-if="star.brightness" class="star-bright">{{ star.brightness }}</text>
					<text v-if="star.mutagen" class="star-mutagen-inline">{{ star.mutagen }}</text>
					<text
						v-for="(tag, tagIndex) in scopeMutagenTags(star.name)"
						:key="'minor-tag-' + index + '-' + tagIndex"
						class="scope-mutagen-tag"
						:class="tag.scope"
					>
						{{ tag.label }}
					</text>
				</view>

				<view v-for="(star, index) in palace.adjectiveStars" :key="'adj' + index" class="star-row">
					<text class="star-name adj-star">{{ star.name }}</text>
				</view>
			</view>
		</view>

		<view class="bottom-meta">
			<text class="stem">{{ palace.heavenlyStem }}</text>
			<text class="branch">{{ palace.earthlyBranch }}</text>
		</view>

		<view v-if="flyMutagenTags.length" class="fly-mutagen-badge">
			<text v-for="(tag, idx) in flyMutagenTags" :key="'fly-' + idx" class="fly-text">{{ tag }}</text>
		</view>
	</view>
</template>

<script lang="ts" setup>
import { computed } from 'vue';

const props = defineProps<{
	palace: any;
	displayJiangqian12?: string;
	displaySuiqian12?: string;
	dynamicLabels?: Array<{ text: string; type: string }>;
	dynamicStars?: string[];
	flyMutagens?: string[];
	scopeMutagens?: Record<string, Array<{ scope: string; label: string }>>;
	isHighlighted?: boolean;
}>();

const formatAges = (ages: number[]) => `小限${ages.join(',')}`;

const formatGod = (raw: string | undefined) => (raw || '').replace(/\s+/g, ' ');
const displayPalaceName = (name: string | undefined) => (name === '仆役' ? '交友' : (name || ''));
const displayJiangqian12 = computed(() => props.displayJiangqian12 || props.palace?.jiangqian12 || '');
const displaySuiqian12 = computed(() => props.displaySuiqian12 || props.palace?.suiqian12 || '');

const scopeMutagenTags = (starName: string) => {
	const tags = props.scopeMutagens?.[starName];
	return Array.isArray(tags) ? tags : [];
};

const flyMutagenTags = computed(() =>
	Array.isArray(props.flyMutagens)
		? props.flyMutagens.filter((item): item is string => typeof item === 'string' && item.length > 0)
		: [],
);
</script>

