<template>
	<view class="timeline-container">
		<view class="timeline-line">
			<view class="line-label">
				<text class="line-title">大限</text>
				<text class="line-badge">解析</text>
			</view>
				<scroll-view
					ref="decadeScrollRef"
					scroll-x
					:enable-flex="true"
					:class="['timeline-scroll', { dragging: isDragging('decade') }]"
					:scroll-into-view="currentDecadeId"
					:show-scrollbar="false"
					@mousedown="startDrag('decade', $event)"
					@mousemove="onDrag('decade', $event)"
					@mouseup="endDrag('decade')"
					@mouseleave="endDrag('decade')"
					@wheel="handleWheel('decade', $event)"
				>
					<view class="timeline-row">
						<view
							v-for="(dec, index) in sortedDecades"
							:id="'dec-' + index"
							:key="dec.range[0]"
							class="timeline-item decade-item"
							:class="{ active: isCurrentDecade(dec) }"
							@click="selectDecade(dec)"
						>
							<text class="timeline-label">{{ dec.range.join('-') }}</text>
							<text class="timeline-ganzhi">{{ dec.ganZhi }}</text>
						<text class="timeline-meta">{{ dec.palaceName }}</text>
					</view>
					<view class="timeline-tail-spacer"></view>
				</view>
			</scroll-view>
		</view>

		<view v-if="viewMode !== 'origin'" class="timeline-line">
			<view class="line-label">
				<text class="line-title">流年</text>
				<text class="line-badge">解析</text>
			</view>
				<scroll-view
					ref="yearScrollRef"
					scroll-x
					:enable-flex="true"
					:class="['timeline-scroll', 'year-scroll', { dragging: isDragging('year') }]"
					:scroll-into-view="currentYearId"
					:show-scrollbar="false"
					@mousedown="startDrag('year', $event)"
					@mousemove="onDrag('year', $event)"
					@mouseup="endDrag('year')"
					@mouseleave="endDrag('year')"
					@wheel="handleWheel('year', $event)"
				>
					<view class="timeline-row">
						<view
							v-for="year in yearList"
							:id="year.id"
							:key="year.id"
							class="timeline-item year-item"
							:class="{ active: isCurrentYear(year) }"
							@click="selectYear(year)"
						>
							<text class="timeline-label">{{ year.year }}</text>
							<text class="timeline-sub">{{ year.age }}岁</text>
						<text class="timeline-ganzhi">{{ year.ganZhi }}</text>
					</view>
					<view class="timeline-tail-spacer"></view>
				</view>
			</scroll-view>
		</view>

		<view v-if="viewMode === 'yearly' || viewMode === 'monthly' || viewMode === 'daily'" class="timeline-line">
			<view class="line-label">
				<text class="line-title">流月</text>
			</view>
				<scroll-view
					ref="monthScrollRef"
					scroll-x
					:enable-flex="true"
					:class="['timeline-scroll', 'month-scroll', { dragging: isDragging('month') }]"
					:scroll-into-view="currentMonthId"
					:show-scrollbar="false"
					@mousedown="startDrag('month', $event)"
					@mousemove="onDrag('month', $event)"
					@mouseup="endDrag('month')"
					@mouseleave="endDrag('month')"
					@wheel="handleWheel('month', $event)"
				>
					<view class="timeline-row">
						<view
							v-for="month in monthList"
							:id="month.id"
							:key="month.id"
							class="timeline-item month-item"
							:class="{ active: isCurrentMonth(month) }"
							@click="selectMonth(month)"
						>
							<text class="timeline-label">{{ month.monthName }}</text>
							<text class="timeline-ganzhi">{{ month.ganZhi }}</text>
					</view>
					<view class="timeline-tail-spacer"></view>
				</view>
			</scroll-view>
		</view>
	</view>
</template>

<script lang="ts" setup>
import { computed, defineProps, defineEmits, watch, ref, reactive, onBeforeUnmount } from 'vue';
import { Lunar, LunarYear, Solar } from 'lunar-javascript';

const props = defineProps<{
	astrolabe: any;
	viewMode: string;
	targetDate: Date;
}>();

const emit = defineEmits(['update:selection']);

const MONTH_NAMES = ['正月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '冬月', '腊月'];

function formatMonthName(monthKey: number): string {
	const idx = Math.abs(monthKey) - 1;
	const base = MONTH_NAMES[idx] || `${Math.abs(monthKey)}月`;
	return monthKey < 0 ? `闰${base}` : base;
}

function formatPalaceName(name: string): string {
	return name === '仆役' ? '交友' : name;
}

function normalizeDate(date: Date) {
	return new Date(date.getTime());
}

function emitSelection(mode: string, date: Date) {
	const normalized = normalizeDate(date);
	emit('update:selection', { mode, date: normalized });
}

type DynamicScope = 'decadal' | 'yearly' | 'monthly' | 'daily';
type ScrollTrack = 'decade' | 'year' | 'month';
type YearScopeBounds = { start: Date; next: Date | null };
type TimelineYearItem = {
	id: string;
	year: number;
	age: number;
	ganZhi: string;
	token: string;
	date: Date;
	exactStart: boolean;
};
type DragMeta = {
	active: boolean;
	startX: number;
	startLeft: number;
	moved: boolean;
	el: HTMLElement | null;
};

const decadeScrollRef = ref<any>(null);
const yearScrollRef = ref<any>(null);
const monthScrollRef = ref<any>(null);

const dragState = reactive<Record<ScrollTrack, DragMeta>>({
	decade: { active: false, startX: 0, startLeft: 0, moved: false, el: null },
	year: { active: false, startX: 0, startLeft: 0, moved: false, el: null },
	month: { active: false, startX: 0, startLeft: 0, moved: false, el: null },
});

const suppressClickUntil = reactive<Record<ScrollTrack, number>>({
	decade: 0,
	year: 0,
	month: 0,
});

const H5_DRAG_CLICK_GUARD_MS = 140;
const scrollElementCache: Record<ScrollTrack, HTMLElement | null> = {
	decade: null,
	year: null,
	month: null,
};
const activeDragTrack = ref<ScrollTrack | null>(null);

const getTrackRef = (track: ScrollTrack) => {
	switch (track) {
		case 'decade':
			return decadeScrollRef;
		case 'year':
			return yearScrollRef;
		case 'month':
			return monthScrollRef;
	}
};

const findScrollableElement = (root: HTMLElement | null): HTMLElement | null => {
	if (!root) return null;
	const candidates = [root, ...Array.from(root.querySelectorAll<HTMLElement>('*'))];
	return (
		candidates.find((el) => {
			if (!(el instanceof HTMLElement)) return false;
			return el.scrollWidth - el.clientWidth > 2;
		}) || null
	);
};

const isUsableScrollElement = (el: HTMLElement | null): el is HTMLElement => {
	if (!el) return false;
	if (!el.isConnected) return false;
	return el.scrollWidth - el.clientWidth > 2;
};

const resolveScrollElement = (track: ScrollTrack): HTMLElement | null => {
	let resolved: HTMLElement | null = null;
	// #ifdef H5
	const cached = scrollElementCache[track];
	if (isUsableScrollElement(cached)) {
		return cached;
	}
	const targetRef = getTrackRef(track);
	const instance = targetRef?.value;
	const root = (instance?.$el || instance) as HTMLElement | null | undefined;
	if (!root || !(root instanceof HTMLElement)) return resolved;
	const el = findScrollableElement(root);
	scrollElementCache[track] = el;
	resolved = el;
	// #endif
	return resolved;
};

const eventX = (event: any): number => {
	if (typeof event?.clientX === 'number') return event.clientX;
	if (typeof event?.detail?.x === 'number') return event.detail.x;
	const touch = event?.changedTouches?.[0] || event?.touches?.[0];
	if (touch && typeof touch.clientX === 'number') return touch.clientX;
	return 0;
};

const isDragging = (track: ScrollTrack) => dragState[track].active;

const shouldIgnoreClick = (track: ScrollTrack) => {
	let ignore = false;
	// #ifdef H5
	ignore = Date.now() < suppressClickUntil[track];
	// #endif
	return ignore;
};

const bindGlobalDragListeners = () => {
	// #ifdef H5
	window.addEventListener('mousemove', handleGlobalMouseMove);
	window.addEventListener('mouseup', handleGlobalMouseUp);
	window.addEventListener('blur', handleGlobalMouseUp);
	// #endif
};

const unbindGlobalDragListeners = () => {
	// #ifdef H5
	window.removeEventListener('mousemove', handleGlobalMouseMove);
	window.removeEventListener('mouseup', handleGlobalMouseUp);
	window.removeEventListener('blur', handleGlobalMouseUp);
	// #endif
};

const startDrag = (track: ScrollTrack, event: any) => {
	// #ifdef H5
	const el = resolveScrollElement(track);
	if (!el) return;
	if (activeDragTrack.value && activeDragTrack.value !== track) {
		closeDrag(activeDragTrack.value);
	}
	const state = dragState[track];
	state.active = true;
	state.moved = false;
	state.el = el;
	state.startX = eventX(event);
	state.startLeft = el.scrollLeft;
	activeDragTrack.value = track;
	bindGlobalDragListeners();
	if (typeof event?.preventDefault === 'function') {
		event.preventDefault();
	}
	// #endif
};

const onDrag = (track: ScrollTrack, event: any) => {
	// #ifdef H5
	const state = dragState[track];
	if (!state.active) return;
	const el = isUsableScrollElement(state.el) ? state.el : resolveScrollElement(track);
	if (!el) return;
	const deltaX = eventX(event) - state.startX;
	if (Math.abs(deltaX) > 3) {
		state.moved = true;
	}
	el.scrollLeft = state.startLeft - deltaX;
	if (typeof event?.preventDefault === 'function') {
		event.preventDefault();
	}
	// #endif
};

const closeDrag = (track: ScrollTrack) => {
	// #ifdef H5
	const state = dragState[track];
	if (!state.active) return;
	state.active = false;
	if (state.moved) {
		suppressClickUntil[track] = Date.now() + H5_DRAG_CLICK_GUARD_MS;
	}
	state.moved = false;
	state.el = null;
	if (activeDragTrack.value === track) {
		activeDragTrack.value = null;
		unbindGlobalDragListeners();
	}
	// #endif
};

const handleGlobalMouseMove = (event: MouseEvent) => {
	// #ifdef H5
	const track = activeDragTrack.value;
	if (!track) return;
	onDrag(track, event);
	// #endif
};

const handleGlobalMouseUp = () => {
	// #ifdef H5
	const track = activeDragTrack.value;
	if (!track) return;
	closeDrag(track);
	// #endif
};

const endDrag = (track: ScrollTrack) => {
	closeDrag(track);
};

const handleWheel = (track: ScrollTrack, event: any) => {
	// #ifdef H5
	const el = resolveScrollElement(track);
	if (!el) return;
	const deltaX = Number(event?.deltaX || 0);
	const deltaY = Number(event?.deltaY || 0);
	const primary = Math.abs(deltaX) > Math.abs(deltaY) ? deltaX : deltaY;
	const deltaMode = Number(event?.deltaMode || 0);
	const factor = deltaMode === 1 ? 16 : deltaMode === 2 ? el.clientWidth : 1;
	const delta = primary * factor;
	if (!delta) return;
	const before = el.scrollLeft;
	el.scrollLeft = before + delta;
	if (el.scrollLeft !== before && typeof event?.preventDefault === 'function') {
		event.preventDefault();
	}
	// #endif
};

function toDateOnly(date: Date): Date {
	return new Date(date.getFullYear(), date.getMonth(), date.getDate());
}

function addDays(date: Date, offset: number): Date {
	const next = new Date(date.getTime());
	next.setDate(next.getDate() + offset);
	return next;
}

function toDateKey(date: Date): string {
	const y = date.getFullYear();
	const m = String(date.getMonth() + 1).padStart(2, '0');
	const d = String(date.getDate()).padStart(2, '0');
	return `${y}-${m}-${d}`;
}

function buildDateInYear(year: number, baseDate: Date): Date {
	const month = baseDate.getMonth();
	const day = baseDate.getDate();
	const next = new Date(year, month, day);
	// Handle dates like Feb 29 in non-leap years.
	if (next.getMonth() !== month) {
		return new Date(year, month + 1, 0);
	}
	return next;
}

function scopeToken(horoscope: any, scope: DynamicScope): string {
	const data = horoscope?.[scope];
	if (!data) return '';
	return `${data.index}-${data.heavenlyStem}-${data.earthlyBranch}`;
}

const horoscopeCache = new Map<string, any>();
const yearlyScopeBoundsCache = new Map<string, YearScopeBounds>();
const yearListCache = new Map<string, any[]>();
const monthListCache = new Map<string, any[]>();

function buildDecadalFastYearList(
	currentDecade: any,
	now: Date,
	currentAge: number,
): TimelineYearItem[] {
	const startAge = currentDecade.range[0];
	const endAge = currentDecade.range[1];
	const total = Math.max(0, endAge - startAge + 1);
	const currentSolarYear = now.getFullYear();
	const startYear = currentSolarYear + (startAge - currentAge);
	const years: TimelineYearItem[] = [];
	for (let i = 0; i < total; i += 1) {
		const age = startAge + i;
		const year = startYear + i;
		const date = buildDateInYear(year, now);
		const h = getHoroscopeAt(date);
		years.push({
			id: `year-${date.getTime()}-${age}`,
			year,
			age,
			ganZhi: h?.yearly ? `${h.yearly.heavenlyStem}${h.yearly.earthlyBranch}` : '',
			token: scopeToken(h, 'yearly'),
			date,
			exactStart: true,
		});
	}
	return years;
}

watch(
	() => props.astrolabe,
	() => {
		unbindGlobalDragListeners();
		activeDragTrack.value = null;
		dragState.decade.active = false;
		dragState.year.active = false;
		dragState.month.active = false;
		dragState.decade.moved = false;
		dragState.year.moved = false;
		dragState.month.moved = false;
		dragState.decade.el = null;
		dragState.year.el = null;
		dragState.month.el = null;
		horoscopeCache.clear();
		yearlyScopeBoundsCache.clear();
		yearListCache.clear();
		monthListCache.clear();
		scrollElementCache.decade = null;
		scrollElementCache.year = null;
		scrollElementCache.month = null;
	},
);

onBeforeUnmount(() => {
	unbindGlobalDragListeners();
	activeDragTrack.value = null;
	horoscopeCache.clear();
	yearlyScopeBoundsCache.clear();
	yearListCache.clear();
	monthListCache.clear();
	scrollElementCache.decade = null;
	scrollElementCache.year = null;
	scrollElementCache.month = null;
});

function getHoroscopeAt(date: Date) {
	if (!props.astrolabe) return null;
	const normalized = toDateOnly(date);
	const key = toDateKey(normalized);
	if (horoscopeCache.has(key)) {
		return horoscopeCache.get(key) || null;
	}
	try {
		const result = props.astrolabe.horoscope(new Date(normalized.getTime()));
		horoscopeCache.set(key, result);
		return result;
	} catch (e) {
		horoscopeCache.set(key, null);
		return null;
	}
}

function firstDayOfLunarYear(lunarYear: number): Date | null {
	try {
		const yearData = LunarYear.fromYear(lunarYear);
		const months = yearData?.getMonths?.();
		if (!Array.isArray(months)) return null;
		const firstMonth = months.find((m: any) => m?.getMonth?.() === 1 && !m?.isLeap?.());
		if (!firstMonth) return null;
		const solar = Solar.fromJulianDay(firstMonth.getFirstJulianDay());
		return new Date(solar.getYear(), solar.getMonth() - 1, solar.getDay());
	} catch (e) {
		return null;
	}
}

function resolveYearScopeBounds(baseDate: Date, _yearlyToken: string): YearScopeBounds {
	const normalized = toDateOnly(baseDate);
	const lunarYear = Lunar.fromDate(normalized).getYear();
	const cacheKey = String(lunarYear);
	const cached = yearlyScopeBoundsCache.get(cacheKey);
	if (cached) {
		return {
			start: new Date(cached.start.getTime()),
			next: cached.next ? new Date(cached.next.getTime()) : null,
		};
	}

	const yearStart = firstDayOfLunarYear(lunarYear) || normalized;
	let nextYearStart = firstDayOfLunarYear(lunarYear + 1);
	if (!nextYearStart || nextYearStart.getTime() <= yearStart.getTime()) {
		nextYearStart = addDays(yearStart, 366);
	}

	const result: YearScopeBounds = { start: yearStart, next: nextYearStart || null };
	yearlyScopeBoundsCache.set(cacheKey, result);
	return {
		start: new Date(result.start.getTime()),
		next: result.next ? new Date(result.next.getTime()) : null,
	};
}

const currentHoroscope = computed(() => {
	if (!props.astrolabe) return null;
	try {
		return getHoroscopeAt(new Date(props.targetDate));
	} catch (e) {
		return null;
	}
});

const currentDecadalIndex = computed(() => currentHoroscope.value?.decadal?.index ?? -1);

const currentScopeToken = computed(() => {
	const h = currentHoroscope.value;
	if (!h) return { yearly: '', monthly: '', daily: '' };
	return {
		yearly: scopeToken(h, 'yearly'),
		monthly: scopeToken(h, 'monthly'),
		daily: scopeToken(h, 'daily'),
	};
});

// 1. Computed Decades
const sortedDecades = computed(() => {
	if (!props.astrolabe) return [];
	const decades = props.astrolabe.palaces.map((p: any) => ({
		range: p.decadal.range,
		palaceName: formatPalaceName(p.name),
		index: p.index,
	        ganZhi: p.decadal.heavenlyStem + p.decadal.earthlyBranch
	}));
	// Sort by start age
	return decades.sort((a: any, b: any) => a.range[0] - b.range[0]);
});

// 2. Computed Year List based on current decade
const yearList = computed(() => {
	if (!props.astrolabe || !currentHoroscope.value) return [];

	const now = toDateOnly(new Date(props.targetDate));
	const currentAge = currentHoroscope.value.age.nominalAge;
	const currentDecade = sortedDecades.value.find((d: any) => d.index === currentDecadalIndex.value)
		|| sortedDecades.value.find((d: any) => currentAge >= d.range[0] && currentAge <= d.range[1]);

	if (!currentDecade) return [];

	const startAge = Number(currentDecade.range?.[0] || 0);
	const startYear = now.getFullYear() + (startAge - currentAge);
	const cacheKey = `dec-fast-${currentDecade.index}-${currentDecade.range[0]}-${currentDecade.range[1]}-${startYear}-${now.getMonth()}-${now.getDate()}`;
	const cached = yearListCache.get(cacheKey);
	if (cached) return cached;

	const years = buildDecadalFastYearList(currentDecade, now, currentAge);

	yearListCache.set(cacheKey, years);
	return years;
});

const activeYearItem = computed(() => {
	const list = yearList.value;
	if (!list.length) return null;

	const yearlyToken = currentScopeToken.value.yearly;
	if (yearlyToken) {
		const matched = list.find((item: any) => item.token === yearlyToken);
		if (matched) return matched;
	}

	const targetYear = toDateOnly(new Date(props.targetDate)).getFullYear();
	const sameYear = list.find((item: any) => item.year === targetYear);
	if (sameYear) return sameYear;

	return list[0];
});

// 3. Computed Month List based on current year
const monthList = computed(() => {
	if (!props.astrolabe || !currentHoroscope.value) return [];
	const yearlyToken = currentScopeToken.value.yearly;
	if (!yearlyToken) return [];
	const activeYear = activeYearItem.value;
	const bounds = resolveYearScopeBounds(
		activeYear?.date ? new Date(activeYear.date) : new Date(props.targetDate),
		yearlyToken,
	);
	const yearStart = bounds.start;
	const nextYearStart = bounds.next || addDays(yearStart, 366);
	const monthCacheKey = `${yearlyToken}|${toDateKey(yearStart)}`;
	const cached = monthListCache.get(monthCacheKey);
	if (cached) return cached;

	const yearEnd = nextYearStart || addDays(yearStart, 366);
	const months = [];
	const lunarYear = Lunar.fromDate(yearStart).getYear();
	let lunarMonths: any[] = [];
	try {
		const yearData = LunarYear.fromYear(lunarYear);
		const rawMonths = yearData?.getMonths?.();
		lunarMonths = Array.isArray(rawMonths) ? rawMonths : [];
	} catch (e) {
		lunarMonths = [];
	}

	for (const lunarMonth of lunarMonths) {
		const firstJulianDay = lunarMonth?.getFirstJulianDay?.();
		if (!Number.isFinite(firstJulianDay)) continue;
		const solar = Solar.fromJulianDay(firstJulianDay);
		const cursor = new Date(solar.getYear(), solar.getMonth() - 1, solar.getDay());
		if (cursor.getTime() < yearStart.getTime()) continue;
		if (cursor.getTime() >= yearEnd.getTime()) break;
		const h = getHoroscopeAt(cursor);
		if (!h || !h.monthly) continue;
		const monthKey = Number(lunarMonth?.getMonth?.()) || Lunar.fromDate(cursor).getMonth();
		months.push({
			id: `month-${cursor.getTime()}`,
			monthKey,
			monthName: formatMonthName(monthKey),
			ganZhi: `${h.monthly.heavenlyStem}${h.monthly.earthlyBranch}`,
			token: scopeToken(h, 'monthly'),
			startDate: new Date(cursor.getTime()),
		});
	}

	monthListCache.set(monthCacheKey, months);
	return months;
});

// 5. Active State Helpers
const isCurrentDecade = (dec: any) => {
	if (currentDecadalIndex.value >= 0) {
		return dec.index === currentDecadalIndex.value;
	}
	const currentAge = currentHoroscope.value?.age?.nominalAge;
	if (typeof currentAge !== 'number') return false;
	return currentAge >= dec.range[0] && currentAge <= dec.range[1];
};

const isCurrentYear = (yearItem: any) => {
	if (props.viewMode === 'decadal' || props.viewMode === 'origin') return false;
	const token = currentScopeToken.value.yearly;
	if (token) return yearItem.token === token;
	return false;
};

const isCurrentMonth = (monthItem: any) => {
	if (props.viewMode === 'yearly' || props.viewMode === 'decadal' || props.viewMode === 'origin') return false;
	const token = currentScopeToken.value.monthly;
	if (token) return monthItem.token === token;
	return false;
};

// 5. Scroll Management
const currentDecadeId = computed(() => {
	const index = sortedDecades.value.findIndex((d: any) => isCurrentDecade(d));
	return index >= 0 ? 'dec-' + index : '';
});

const currentYearId = computed(() => {
	const matched = yearList.value.find((item: any) => isCurrentYear(item));
	return matched ? matched.id : '';
});

const currentMonthId = computed(() => {
	const matched = monthList.value.find((item: any) => isCurrentMonth(item));
	return matched ? matched.id : '';
});
// 6. Handlers
const selectDecade = (dec: any) => {
	if (shouldIgnoreClick('decade')) return;
	const baseDate = new Date(props.targetDate);
	if (props.viewMode === 'decadal' && isCurrentDecade(dec)) {
		emitSelection('origin', baseDate);
		return;
	}
	let nextDate = baseDate;
	if (!isCurrentDecade(dec) && currentHoroscope.value) {
		const currentAge = currentHoroscope.value.age.nominalAge;
		const currentYear = toDateOnly(new Date(props.targetDate)).getFullYear();
		const targetYear = currentYear + (dec.range[0] - currentAge);
		nextDate = buildDateInYear(targetYear, new Date(props.targetDate));
	}
	emitSelection('decadal', nextDate);
};

const selectYear = (yearItem: any) => {
	if (shouldIgnoreClick('year')) return;
	const baseDate = new Date(props.targetDate);
	if (props.viewMode === 'yearly' && isCurrentYear(yearItem)) {
		emitSelection('decadal', baseDate);
		return;
	}
	const seedDate = yearItem?.date ? new Date(yearItem.date) : buildDateInYear(yearItem.year, new Date(props.targetDate));
	emitSelection('yearly', seedDate);
};

const selectMonth = (monthItem: any) => {
	if (shouldIgnoreClick('month')) return;
	const baseDate = new Date(props.targetDate);
	if ((props.viewMode === 'monthly' || props.viewMode === 'daily') && isCurrentMonth(monthItem)) {
		emitSelection('yearly', baseDate);
		return;
	}
	const newDate = monthItem?.startDate ? new Date(monthItem.startDate) : new Date(props.targetDate);
	emitSelection('monthly', newDate);
};

</script>

