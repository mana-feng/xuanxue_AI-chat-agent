<template>
	<tm-app>
		<PageScaffold
			class="page-ziwei-result"
			card-class="detail-card ziwei-card"
			title="&#x7D2B;&#x5FAE;&#x6392;&#x76D8;&#x7ED3;&#x679C;"
			subtitle="&#x67E5;&#x770B;&#x547D;&#x76D8;&#x3001;&#x4FDD;&#x5B58;&#x8BB0;&#x5F55;&#x3001;&#x5BFC;&#x51FA;&#x4E0E; AI &#x89E3;&#x8BFB;"
		>
			<view v-if="astrolabe" class="result-container">
				<view class="section info-summary">
					<header class="section__header">
						<tm-icon name="tmicon-md-person" :font-size="26" color="#667eea"></tm-icon>
						<h2 class="section__title">&#x57FA;&#x7840;&#x4FE1;&#x606F;</h2>
					</header>
					<view class="section__body">
						<view class="info-grid">
							<view v-for="item in summaryTiles" :key="item.label" class="info-tile">
								<tm-text :font-size="24" color="#718096" :label="item.label"></tm-text>
								<tm-text :font-size="30" :bold="true" color="#2d3748" :label="item.value"></tm-text>
							</view>
						</view>

						<view class="actions-row">
							<tm-button
								type="primary"
								:loading="saving"
								:disabled="saving"
								:round="12"
								:padding="[24, 20]"
								:bold="true"
								label="&#x4FDD;&#x5B58;&#x5230;&#x8D26;&#x53F7;"
								icon="tmicon-md-save"
								@tap="saveToAccount"
							></tm-button>
							<tm-button
								type="primary"
								:round="12"
								:padding="[24, 20]"
								label="&#x7F16;&#x8F91;&#x4FE1;&#x606F;"
								icon="tmicon-md-create"
								@tap="editZiwei"
							></tm-button>
							<tm-button
								type="primary"
								:round="12"
								:padding="[24, 20]"
								label="&#x5BFC;&#x51FA; TOON"
								icon="tmicon-md-download"
								@tap="exportToon"
							></tm-button>
							<tm-button
								type="primary"
								:round="12"
								:padding="[24, 20]"
								label="AI &#x89E3;&#x7B54;"
								icon="tmicon-md-bulb"
								@tap="goToChat"
							></tm-button>
						</view>

						<view v-if="saveError" class="export-error">
							<text class="export-error-text">{{ saveError }}</text>
						</view>
						<view v-if="exportError" class="export-error">
							<text class="export-error-text">{{ exportError }}</text>
						</view>
					</view>
				</view>

				<view class="section chart-section">
					<header class="section__header">
						<tm-icon name="tmicon-md-grid" :font-size="26" color="#667eea"></tm-icon>
						<h2 class="section__title">&#x547D;&#x76D8;&#x603B;&#x89C8;</h2>
					</header>
					<view class="section__body">
						<view class="chart-grid">
							<view class="chart-row top-row">
								<view
									v-for="cell in sortedCells.top"
									:key="cell.original.earthlyBranch"
									class="chart-cell"
									:class="getCellClass(cell)"
									@click="handleCellClick(cell)"
								>
									<PalaceContent
										:palace="cell.original"
										:display-jiangqian12="cell.displayJiangqian12"
										:display-suiqian12="cell.displaySuiqian12"
										:dynamic-labels="cell.dynamicLabels"
										:dynamic-stars="cell.dynamicStars"
										:fly-mutagens="cell.flyMutagens"
										:scope-mutagens="cell.scopeMutagens"
										:is-highlighted="highlightedIndices.includes(cell.original.index)"
									/>
								</view>
							</view>

							<view class="chart-row middle-row">
								<view class="chart-col side-col">
									<view
										v-for="cell in sortedCells.left"
										:key="cell.original.earthlyBranch"
										class="chart-cell"
										:class="getCellClass(cell)"
										@click="handleCellClick(cell)"
									>
										<PalaceContent
											:palace="cell.original"
											:display-jiangqian12="cell.displayJiangqian12"
											:display-suiqian12="cell.displaySuiqian12"
											:dynamic-labels="cell.dynamicLabels"
											:dynamic-stars="cell.dynamicStars"
											:fly-mutagens="cell.flyMutagens"
											:scope-mutagens="cell.scopeMutagens"
											:is-highlighted="highlightedIndices.includes(cell.original.index)"
										/>
									</view>
								</view>

								<view class="center-info">
									<view class="info-content">
										<view class="info-header">
											<text class="info-name">{{ userStore.realname || '\u533F\u540D' }}</text>
											<text class="info-gender">{{ Number(userStore.gender) === 0 ? '\u7537' : '\u5973' }}</text>
										</view>

										<view class="info-row">
											<text class="info-label">&#x9634;&#x5386;&#xFF1A;</text>
											<text class="info-val">{{ astrolabe.lunarDate }}</text>
										</view>
										<view class="info-row">
											<text class="info-label">&#x9633;&#x5386;&#xFF1A;</text>
											<text class="info-val">{{ astrolabe.solarDate }}</text>
										</view>

										<view class="info-row">
											<text class="info-label">&#x4E94;&#x884C;&#x5C40;&#xFF1A;</text>
											<text class="info-val">{{ astrolabe.fiveElementsClass }}</text>
											<text class="info-val info-val-spaced">{{ astrolabe.time }}</text>
										</view>

										<view class="info-row">
											<text class="info-label">&#x547D;&#x4E3B;&#xFF1A;</text>
											<text class="info-val">{{ astrolabe.soul }}</text>
											<text class="info-label info-label-spaced">&#x8EAB;&#x4E3B;&#xFF1A;</text>
											<text class="info-val">{{ astrolabe.body }}</text>
										</view>

										<view v-if="ziweiStore.viewMode !== 'origin'" class="scope-info">
											<text class="scope-label">&#x5F53;&#x524D;&#x8FD0;&#x9650;&#xFF1A;</text>
											<text class="scope-val">{{ currentScopeLabel }}</text>
										</view>

										<view v-if="focusSummary" class="focus-summary">
											<text class="focus-title">{{ focusSummary.name }}&#x4E09;&#x65B9;&#x56DB;&#x6B63;</text>
											<view class="focus-mutagen-row">
												<text
													v-for="item in focusSummary.surroundMutagens"
													:key="'focus-mtg-' + item.name"
													class="focus-mutagen"
													:class="{ active: item.active }"
												>
													{{ item.name }}
												</text>
											</view>
											<text v-if="focusSummary.flyText" class="focus-fly">{{ focusSummary.flyText }}</text>
										</view>

										<view class="legend-box">
											<text class="legend-title">&#x56DB;&#x5316;&#x6807;&#x8BB0;</text>
											<view class="legend-items">
												<text class="legend-item lu">&#x7984;</text>
												<text class="legend-item quan">&#x6743;</text>
												<text class="legend-item ke">&#x79D1;</text>
												<text class="legend-item ji">&#x5FCC;</text>
											</view>
										</view>
									</view>
								</view>

								<view class="chart-col side-col">
									<view
										v-for="cell in sortedCells.right"
										:key="cell.original.earthlyBranch"
										class="chart-cell"
										:class="getCellClass(cell)"
										@click="handleCellClick(cell)"
									>
										<PalaceContent
											:palace="cell.original"
											:display-jiangqian12="cell.displayJiangqian12"
											:display-suiqian12="cell.displaySuiqian12"
											:dynamic-labels="cell.dynamicLabels"
											:dynamic-stars="cell.dynamicStars"
											:fly-mutagens="cell.flyMutagens"
											:scope-mutagens="cell.scopeMutagens"
											:is-highlighted="highlightedIndices.includes(cell.original.index)"
										/>
									</view>
								</view>
							</view>

							<view class="chart-row bottom-row">
								<view
									v-for="cell in sortedCells.bottom"
									:key="cell.original.earthlyBranch"
									class="chart-cell"
									:class="getCellClass(cell)"
									@click="handleCellClick(cell)"
								>
									<PalaceContent
										:palace="cell.original"
										:display-jiangqian12="cell.displayJiangqian12"
										:display-suiqian12="cell.displaySuiqian12"
										:dynamic-labels="cell.dynamicLabels"
										:dynamic-stars="cell.dynamicStars"
										:fly-mutagens="cell.flyMutagens"
										:scope-mutagens="cell.scopeMutagens"
										:is-highlighted="highlightedIndices.includes(cell.original.index)"
									/>
								</view>
							</view>
						</view>

						<view v-if="zoomedCell" class="palace-zoom-mask" @tap="closeCellZoom">
							<view class="palace-zoom-panel" @tap.stop>
								<view class="palace-zoom-header">
									<view class="palace-zoom-title-wrap">
										<text class="palace-zoom-title">
											{{ displayPalaceName(zoomedCell.original.name) }}
										</text>
										<text class="palace-zoom-subtitle">双击宫位可放大查看</text>
									</view>
									<text class="palace-zoom-close" @tap="closeCellZoom">×</text>
								</view>
								<view class="palace-zoom-body">
									<view class="palace-zoom-content">
										<PalaceContent
											:palace="zoomedCell.original"
											:display-jiangqian12="zoomedCell.displayJiangqian12"
											:display-suiqian12="zoomedCell.displaySuiqian12"
											:dynamic-labels="zoomedCell.dynamicLabels"
											:dynamic-stars="zoomedCell.dynamicStars"
											:fly-mutagens="zoomedCell.flyMutagens"
											:scope-mutagens="zoomedCell.scopeMutagens"
											:is-highlighted="highlightedIndices.includes(zoomedCell.original.index)"
										/>
									</view>
								</view>
							</view>
						</view>
					</view>
				</view>

				<view class="section timeline-section">
					<header class="section__header">
						<tm-icon name="tmicon-md-time" :font-size="26" color="#667eea"></tm-icon>
						<h2 class="section__title">&#x8FD0;&#x9650;&#x65F6;&#x95F4;&#x8F74;</h2>
					</header>
					<view class="section__body">
						<Timeline
							:astrolabe="astrolabe"
							:view-mode="ziweiStore.viewMode"
							:target-date="ziweiStore.targetDate"
							@update:selection="handleTimelineSelectionUpdate"
						/>
					</view>
				</view>
			</view>

			<view v-else class="section empty-state">
				<tm-icon name="tmicon-md-time" :font-size="72" color="#cbd5e0"></tm-icon>
				<tm-text :font-size="26" color="#718096" label="&#x6682;&#x65E0;&#x6392;&#x76D8;&#x6570;&#x636E;&#xFF0C;&#x8BF7;&#x5148;&#x8FD4;&#x56DE;&#x6392;&#x76D8;&#x4E3B;&#x9875;&#x751F;&#x6210;&#x547D;&#x76D8;&#x3002;"></tm-text>
				<tm-button type="primary" :round="12" :padding="[22, 16]" label="&#x8FD4;&#x56DE;&#x6392;&#x76D8;" @tap="goStart"></tm-button>
			</view>
		</PageScaffold>
	</tm-app>
</template>

<script lang="ts" setup>
import { computed, ref } from 'vue';
import PageScaffold from '@/components/layout/PageScaffold.vue';
import { useZiweiStore } from '@/store/ziwei';
import { useUserStore } from '@/store/user';
import { request } from '@/services/api/index';
import { encodeTOON } from '@/utils/toon';
import { buildZiweiExportPayload } from '@/utils/ziweiExport';
// @ts-expect-error nvue component import type is not inferred
import PalaceContent from './components/PalaceContent.nvue';
// @ts-expect-error nvue component import type is not inferred
import Timeline from './components/Timeline.nvue';

const ziweiStore = useZiweiStore();
const userStore = useUserStore();
const saving = ref(false);
const saveError = ref('');
const exportError = ref('');
const zoomedCell = ref<any | null>(null);
const lastClickTs = ref(0);
const lastClickPalaceIndex = ref<number | null>(null);

const astrolabe = computed(() => ziweiStore.astrolabe);
const currentHoroscope = computed(() => ziweiStore.currentHoroscope);

const formatTimestampForFilename = (timestamp: number | null | undefined): string => {
	if (typeof timestamp !== 'number' || !Number.isFinite(timestamp)) return '';
	const date = new Date(timestamp);
	if (!Number.isFinite(date.getTime())) return '';
	const pad = (value: number) => String(value).padStart(2, '0');
	return `${date.getFullYear()}${pad(date.getMonth() + 1)}${pad(date.getDate())}${pad(date.getHours())}${pad(date.getMinutes())}`;
};

const exportToon = () => {
	exportError.value = '';
	if (!astrolabe.value) {
		uni.showToast({
			title: '\u6682\u65E0\u6392\u76D8\u6570\u636E\uFF0C\u65E0\u6CD5\u5BFC\u51FA',
			icon: 'none',
			duration: 2000,
		});
		return;
	}

	let payload: Record<string, unknown> | null = null;
	try {
		payload = buildZiweiExportPayload(userStore, ziweiStore);
	} catch (e: any) {
		exportError.value = `\u751F\u6210\u5BFC\u51FA\u6570\u636E\u5931\u8D25\uFF1A${e?.message || e}`;
		return;
	}

	if (!payload) {
		exportError.value = '\u5BFC\u51FA\u6570\u636E\u4E3A\u7A7A\uFF0C\u65E0\u6CD5\u751F\u6210 TOON \u6587\u4EF6';
		return;
	}

	let toonStr = '';
	try {
		toonStr = encodeTOON(payload);
	} catch (e: any) {
		exportError.value = `TOON \u5E8F\u5217\u5316\u5931\u8D25\uFF1A${e?.message || e}`;
		return;
	}

	const filename = `ziwei-${formatTimestampForFilename(userStore.timestamp) || 'export'}.toon`;

	// #ifdef H5
	try {
		const blob = new Blob([toonStr], { type: 'text/plain;charset=utf-8' });
		const url = URL.createObjectURL(blob);
		const link = document.createElement('a');
		link.href = url;
		link.download = filename;
		link.click();
		URL.revokeObjectURL(url);
		uni.showToast({
			title: '\u5DF2\u4E0B\u8F7D TOON \u6587\u4EF6',
			icon: 'none',
			duration: 2000,
		});
		return;
	} catch (e) {
		// fallback to clipboard
	}
	// #endif

	uni.setClipboardData({
		data: toonStr,
		success() {
			uni.showToast({
				title: 'TOON \u5DF2\u590D\u5236\uFF0C\u8BF7\u7C98\u8D34\u4FDD\u5B58',
				icon: 'none',
				duration: 2000,
			});
		},
		fail(err) {
			exportError.value = `\u5BFC\u51FA\u5931\u8D25\uFF1A${err?.errMsg || '\u526A\u8D34\u677F\u4E0D\u53EF\u7528'}`;
		},
	});
};

const buildZiweiLitePayload = () => {
	const chart = astrolabe.value;
	if (!chart) return null;

	const palaces = (chart.palaces || []).map((palace: any) => ({
		index: palace?.index,
		name: palace?.name || '',
		heavenlyStem: palace?.heavenlyStem || '',
		earthlyBranch: palace?.earthlyBranch || '',
	}));

	return {
		lite: true,
		module: 'ziwei',
		user: {
			realname: userStore.realname || '',
			gender: userStore.gender,
			timestamp: userStore.timestamp,
		},
		selection: {
			viewMode: ziweiStore.viewMode,
			targetDate:
				ziweiStore.targetDate instanceof Date
					? ziweiStore.targetDate.toISOString()
					: new Date(ziweiStore.targetDate as any).toISOString(),
			focusPalaceIndex: ziweiStore.focusPalaceIndex,
		},
		summary: {
			solarDate: chart.solarDate || '',
			lunarDate: chart.lunarDate || '',
			time: chart.time || '',
			fiveElementsClass: chart.fiveElementsClass || '',
			soul: chart.soul || '',
			body: chart.body || '',
			palaces,
		},
	};
};

const saveToAccount = async () => {
	saveError.value = '';

	if (!userStore.isLoggedIn) {
		uni.showToast({
			 title: '\u8BF7\u5148\u767B\u5F55',
			icon: 'none',
			duration: 2000,
		});
		return;
	}

	if (!astrolabe.value || !userStore.timestamp) {
		uni.showToast({
			 title: '\u6392\u76D8\u6570\u636E\u4E0D\u5B8C\u6574',
			icon: 'none',
			duration: 2000,
		});
		return;
	}

	if (saving.value) return;
	saving.value = true;
	const recordId = userStore.recordId;
	const isUpdate = !!recordId;

	try {
		const rawPayload = buildZiweiLitePayload();
		const res = await request(isUpdate ? `/api/ziwei/${recordId}` : '/api/ziwei', {
			method: isUpdate ? 'PUT' : 'POST',
			needAuth: true,
			data: {
				name: (userStore.realname || '').trim() || '\u533F\u540D',
				gender:
					userStore.gender !== undefined && userStore.gender !== null
						? String(userStore.gender)
						: null,
				birthDatetime: Number(userStore.timestamp),
				calendarType: 'solar',
				rawPayload,
			},
		});
		const responseData = res?.data || res;
		if (responseData?.id) {
			userStore.recordId = responseData.id;
		}

		uni.showToast({
			 title: isUpdate ? '\u8BB0\u5F55\u5DF2\u66F4\u65B0' : '\u5DF2\u4FDD\u5B58\u5230\u8D26\u53F7',
			icon: 'success',
			duration: 1500,
		});
	} catch (e: any) {
		if (isUpdate) {
			userStore.recordId = null;
		}
		const message = e?.error || e?.message || '\u4FDD\u5B58\u5931\u8D25\uFF0C\u8BF7\u91CD\u8BD5';
		saveError.value = message;
		uni.showToast({
			title: message,
			icon: 'none',
			duration: 2000,
		});
	} finally {
		saving.value = false;
	}
};

function editZiwei() {
	if (!userStore.timestamp) {
		uni.showToast({
			 title: '\u7F3A\u5C11\u51FA\u751F\u65F6\u95F4',
			icon: 'none',
			duration: 2000,
		});
		return;
	}

	const editData = {
		realname: userStore.realname || '',
		gender:
			userStore.gender !== undefined && userStore.gender !== null
				? Number(userStore.gender)
				: 0,
		timestamp: Number(userStore.timestamp),
		recordId: userStore.recordId || null,
		isEdit: true,
	};

	try {
		uni.setStorageSync('edit_ziwei_data', JSON.stringify(editData));
		uni.showToast({
			 title: '\u8DF3\u8F6C\u4E2D...',
			icon: 'loading',
			duration: 900,
		});
		setTimeout(() => {
			uni.reLaunch({
				url: '/pages/ziwei/index',
			});
		}, 300);
	} catch (e) {
		console.error('\u51C6\u5907\u7F16\u8F91\u6570\u636E\u5931\u8D25:', e);
		uni.showToast({
			title: '\u8F7D\u5165\u5931\u8D25\uFF0C\u8BF7\u91CD\u8BD5',
			icon: 'none',
			duration: 2000,
		});
	}
}

function goToChat() {
	if (!astrolabe.value) {
		uni.showToast({
			title: '\u6682\u65E0\u6392\u76D8\u6570\u636E',
			icon: 'none',
			duration: 2000,
		});
		return;
	}

	uni.navigateTo({
		url: '/pages/chat/index?from=ziwei',
	});
}

function goStart() {
	uni.reLaunch({
		url: '/pages/ziwei/index',
	});
}

const currentScopeLabel = computed(() => {
    const h = currentHoroscope.value;
    if (!h) return '';

    if (ziweiStore.viewMode === 'decadal' && h.decadal) {
		return `${h.decadal.heavenlyStem}${h.decadal.earthlyBranch}\u5927\u9650`;
    } else if (ziweiStore.viewMode === 'yearly' && h.yearly) {
		return `${h.yearly.heavenlyStem}${h.yearly.earthlyBranch}\u6D41\u5E74`;
    } else if (ziweiStore.viewMode === 'monthly' && h.monthly) {
		return `${h.monthly.heavenlyStem}${h.monthly.earthlyBranch}\u6D41\u6708`;
    } else if (ziweiStore.viewMode === 'daily' && h.daily) {
		return `${h.daily.heavenlyStem}${h.daily.earthlyBranch}\u6D41\u65E5`;
    }
    return '';
});

const summaryTiles = computed(() => {
	if (!astrolabe.value) return [];
	const tiles = [
		{ label: '\u59D3\u540D', value: (userStore.realname || '').trim() || '\u533F\u540D' },
		{ label: '\u6027\u522B', value: Number(userStore.gender) === 0 ? '\u7537' : '\u5973' },
		{ label: '\u9633\u5386', value: astrolabe.value.solarDate || '-' },
		{ label: '\u9634\u5386', value: astrolabe.value.lunarDate || '-' },
		{ label: '\u4E94\u884C\u5C40', value: astrolabe.value.fiveElementsClass || '-' },
		{ label: '\u547D\u4E3B / \u8EAB\u4E3B', value: `${astrolabe.value.soul || '-'} / ${astrolabe.value.body || '-'}` },
	];
	return tiles;
});

const handleTimelineSelectionUpdate = (payload: any) => {
	const mode = payload?.mode;
	const value = payload?.date;
	if (!mode) return;
	const date = value instanceof Date ? new Date(value.getTime()) : new Date(value || ziweiStore.targetDate);
	if (!Number.isFinite(date.getTime())) return;
	ziweiStore.setTimelineSelection({ mode, date });
};

type DynamicScope = 'decadal' | 'age' | 'yearly' | 'monthly' | 'daily';
type MutagenName = string;
type HoroscopeScope = 'hourly' | 'daily' | 'monthly' | 'yearly' | 'decadal' | 'age';

const SCOPE_PREFIX: Record<DynamicScope, string> = {
	decadal: '\u5927',
	age: '\u5C0F',
	yearly: '\u5E74',
	monthly: '\u6708',
	daily: '\u65E5',
};

const MUTAGEN_NAMES: MutagenName[] = ['\u7984', '\u6743', '\u79D1', '\u5FCC'];
const DYNAMIC_LABEL_SCOPE_ORDER: HoroscopeScope[] = ['hourly', 'daily', 'monthly', 'yearly', 'decadal', 'age'];
const DYNAMIC_STAR_SCOPE_ORDER: Array<Exclude<HoroscopeScope, 'age'>> = ['hourly', 'daily', 'monthly', 'yearly', 'decadal'];
const DYNAMIC_LABEL_PREFIX: Record<HoroscopeScope, string> = {
	hourly: '\u65F6',
	daily: '\u65E5',
	monthly: '\u6708',
	yearly: '\u5E74',
	decadal: '\u5927',
	age: '\u5C0F',
};
const displayPalaceName = (name: string) => (name === '\u4EC6\u5F79' ? '\u4EA4\u53CB' : name);

const palaceStarNameSet = computed(() => {
	const sets = new Map<number, Set<string>>();
	if (!astrolabe.value) return sets;
	astrolabe.value.palaces.forEach((palace) => {
		const names = new Set<string>();
		[...(palace.majorStars || []), ...(palace.minorStars || [])].forEach((star: any) => {
			const name = star?.name;
			if (typeof name === 'string' && name) names.add(name);
		});
		sets.set(palace.index, names);
	});
	return sets;
});

const focusedSurroundedPalaces = computed(() => {
	const focusIndex = ziweiStore.focusPalaceIndex;
	if (focusIndex === null || !astrolabe.value) return null;

	const focusPalace = astrolabe.value.palaces[focusIndex];
	if (!focusPalace) return null;

	if (ziweiStore.viewMode !== 'origin' && currentHoroscope.value?.surroundPalaces) {
		try {
			return currentHoroscope.value.surroundPalaces(focusPalace.name, ziweiStore.viewMode);
		} catch (e) {
			console.warn('Failed to load surrounded palaces in scope:', e);
		}
	}

	try {
		return astrolabe.value.surroundedPalaces(focusPalace.index);
	} catch (e) {
		console.warn('Failed to load surrounded palaces:', e);
		return null;
	}
});

const highlightedIndices = computed(() => {
	const surrounded = focusedSurroundedPalaces.value;
	if (!surrounded) return [];

	return Array.from(
        new Set(
            [surrounded.target?.index, surrounded.opposite?.index, surrounded.wealth?.index, surrounded.career?.index].filter(
                (idx): idx is number => typeof idx === 'number',
            ),
        ),
    );
});

const focusSummary = computed(() => {
    const focusIndex = ziweiStore.focusPalaceIndex;
    if (focusIndex === null || !astrolabe.value) return null;

	const focusPalace = astrolabe.value.palaces[focusIndex];
	if (!focusPalace) return null;

	const surrounded = focusedSurroundedPalaces.value;
	const surroundMutagens = MUTAGEN_NAMES.map((name) => ({
		name,
		active: surrounded ? surrounded.haveMutagen(name) : false,
    }));

    const flyParts: string[] = [];
	    astrolabe.value.palaces.forEach((targetPalace) => {
	        const hits = MUTAGEN_NAMES.filter((mutagen) => {
	            try {
	                return focusPalace.fliesTo(targetPalace.index, mutagen);
	            } catch (e) {
	                return false;
	            }
	        });
	        if (hits.length) {
	            flyParts.push(`${displayPalaceName(targetPalace.name)}${hits.join('')}`);
	        }
	    });

	    return {
	        name: displayPalaceName(focusPalace.name),
	        surroundMutagens,
	        flyText: flyParts.join('\u3001'),
	    };
	});

const sortedCells = computed(() => {
    if (!astrolabe.value) return { top: [], left: [], right: [], bottom: [] };

    const cellsMap = new Map();
    
	// 1. Initialize with Original Palaces
	astrolabe.value.palaces.forEach(p => {
		cellsMap.set(p.earthlyBranch, {
			original: p,
			dynamicLabels: [],
			dynamicStars: [],
			flyMutagens: [],
			scopeMutagens: {},
			displayJiangqian12: undefined,
			displaySuiqian12: undefined,
		});
	});

	// 2. Add Dynamic Info (Horoscope)
	if (ziweiStore.viewMode !== 'origin' && currentHoroscope.value) {
		const mode = ziweiStore.viewMode;
		const horoscope = currentHoroscope.value;
		const hasScopeMutagenCache = new Map<string, boolean>();

		if (mode === 'yearly') {
			const yearlyDecStar = (horoscope as any)?.yearly?.yearlyDecStar;
			const yearlySuiqian12 = Array.isArray(yearlyDecStar?.suiqian12) ? yearlyDecStar.suiqian12 : [];
			const yearlyJiangqian12 = Array.isArray(yearlyDecStar?.jiangqian12) ? yearlyDecStar.jiangqian12 : [];

			astrolabe.value.palaces.forEach((basePalace, palaceIndex) => {
				const cell = cellsMap.get(basePalace.earthlyBranch);
				if (!cell) return;
				const suiqianValue = yearlySuiqian12[palaceIndex];
				const jiangqianValue = yearlyJiangqian12[palaceIndex];
				if (typeof suiqianValue === 'string' && suiqianValue) {
					cell.displaySuiqian12 = suiqianValue;
				}
				if (typeof jiangqianValue === 'string' && jiangqianValue) {
					cell.displayJiangqian12 = jiangqianValue;
				}
			});
		}

		// Keep only current scope to avoid information overload.
		const activeScopesByMode: Record<string, DynamicScope[]> = {
            decadal: ['decadal'],
            yearly: ['yearly'],
            monthly: ['monthly'],
            daily: ['daily'],
        };
        const activeScopes: DynamicScope[] = activeScopesByMode[mode] || [];

		DYNAMIC_LABEL_SCOPE_ORDER.forEach((scope) => {
			const scopeData = (horoscope as any)?.[scope];
			if (!scopeData) return;
			const prefix = DYNAMIC_LABEL_PREFIX[scope];

			const palaceNames = Array.isArray(scopeData.palaceNames) ? scopeData.palaceNames : [];

			// 2.1 Overlay dynamic palace labels for all available scopes.
			palaceNames.forEach((palaceName: string, palaceIndex: number) => {
				const basePalace = astrolabe.value?.palaces?.[palaceIndex];
				if (!basePalace) return;

                const cell = cellsMap.get(basePalace.earthlyBranch);
                if (!cell) return;

					if (!cell.dynamicLabels) cell.dynamicLabels = [];
					cell.dynamicLabels.push({
						text: `${prefix}${displayPalaceName(String(palaceName || ''))}`,
						type: scope,
					});
				});
		});

		DYNAMIC_STAR_SCOPE_ORDER.forEach((scope) => {
			const scopeData = (horoscope as any)?.[scope];
			if (!scopeData) return;
			const starsByPalace = Array.isArray(scopeData.stars) ? scopeData.stars : [];
			starsByPalace.forEach((stars: any[], palaceIndex: number) => {
				if (!Array.isArray(stars) || !stars.length) return;
				const basePalace = astrolabe.value?.palaces?.[palaceIndex];
				if (!basePalace) return;
				const cell = cellsMap.get(basePalace.earthlyBranch);
				if (!cell) return;
				if (!Array.isArray(cell.dynamicStars)) cell.dynamicStars = [];
				stars.forEach((star: any) => {
					const starName = star?.name;
					if (typeof starName !== 'string' || !starName) return;
					if (!cell.dynamicStars.includes(starName)) {
						cell.dynamicStars.push(starName);
					}
				});
			});
		});

		activeScopes.forEach((scope) => {
			const prefix = SCOPE_PREFIX[scope];
			const scopeData = (horoscope as any)?.[scope];
			if (!scopeData) return;
			// 2.2 Apply scope mutagens to natal stars (iztro hasHoroscopeMutagen logic).
			const scopeMutagenList = Array.isArray(scopeData.mutagen) ? scopeData.mutagen : [];
			for (const cell of cellsMap.values()) {
				const starSet = palaceStarNameSet.value.get(cell.original.index);

				scopeMutagenList.forEach((starName: string, idx: number) => {
					if (!starName) return;
                    const mutagenName = MUTAGEN_NAMES[idx];
                    if (!mutagenName) return;
					const palaceName = cell.original?.name;
					if (!palaceName) return;

					if (typeof horoscope?.hasHoroscopeMutagen === 'function') {
						const cacheKey = `${scope}|${palaceName}|${mutagenName}`;
						let matched = hasScopeMutagenCache.get(cacheKey);
						if (typeof matched !== 'boolean') {
							try {
								matched = horoscope.hasHoroscopeMutagen(palaceName, scope as any, mutagenName);
							} catch (e) {
								matched = false;
							}
							hasScopeMutagenCache.set(cacheKey, matched);
						}
						if (!matched) return;
					}

					if (!starSet?.has(starName)) return;

                    const mutagenLabel = prefix + mutagenName;
                    if (!mutagenLabel) return;

                    if (!cell.scopeMutagens) cell.scopeMutagens = {};
                    if (!cell.scopeMutagens[starName]) cell.scopeMutagens[starName] = [];
                    cell.scopeMutagens[starName].push({
                        scope,
                        label: mutagenLabel,
                    });
                });
            }
        });
    }

    // 3. Add Flying Mutagen (Focus)
    if (ziweiStore.focusPalaceIndex !== null) {
        const focusPalace = astrolabe.value.palaces[ziweiStore.focusPalaceIndex];
        if (focusPalace) {
            astrolabe.value.palaces.forEach((targetPalace) => {
                const cell = cellsMap.get(targetPalace.earthlyBranch);
                if (!cell) return;

                MUTAGEN_NAMES.forEach((mutagenName) => {
                    try {
                        if (focusPalace.fliesTo(targetPalace.index, mutagenName)) {
                            if (!Array.isArray(cell.flyMutagens)) {
                                cell.flyMutagens = [];
                            }
                            if (!cell.flyMutagens.includes(mutagenName)) {
                                cell.flyMutagens.push(mutagenName);
                            }
                        }
                    } catch (e) {
                        // Ignore single mutagen check error and continue.
                    }
                });
            });
        }
    }

	for (const cell of cellsMap.values()) {
		if (!Array.isArray(cell.flyMutagens)) {
			cell.flyMutagens = [];
		}
		if (!Array.isArray(cell.dynamicStars)) {
			cell.dynamicStars = [];
		}
	}

	return {
			top: ['\u5DF3', '\u5348', '\u672A', '\u7533'].map((b) => cellsMap.get(b)),
			left: ['\u8FB0', '\u536F'].map((b) => cellsMap.get(b)),
			right: ['\u9149', '\u620C'].map((b) => cellsMap.get(b)),
			bottom: ['\u5BC5', '\u4E11', '\u5B50', '\u4EA5'].map((b) => cellsMap.get(b)),
	};
});

const getCellClass = (cell: any) => {
    const isFocus = ziweiStore.focusPalaceIndex === cell.original.index;
	const isMing = cell.original.name === '\u547D\u5BAB';
    
    return {
        'cell-focused': isFocus,
        'cell-highlight': isMing && !isFocus
    };
};

const DOUBLE_CLICK_WINDOW_MS = 280;

const closeCellZoom = () => {
	zoomedCell.value = null;
};

const handleCellClick = (cell: any) => {
	if (!cell?.original) return;

	const palaceIndex = cell.original.index;
	ziweiStore.setFocus(palaceIndex);

	const now = Date.now();
	const isSamePalace = lastClickPalaceIndex.value === palaceIndex;
	const isDoubleClick = isSamePalace && now - lastClickTs.value <= DOUBLE_CLICK_WINDOW_MS;

	lastClickPalaceIndex.value = palaceIndex;
	lastClickTs.value = now;

	if (isDoubleClick) {
		zoomedCell.value = cell;
		lastClickPalaceIndex.value = null;
		lastClickTs.value = 0;
	}
};
</script>

