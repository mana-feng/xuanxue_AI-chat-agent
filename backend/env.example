# 后端环境变量配置示例
# 复制此文件为 .env 并修改配置

# ============================================
# 后端服务器配置
# ============================================

# 后端服务端口
PORT=3001

# JWT 密钥（必须修改为随机字符串，建议使用32位以上）
JWT_SECRET=please_change_me_to_a_random_secret_key_at_least_32_chars

# Access Token 有效期（默认 30 分钟）
ACCESS_TOKEN_EXPIRES_IN=30m

# Refresh Token 有效期（默认 15 天）
REFRESH_TOKEN_EXPIRES_DAYS=15

# CORS 允许的来源（主要用于 H5 浏览器端）
# 多个域名用逗号分隔，例如：https://your-frontend.com,https://h5.your-frontend.com
# 
# 说明：
# - H5（浏览器）：需要配置前端域名，防止未授权网站访问 API
# - 小程序：自动允许，无需配置（微信小程序有独立的域名白名单机制）
# - App：自动允许，无需配置（原生请求不受 CORS 限制）
# 
# 如果只部署小程序或 App，可以留空
# 如果同时部署 H5，生产环境建议配置具体的前端域名
CORS_ORIGINS=https://your-frontend-domain.com,https://h5.your-frontend-domain.com

# ============================================
# MySQL 数据库配置（仅后端需要）
# ============================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password_here
DB_NAME=bazi_app

# ============================================
# 重要安全提示
# ============================================
# 1. JWT_SECRET 必须使用强随机字符串
# 2. DB_PASS 数据库密码不要泄露
# 3. .env 文件不要提交到Git仓库
# 4. 生产环境建议使用环境变量或密钥管理服务
# 5. 默认管理员账号通过 init-mysql.sql 脚本创建
#    如需修改，请编辑 init-mysql.sql 文件后重新执行初始化
# ============================================

# ============================================
# 注意：邮箱SMTP配置不再从环境变量读取
# 请在后台管理中配置邮箱服务
# ============================================

