	0% { transform: rotate(0deg) scale(1); }
	10% { transform: rotate(-18deg) scale(1.05); }
	20% { transform: rotate(18deg) scale(1.05); }
	30% { transform: rotate(-12deg) scale(1.03); }
	40% { transform: rotate(12deg) scale(1.03); }
	50% { transform: rotate(-6deg) scale(1.01); }
	60% { transform: rotate(6deg) scale(1.01); }
	70% { transform: rotate(-3deg) scale(1); }
	80% { transform: rotate(3deg) scale(1); }
	100% { transform: rotate(0deg) scale(1); }
}

