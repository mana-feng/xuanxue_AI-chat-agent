<script lang="ts" setup>
import { computed, ref } from 'vue';
import { onLoad } from '@dcloudio/uni-app';
import { Solar } from 'lunar-javascript';
import liuyaoService from '@/features/liuyao/service';
import { getYaoName, getYaoSymbol, formatDateTime } from '@/features/liuyao/uiHelpers';
import TimeInput from '@/components/liuyao/TimeInput.vue';
import ParamPreview from '@/components/liuyao/ParamPreview.vue';
import MethodCard from '@/components/liuyao/MethodCard.vue';
import YaoSelector from '@/components/liuyao/YaoSelector.vue';
import LiuyaoBasicInfo from '@/components/liuyao/LiuyaoBasicInfo.vue';
import { compileNajia, buildDisplayData } from '@/features/liuyao/najiaCore';
import { GUA64 } from '@/features/liuyao/najiaConst';
import { useLiuyaoStore } from '@/store/liuyao';
type MethodKey =
	| 'computer'   // 电脑自动
	| 'online'     // 在线起卦
	| 'manual'     // 手工指定
	| 'time'       // 时间起卦
	| 'single'     // 单数起卦
	| 'double'     // 双数起卦
	| 'chars'      // 汉字起卦
	| 'gua'        // 卦名起卦
	| 'auto'       // 自动起卦（随机）
	| 'shake';     // 手动摇卦

const headerRef = ref(null);

const pageWrapperStyle = computed(() => ({}));

import useLiuyaoForm from '@/features/liuyao/useLiuyaoForm';

const {
	form,
	methodTabs,
	methodIndex,
	currentMethod,
	yaoOptions,
	getYaoLabel,
	getYaoIndex,
	getYaoDisplayValue,
	getYaoName,
	getYaoSymbol,
	methodInfo,
	currentMethodIcon,
	methodDesc,
	setMethod,
	timePickerShow,
	timePickerDefault,
	timePick,
	timeSuffix,
	openTimePicker,
	onTimeConfirm,
	useNowTime,
	generateAuto,
	generateShake,
	generateTime,
	generateSingle,
	generateDouble,
	generateChars,
	generateGua,
	startOnlineShake,
	onlineActive,
	onlineMsg,
	startLiuyao,
	resetForm,
	canStart,
	guaMarks,
	guaMainIndex,
	guaBianIndex,
	guaMainLabel,
	guaBianLabel,
	onGuaMainChange,
	onGuaBianChange
} = useLiuyaoForm();

onLoad(() => {
	const now = new Date();
	form.value.timeLabel = formatDateTime(now);
	timePickerDefault.value = formatDateTime(now).replace(/-/g, '/');
});
</script>

