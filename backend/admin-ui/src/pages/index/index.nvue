<template>
	<tm-app>
		<PageScaffold class="page-bazi-input" title="排盘信息" subtitle="请填写以下信息进行八字排盘">
			<SectionBlock icon="tmicon-md-person" title="基本信息">
				<view class="card-stack">
					<tm-input
						v-model="realname"
						placeholder="请输入姓名（可选）"
						prefix="tmicon-md-person"
						:round="12"
						:border="1"
						:padding="[24, 20]"
					></tm-input>

					<view class="form-group-single">
						<view class="form-label">
							<tm-icon name="tmicon-md-people" :font-size="24" color="#718096" :margin="[0, 6, 0, 0]"></tm-icon>
							<tm-text :font-size="26" color="#718096" label="性别"></tm-text>
						</view>
						<view class="form-control">
							<tm-radio-group v-model="gender">
								<tm-radio label="男" :value="0" :margin="[0, 16, 0, 0]"></tm-radio>
								<tm-radio label="女" :value="1"></tm-radio>
							</tm-radio-group>
						</view>
					</view>
				</view>
			</SectionBlock>

			<SectionBlock icon="tmicon-time" title="出生时间" subtitle="支持阳历/阴历，精确到分钟">
				<view class="card-stack">
					<view class="form-group-single calendar-type-selector">
						<view class="form-label">
							<tm-icon name="tmicon-calendar-alt" :font-size="24" color="#718096" :margin="[0, 6, 0, 0]"></tm-icon>
							<tm-text :font-size="26" color="#718096" label="日历类型"></tm-text>
						</view>
						<view class="form-control segtab-wrapper">
							<tm-segtab
								v-model="model"
								:default-value="0"
								:list="[{ text: '阳历' }, { text: '阴历' }]"
								:margin="[0, 0]"
								:width="300"
							></tm-segtab>
						</view>
					</view>

					<tm-input
						:placeholder="model === 0 ? '请选择阳历出生日期和时间（精确到分钟）' : '请选择阴历出生日期和时间（精确到分钟）'"
						prefix="tmicon-calendar-alt"
						suffix="tmicon-angle-right"
						v-model="datetime_label"
						:round="12"
						:border="1"
						:padding="[24, 20]"
						@tap="SelectTime"
					></tm-input>

					<view v-if="lunar_label || bazi_label" class="info-grid info-cards">
						<view v-if="lunar_label" class="info-card">
							<view class="info-card-header">
								<tm-icon name="tmicon-integral" :font-size="32" color="#48bb78"></tm-icon>
								<tm-text
									:font-size="24"
									color="#718096"
									:label="model === 0 ? '对应阴历' : '对应阳历'"
									:margin="[0, 0, 0, 12]"
								></tm-text>
							</view>
							<tm-text :font-size="28" color="#2d3748" :bold="true" :label="lunar_label"></tm-text>
						</view>

						<view v-if="bazi_label" class="info-card">
							<view class="info-card-header">
								<tm-icon name="tmicon-calendar" :font-size="32" color="#667eea"></tm-icon>
								<tm-text :font-size="24" color="#718096" label="四柱八字" :margin="[0, 0, 0, 12]"></tm-text>
							</view>
							<view class="bazi-display">
								<tm-tag
									v-for="(item, index) in bazi_label.split(' ')"
									:key="index"
									:label="item"
									type="primary"
									:round="8"
									:margin="[0, 8, 0, 0]"
									:font-size="26"
									:bold="true"
								></tm-tag>
							</view>
						</view>
					</view>
				</view>
			</SectionBlock>

			<template #footer>
				<tm-button
					:class="['primary-btn', { disabled: !canSubmit }]"
					:label="'开始排盘'"
					:type="canSubmit ? 'primary' : 'grey'"
					:round="999"
					:bold="true"
					:linear="canSubmit ? 'right' : ''"
					:linearDeep="'accent'"
					:shadow="canSubmit ? 10 : 0"
					:disabled="!canSubmit"
					icon="tmicon-calendar-alt"
					@tap="Sumbit"
					block
				></tm-button>
			</template>
		</PageScaffold>

		<tm-time-picker
			v-model:show="solar_select_show"
			:round="6"
			:default-value="solar_default_value"
			:start="time_pick.start"
			:end="time_pick.end"
			:format="time_pick.format"
			:showDetail="time_pick.detail"
			:showSuffix="time_suffix.solar"
			@confirm="SolarConfirm"
		></tm-time-picker>
		<tm-time-picker
			v-model:show="lunar_select_show"
			:round="6"
			:default-value="lunar_default_value"
			:start="time_pick.start"
			:end="time_pick.end"
			:format="time_pick.format"
			:showDetail="time_pick.detail"
			:showSuffix="time_suffix.lunar"
			@confirm="LunarConfirm"
		></tm-time-picker>

		<tm-overlay v-model:show="showAnnouncementModal" :opacity="0.4" :duration="200">
			<tm-sheet
				:round="18"
				:padding="[24, 24]"
				:margin="[40, 32]"
				:shadow="2"
				:width="600"
				class="announcement-modal"
			>
				<view class="modal-header">
					<tm-text :font-size="30" label="公告" bold></tm-text>
					<tm-button size="small" type="grey" :round="12" @tap="closeAnnouncements">关闭</tm-button>
				</view>
				<view v-if="annLoading" class="py-10">
					<tm-text label="加载中.." color="#999"></tm-text>
				</view>
				<view v-else-if="announcementList.length === 0" class="py-10">
					<tm-text label="暂无公告" color="#999"></tm-text>
				</view>
				<view v-else class="announcement-list">
					<tm-sheet
						v-for="item in announcementList"
						:key="item.id"
						:round="12"
						:padding="[18, 16]"
						:margin="[0, 0, 16, 0]"
						:shadow="1"
					>
						<tm-text :font-size="28" bold :label="item.title"></tm-text>
						<tm-text
							v-if="item.expiresAt"
							:font-size="22"
							color="#999"
							:label="`有效期至：${item.expiresAt}`"
							class="mt-4"
						></tm-text>
						<tm-text :font-size="24" color="#444" class="mt-6" :label="item.content"></tm-text>
					</tm-sheet>
				</view>
				<view v-if="annError" class="mt-6">
					<tm-text :label="annError" color="red"></tm-text>
				</view>
			</tm-sheet>
		</tm-overlay>
	</tm-app>
</template>


<script lang="ts" setup>
import { ref, computed, watch, nextTick } from 'vue';
import { onLoad, onShow } from '@dcloudio/uni-app';
import { Solar } from 'lunar-javascript';
import PageScaffold from '@/components/layout/PageScaffold.vue';
import SectionBlock from '@/components/layout/SectionBlock.vue';
import { useUserStore } from '@/store/user';
import { useBaziStore } from '@/store/bazi';
import utils from '@/libs/utils/utils';
import { fetchAnnouncementMeta, fetchAnnouncements, type Announcement, type AnnouncementMeta } from '@/services/api/announcement';

const realname = ref('');
const gender = ref(0);
const model = ref(0);
const timestamp = ref<number | null>(null);
const datetime_label = ref('');
const lunar_label = ref<string | null>(null);
const bazi_label = ref('');

const user_store = useUserStore();
const bazi_store = useBaziStore();

const canSubmit = computed(() => timestamp.value !== null);

const solar_select_show = ref(false);
const lunar_select_show = ref(false);

const solar_default_value = ref('');
const lunar_default_value = ref('');

const time_pick = {
	start: '1900/01/01 00:00',
	end: '2099/12/30 00:00',
	format: 'YYYY/MM/DD HH:mm',
	detail: {
		year: true,
		month: true,
		day: true,
		hour: true,
		minute: true,
		second: false,
	},
};

const time_suffix = {
	solar: { year: '年', month: '月', day: '日', hour: '时', minute: '分', second: '秒' },
	lunar: { year: '年', month: '月', day: '日', hour: '时辰', minute: '分', second: '秒' },
};

const ANN_CACHE_KEY = 'announcements_cache_v1';
const showAnnouncementModal = ref(false);
const announcementList = ref<Announcement[]>([]);
const annLoading = ref(false);
const annError = ref('');

watch(model, PullDatatimeLabel);
watch(timestamp, PullDatatimeLabel);

function initCurrentTime() {
	timestamp.value = new Date().getTime();
	PullDatatimeLabel();
}

let editDataProcessed = false;

onLoad((options: any) => {
	user_store.restoreAuth();

	const editDataStr = uni.getStorageSync('edit_bazi_data');

	if (editDataStr) {
		try {
			const editData = JSON.parse(editDataStr);

			if (editData.isEdit && editData.timestamp) {
				realname.value = editData.realname || '';
				gender.value = editData.gender !== undefined && editData.gender !== null ? editData.gender : 0;
				timestamp.value = editData.timestamp;

				if (editData.recordId) {
					user_store.recordId = editData.recordId;
				}

				editDataProcessed = true;

				uni.removeStorageSync('edit_bazi_data');

				nextTick(() => {
					PullDatatimeLabel();
					uni.showToast({
						title: '已加载数据，可进行编辑',
						icon: 'success',
						duration: 2000,
					});
				});
				return;
			}
		} catch (e) {
			console.warn('解析编辑数据失败:', e);
			uni.removeStorageSync('edit_bazi_data');
		}
	}

	realname.value = '';
	gender.value = 0;
	user_store.recordId = null;

	initCurrentTime();

	if (options && options.showAnnouncements === '1') {
		setTimeout(() => {
			openAnnouncements();
		}, 200);
	}
});

onShow(() => {
	if (editDataProcessed) {
		editDataProcessed = false;
		return;
	}

	const editDataStr = uni.getStorageSync('edit_bazi_data');
	if (editDataStr) {
		try {
			const editData = JSON.parse(editDataStr);
			if (editData.isEdit && editData.timestamp) {
				realname.value = editData.realname || '';
				gender.value = editData.gender !== undefined && editData.gender !== null ? editData.gender : 0;
				timestamp.value = editData.timestamp;
				if (editData.recordId) {
					user_store.recordId = editData.recordId;
				}
				uni.removeStorageSync('edit_bazi_data');
				nextTick(() => {
					PullDatatimeLabel();
				});
				return;
			}
		} catch (e) {
			console.warn('解析编辑数据失败:', e);
			uni.removeStorageSync('edit_bazi_data');
		}
	}

	if (!editDataStr) {
		user_store.recordId = null;
	}
});

function SelectTime() {
	uni.hideKeyboard();
	const timeToUse = timestamp.value || new Date().getTime();
	const timeStr = utils.HideSecond(timeToUse);
	solar_default_value.value = timeStr;
	lunar_default_value.value = timeStr;

	setTimeout(() => {
		if (model.value === 0) {
			solar_select_show.value = true;
		} else {
			lunar_select_show.value = true;
		}
	}, 400);
}

const SolarConfirm = (time: string) => {
	timestamp.value = new Date(time).getTime();
};
const LunarConfirm = (time: string) => {
	timestamp.value = new Date(time).getTime();
};

function PullDatatimeLabel() {
	const time = timestamp.value;
	if (time === null) return;
	const index = model.value;
	const solar = Solar.fromDate(new Date(time));
	const lunar = solar.getLunar();

	const bazi = lunar.getEightChar();
	const baziList = [bazi.getYear(), bazi.getMonth(), bazi.getDay(), bazi.getTime()];
	bazi_label.value = baziList.join(' ');

	if (index === 0) {
		const date = utils.HideSecond(time);
		datetime_label.value = date;
		solar_default_value.value = date;
		lunar_default_value.value = date;
		lunar_label.value = `${lunar.toString()} ${lunar.getTimeZhi()}时`;
	} else {
		const lunarStr = `${lunar.toString()} ${lunar.getTimeZhi()}时`;
		datetime_label.value = lunarStr;
		const date = utils.HideSecond(time);
		solar_default_value.value = date;
		lunar_default_value.value = date;
		lunar_label.value = date;
	}
}

function Sumbit() {
	const datetime = timestamp.value;
	if (datetime === null) {
		uni.showToast({
			title: '请先选择出生日期和时间',
			icon: 'none',
			duration: 2000,
		});
		SelectTime();
		return;
	}

	const params = {
		realname: (realname.value || '').trim() || '佚名',
		timestamp: datetime,
		gender: Number(gender.value),
	};
	uni.showLoading({
		title: '排盘中，请稍后！',
	});

	try {
		uni.setStorageSync('info', JSON.stringify(params));
		const currentRecordId = user_store.recordId;
		user_store.set(params);
		if (currentRecordId) {
			user_store.recordId = currentRecordId;
		} else {
			user_store.recordId = null;
		}

		bazi_store.pull(params);

		setTimeout(() => {
			uni.hideLoading();

			if (!bazi_store.solar || !bazi_store.solar.year) {
				uni.showToast({
					title: '排盘数据不完整，请重试',
					icon: 'none',
					duration: 2000,
				});
				return;
			}

			uni.navigateTo({
				url: '/pages/index/detail',
				fail: (err) => {
					console.error('跳转失败:', err);
					uni.showToast({
						title: '跳转失败，请重试',
						icon: 'none',
						duration: 2000,
					});
				},
			});
		}, 200);
	} catch (error: any) {
		uni.hideLoading();
		console.error('排盘失败:', error);
		uni.showToast({
			title: '排盘计算失败：' + (error?.message || '未知错误'),
			icon: 'none',
			duration: 2000,
		});
	}
}

function loadAnnouncementCache() {
	try {
		const cacheStr = uni.getStorageSync(ANN_CACHE_KEY);
		if (!cacheStr) return null;
		return JSON.parse(cacheStr);
	} catch (e) {
		return null;
	}
}

function saveAnnouncementCache(payload: { signature: string; list: Announcement[] }) {
	try {
		uni.setStorageSync(ANN_CACHE_KEY, JSON.stringify(payload));
	} catch (e) {
		// ignore
	}
}

function buildSignature(meta: AnnouncementMeta[]) {
	return meta.map((m) => `${m.id}-${m.updatedAt || ''}`).join('|');
}

async function refreshAnnouncements() {
	annError.value = '';
	annLoading.value = true;
	try {
		const metaRes = await fetchAnnouncementMeta();
		const metaList = (metaRes.data?.meta || []) as AnnouncementMeta[];
		const newSig = buildSignature(metaList);
		const cache = loadAnnouncementCache();
		if (cache && cache.signature === newSig) {
			announcementList.value = cache.list || [];
			return;
		}
		const fullRes = await fetchAnnouncements();
		const list = (fullRes.data?.list || []) as Announcement[];
		announcementList.value = list;
		saveAnnouncementCache({ signature: newSig, list });
	} catch (e: any) {
		annError.value = e?.error || e?.message || '获取公告失败';
		const cache = loadAnnouncementCache();
		if (cache?.list) {
			announcementList.value = cache.list;
		}
	} finally {
		annLoading.value = false;
	}
}

async function openAnnouncements() {
	const cache = loadAnnouncementCache();
	if (cache?.list) {
		announcementList.value = cache.list;
	}
	showAnnouncementModal.value = true;
	await refreshAnnouncements();
}

function closeAnnouncements() {
	showAnnouncementModal.value = false;
}
</script>


<style scoped>
/* 页面样式已在 app-shell.css 中定义 */
/* 这里只添加页面特定的样式 */

.page-bazi-input .app-main {
	background: radial-gradient(circle at 20% 20%, rgba(102, 126, 234, 0.08), transparent 40%),
		radial-gradient(circle at 80% 10%, rgba(118, 75, 162, 0.08), transparent 38%),
		#f6f8fc;
}

.page-bazi-input .page-shell {
	width: 100%;
	display: flex;
	justify-content: center;
	padding: var(--page-pad-y) var(--page-pad-x);
	box-sizing: border-box;
}

.page-bazi-input .page-card {
	width: 100%;
	max-width: var(--page-max);
	background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
