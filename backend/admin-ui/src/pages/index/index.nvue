	border-radius: 16px;
	box-shadow: 0 12px 32px rgba(31, 41, 55, 0.1);
	padding: 18px 16px;
	position: relative;
	overflow: hidden;
}

.page-bazi-input .page-card::before {
	content: '';
	position: absolute;
	inset: 0;
	background: radial-gradient(circle at 12% 12%, rgba(102, 126, 234, 0.08), transparent 35%),
		radial-gradient(circle at 88% 6%, rgba(118, 75, 162, 0.07), transparent 32%);
	pointer-events: none;
}

.page-bazi-input .page-title-wrapper {
	display: flex;
	align-items: flex-start;
	gap: 12px;
	margin-bottom: 12px;
	position: relative;
	z-index: 1;
}

.page-bazi-input .page-title {
	margin: 0;
	font-size: 22px;
	color: #1f2937;
	letter-spacing: 0.2px;
}

.page-bazi-input .page-subtitle {
	margin: 4px 0 0;
	font-size: 13px;
	color: #6b7280;
}

.page-bazi-input .section {
	background: #ffffff;
	border-radius: 14px;
	border: 1px solid #e2e8f0;
	padding: 14px 12px 12px;
	margin-bottom: 14px;
	box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
	position: relative;
	z-index: 1;
}

.page-bazi-input .section__header {
	display: flex;
	align-items: center;
	gap: 12px;
	margin-bottom: 12px;
	border-bottom: 1px dashed #e5e7eb;
	padding-bottom: 12px;
}

.page-bazi-input .section__title {
	font-size: 18px;
	color: #2d3748;
}

.page-bazi-input .section__body {
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.page-bazi-input .page-card__footer {
	margin-top: 14px;
	padding-top: 10px;
	border-top: 1px solid #eef2f7;
	display: flex;
	justify-content: center;
	position: relative;
	z-index: 1;
	padding-bottom: env(safe-area-inset-bottom);
}

@media (min-width: 900px) {
	.page-bazi-input .page-shell {
		padding: var(--page-pad-y) var(--page-pad-x);
	}
	.page-bazi-input .page-card {
		max-width: var(--page-max);
		padding: 28px 26px;
		border-radius: 20px;
		box-shadow: 0 18px 60px rgba(31, 41, 55, 0.12);
	}
	.page-bazi-input .section {
		padding: 20px 18px 18px;
		margin-bottom: 18px;
	}
}

.layout-wide .page-bazi-input .page-shell {
	padding: var(--page-pad-y) var(--page-pad-x);
}

.layout-wide .page-bazi-input .page-card {
	max-width: var(--page-max);
	padding: 28px 26px;
	border-radius: 20px;
	box-shadow: 0 18px 60px rgba(31, 41, 55, 0.12);
}

.layout-wide .page-bazi-input .section {
	padding: 20px 18px 18px;
	margin-bottom: 18px;
}


/* 未登录状态样式 */
.page-bazi-input .auth-not-logged-in {
	display: flex;
	flex-direction: column;
	gap: 20rpx;
	width: 100%;
}

/* 登录/注册表单样式 */
.page-bazi-input .auth-form-container {
	margin-top: 24rpx;
	padding-top: 24rpx;
	border-top: 1rpx solid #e2e8f0;
	width: 100%;
	box-sizing: border-box;
	background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
	border-radius: 12rpx;
	padding: 24rpx;
}

.page-bazi-input .auth-tabs {
	display: flex;
	flex-direction: row;
	border-bottom: 2rpx solid #e2e8f0;
	margin-bottom: 24rpx;
	width: 100%;
}

.page-bazi-input .auth-tab {
	flex: 1;
	display: flex;
	justify-content: center;
	align-items: center;
	padding: 20rpx 0;
	border-bottom: 4rpx solid transparent;
	transition: all 0.3s;
	min-width: 0;
}

.page-bazi-input .auth-tab.active {
	border-bottom-color: #667eea;
}

.page-bazi-input .auth-form-fields {
	margin-bottom: 20rpx;
	width: 100%;
}

.page-bazi-input .auth-form-hint {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 20rpx;
	width: 100%;
	flex-wrap: wrap;
}

.page-bazi-input .auth-form-hint > view {
	margin-right: 8rpx;
	margin-bottom: 8rpx;
}

.page-bazi-input .auth-form-hint > view:last-child {
	margin-right: 0;
}

.page-bazi-input .auth-error {
	display: flex;
	flex-direction: row;
	align-items: center;
	padding: 16rpx 20rpx;
	background: rgba(245, 101, 101, 0.1);
	border-radius: 12rpx;
	border-left: 4rpx solid #f56565;
	margin-bottom: 20rpx;
	width: 100%;
}

.page-bazi-input .auth-form-actions {
	display: flex;
	flex-direction: column;
	width: 100%;
}

/* 表单卡片样式 - 使用响应式类 */
.page-bazi-input .form-card {
  /* 已在 responsive-card 中定义 */
}

.page-bazi-input .form-header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.page-bazi-input .form-header-text > view {
	margin-bottom: 6px;
}

.page-bazi-input .form-header-text > view:last-child {
	margin-bottom: 0;
}

.page-bazi-input .form-section-card {
	background: linear-gradient(180deg, #fbfdff 0%, #ffffff 100%);
