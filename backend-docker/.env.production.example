#
# Backend production env template.
# Copy to ".env" in production and fill with real secrets.
#

NODE_ENV=production
PORT=3000

# CORS and proxy
CORS_ORIGINS=https://xuan.manafeng.com,https://xuanapi.manafeng.com
TRUST_PROXY=1

# HTTPS:
# If TLS is terminated at nginx/load balancer, keep HTTPS_ENABLED=false.
# If backend serves TLS directly, set HTTPS_ENABLED=true and provide cert/key paths.
HTTPS_ENABLED=false
HTTPS_CERT_PATH=/run/secrets/tls.crt
HTTPS_KEY_PATH=/run/secrets/tls.key

# Database
DB_HOST=db
DB_PORT=3306
DB_USER=app_user
DB_PASS=replace_with_strong_prod_db_password
DB_NAME=bazi_app

# Auth and token
JWT_SECRET=replace_with_32_plus_secure_random_chars
ACCESS_TOKEN_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_DAYS=15

# API signature and replay protection
API_SIGNATURE_SECRET=replace_with_32_plus_secure_random_chars
API_SIGNATURE_TIMESTAMP_WINDOW=300000
API_SIGNATURE_DISABLED=false
REDIS_URL=redis://redis:6379
REDIS_PREFIX=bazi

# Limits and cookie policy
REQUEST_SIZE_LIMIT=10485760
COOKIE_SECURE=true
ALLOW_INSECURE_SECRETS=false

# CSP
CSP_CONNECT_SRC=
CSP_ALLOW_UNSAFE_INLINE=false
CSP_ALLOW_UNSAFE_EVAL=false

# Bootstrap admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_prod_admin_password

# Optional startup switch
SKIP_DB=false
