# ================================================================
# Backend Environment Configuration
# ================================================================
# Copy this file to .env and adjust values for your environment.
# Usage: cp .env.example .env
#
# SCENARIOS:
# - Local Development: Use defaults below (localhost, HTTP)
# - Production: Update CORS_ORIGINS, DB_HOST, secrets, COOKIE_SECURE=true
# - Docker Deploy: Set DB_HOST to service name (e.g., 'db'), configure REDIS_URL
# ================================================================

# ----------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------
# NODE_ENV: production | development
#   - production: Enables production optimizations
#   - development: Enables debug features
NODE_ENV=production

# PORT: Server listening port
#   - Default: 3001 (local dev)
#   - Production: 3000 (or as needed)
PORT=3001

# ----------------------------------------------------------------
# CORS and Proxy Configuration
# ----------------------------------------------------------------
# CORS_ORIGINS: Comma-separated list of allowed origins
#   - Local dev: http://localhost:3000,http://localhost:3001,http://localhost:3002
#   - Production: https://yourdomain.com,https://api.yourdomain.com
#   - Note: Must include protocol (http/https)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ALLOWED_HOSTS: Comma-separated list of allowed Host header values
#   - Local dev: localhost,127.0.0.1,::1,[::1]
#   - Production: yourdomain.com,api.yourdomain.com
#   - Used for Host header injection protection
ALLOWED_HOSTS=localhost,127.0.0.1,::1,[::1]

# TRUST_PROXY: Trust proxy headers
#   - false: Local development (no proxy)
#   - true or 1: Behind reverse proxy (nginx, load balancer)
#   - Number: Number of hops to trust
TRUST_PROXY=false

# ----------------------------------------------------------------
# Database Configuration (MySQL)
# ----------------------------------------------------------------
# DB_HOST: Database server hostname
#   - Local: localhost
#   - Docker: db (service name in docker-compose)
#   - Production: Your database server address
DB_HOST=localhost

# DB_PORT: Database server port
DB_PORT=3306

# DB_USER: Database username
#   - Local: root (or your user)
#   - Production: Use dedicated app user with limited permissions
DB_USER=root

# DB_PASS: Database password
#   IMPORTANT: Change this in production!
DB_PASS=replace_with_local_db_password

# DB_NAME: Database name
DB_NAME=bazi_app

# ----------------------------------------------------------------
# Authentication and Tokens
# ----------------------------------------------------------------
# JWT_SECRET: Secret key for JWT token signing
#   - MUST be at least 32 characters
#   - Use strong random string in production
#   - Generate: openssl rand -base64 32
JWT_SECRET=replace_with_32_plus_random_chars

# ACCESS_TOKEN_EXPIRES_IN: Access token validity period
ACCESS_TOKEN_EXPIRES_IN=30m

# REFRESH_TOKEN_EXPIRES_DAYS: Refresh token validity (days)
REFRESH_TOKEN_EXPIRES_DAYS=15

# ----------------------------------------------------------------
# API Signature and Replay Protection
# ----------------------------------------------------------------
# API_SIGNATURE_SECRET: Secret for API request signing
#   - MUST be at least 32 characters
#   - Should match backend_api_signature_secret in frontend config
API_SIGNATURE_SECRET=replace_with_32_plus_random_chars

# API_SIGNATURE_ENABLED: Enable API signature verification
#   - true: Enable signature verification (recommended for production)
#   - false: Disable for local testing only
API_SIGNATURE_ENABLED=true

# API_SIGNATURE_TIMESTAMP_WINDOW: Request timestamp window (milliseconds)
#   - Requests older than this will be rejected
#   - Default: 300000 (5 minutes)
API_SIGNATURE_TIMESTAMP_WINDOW=300000

# REDIS_URL: Redis connection URL (for nonce cache in multi-instance)
#   - Local dev: Leave empty (single instance)
#   - Production: redis://host:port
#   - Example: redis://redis:6379
REDIS_URL=

# REDIS_PREFIX: Key prefix for Redis storage
REDIS_PREFIX=bazi

# ----------------------------------------------------------------
# Security and Limits
# ----------------------------------------------------------------
# REQUEST_SIZE_LIMIT: Maximum request body size (bytes)
#   - Default: 10485760 (10MB)
REQUEST_SIZE_LIMIT=10485760

# COOKIE_SECURE: Enable secure cookie flag
#   - false: Local development (HTTP)
#   - true: Production (HTTPS required)
COOKIE_SECURE=false

# ALLOW_INSECURE_SECRETS: Allow weak/default secrets
#   - true: Local development only
#   - false: Production (will fail if secrets are weak)
ALLOW_INSECURE_SECRETS=true

# ----------------------------------------------------------------
# Content Security Policy (CSP)
# ----------------------------------------------------------------
# CSP_CONNECT_SRC: Additional allowed connection sources
#   - Leave empty for default
#   - Add WebSocket URLs, API endpoints as needed
CSP_CONNECT_SRC=

# CSP_ALLOW_UNSAFE_INLINE: Allow inline scripts
#   - false: Recommended for production
#   - true: May be needed for some third-party scripts
CSP_ALLOW_UNSAFE_INLINE=false

# CSP_ALLOW_UNSAFE_EVAL: Allow eval() in scripts
#   - false: Recommended for production
#   - true: May be needed for some libraries
CSP_ALLOW_UNSAFE_EVAL=false

# ----------------------------------------------------------------
# Bootstrap Admin Account
# ----------------------------------------------------------------
# Created on first startup if database is empty
# Change these in production!

# ADMIN_USERNAME: Initial admin username
ADMIN_USERNAME=admin123

# ADMIN_EMAIL: Initial admin email
ADMIN_EMAIL=admin123@local.admin

# ADMIN_PASSWORD: Initial admin password
#   IMPORTANT: Change immediately after first login in production!
ADMIN_PASSWORD=replace_with_local_admin_password

# ----------------------------------------------------------------
# Optional Startup Switches
# ----------------------------------------------------------------
# SKIP_DB: Skip database initialization
#   - false: Normal startup with database
#   - true: Start in degraded mode without database
SKIP_DB=false
