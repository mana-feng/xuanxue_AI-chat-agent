#
# Backend local development env template.
# Copy to ".env" for local development.
#

NODE_ENV=development
PORT=3000

# CORS and proxy
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174,https://localhost:3000,https://localhost:3001,https://localhost:3002,https://localhost:5173,https://localhost:5174
TRUST_PROXY=false

# HTTPS (local cert defaults)
HTTPS_ENABLED=true
HTTPS_CERT_PATH=../cert/localhost.pem
HTTPS_KEY_PATH=../cert/localhost-key.pem

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=change_me_local_db_password
DB_NAME=bazi_app

# Auth and token
JWT_SECRET=change_me_to_32_plus_random_chars_for_local
ACCESS_TOKEN_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_DAYS=15

# API signature and replay protection
API_SIGNATURE_SECRET=change_me_to_32_plus_random_chars_for_local
API_SIGNATURE_TIMESTAMP_WINDOW=300000
API_SIGNATURE_DISABLED=false
REDIS_URL=
REDIS_PREFIX=bazi

# Limits and cookie policy
REQUEST_SIZE_LIMIT=10485760
COOKIE_SECURE=false
ALLOW_INSECURE_SECRETS=true

# CSP
CSP_CONNECT_SRC=
CSP_ALLOW_UNSAFE_INLINE=true
CSP_ALLOW_UNSAFE_EVAL=true

# Bootstrap admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_local_admin_password

# Optional startup switch
SKIP_DB=false
