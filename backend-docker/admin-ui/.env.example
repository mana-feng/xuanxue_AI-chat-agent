# ================================================================
# Admin UI Environment Configuration
# ================================================================
# Copy this file to .env and adjust values for your environment.
# Usage: cp .env.example .env
#
# SCENARIOS:
# - Local Development: Use defaults below (localhost, HTTP)
# - Production: Update API URLs to production endpoints
# - Docker Deploy: Configure API_BASE_URL to backend service
# ================================================================

# ----------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------
# VITE_API_BASE_URL: Base URL for API requests
#   - Local dev: http://localhost:3001
#   - Production: https://api.yourdomain.com
#   - Docker: http://backend:3001 (service name)
VITE_API_BASE_URL=http://localhost:3001

# VITE_API_PROXY_TARGET: Proxy target for development server
#   - Should match VITE_API_BASE_URL in most cases
#   - Used by Vite dev server for API proxying
VITE_API_PROXY_TARGET=http://localhost:3001

# ----------------------------------------------------------------
# API Signature Configuration
# ----------------------------------------------------------------
# VITE_API_SIGNATURE_ENABLED: Enable API signature in requests
#   - true: Enable signature (recommended for production)
#   - false: Disable for local testing only
VITE_API_SIGNATURE_ENABLED=true

# VITE_API_SIGNATURE_SECRET: Secret for API request signing
#   - MUST match API_SIGNATURE_SECRET in backend .env
#   - Used to generate request signatures
VITE_API_SIGNATURE_SECRET=replace_with_same_value_as_backend_api_signature_secret

# ----------------------------------------------------------------
# Development Server Configuration
# ----------------------------------------------------------------
# VITE_DEV_PORT: Port for Vite development server
#   - Default: 3002
#   - Change if port is in use
VITE_DEV_PORT=3002

# ----------------------------------------------------------------
# Content Security Policy (CSP)
# ----------------------------------------------------------------
# VITE_CSP_ALLOW_UNSAFE_INLINE: Allow inline scripts
#   - false: Recommended for production
#   - true: May be needed for some third-party scripts
VITE_CSP_ALLOW_UNSAFE_INLINE=false

# VITE_CSP_ALLOW_UNSAFE_EVAL: Allow eval() in scripts
#   - false: Recommended for production
#   - true: May be needed for some libraries
VITE_CSP_ALLOW_UNSAFE_EVAL=false

# VITE_CSP_ALLOW_UNSAFE_STYLE_INLINE: Allow inline styles
#   - true: Often needed for component libraries
#   - false: Stricter security, may break some UI components
VITE_CSP_ALLOW_UNSAFE_STYLE_INLINE=true
