<template>
	<view class="chat-page-shell">
		<yx-nav-header></yx-nav-header>
		<chat-panel class="chat-panel-wrapper" @send="handleSend" ref="panelRef" />
	</view>
</template>

<script lang="ts" setup>
import { ref, onMounted, nextTick } from 'vue';
import ChatPanel from '@/chat/ChatPanel.vue';
import { request } from '@/services/api/index';
import { getAccessToken } from '@/utils/tokenStore';
import { API_BASE_URL } from '@/config/config';
import { useUserStore } from '@/store/user';
import { useBaziStore } from '@/store/bazi';
import { useYunStore } from '@/store/yun';
import { buildBaziExportPayload } from '@/utils/baziExport';
import { encodeTOON } from '@/utils/toon';

const panelRef = ref<InstanceType<typeof ChatPanel> | null>(null);

const userStore = useUserStore();
const baziStore = useBaziStore();
const yunStore = useYunStore();
let firstSendDone = false;

// 加载用户额度信息
async function loadQuotaInfo() {
	try {
		const res = await request('/api/llm/quota', {
			method: 'GET',
			needAuth: true,
		});
		if (res?.success && res?.data) {
			// 确保组件已经挂载
			await nextTick();
			if (panelRef.value) {
				panelRef.value.updateQuotaInfo(res.data);
			}
		}
	} catch (err) {
		console.error('加载额度信息失败:', normalizeError((err as any)?.message || err));
	}
}

// 页面挂载后获取额度信息
onMounted(() => {
	// 延迟一下确保组件完全挂载
	setTimeout(() => {
		loadQuotaInfo();
	}, 100);
});

function handleSend(text: string) {
	sendToLLM(text);
}

function stripHtml(value: unknown): string {
	const raw = String(value ?? '');
	const stripped = raw.replace(/<[^>]+>/g, '');
	return stripped || raw;
}

function maskSensitiveText(value: unknown): string {
	const raw = String(value ?? '');
	return raw
		.replace(/([?&]key=)[^&\s]+/gi, '$1***')
		.replace(
			/([?&](token|access_token|refresh_token|api_key|apikey|signature|sign|nonce)=)[^&\s]+/gi,
			'$1***'
		)
		.replace(/(Bearer\s+)[A-Za-z0-9._~+/=-]+/gi, '$1***')
		.replace(
			/(["']?(api[_-]?key|token|access[_-]?token|refresh[_-]?token|password|secret|authorization|signature)["']?\s*[:=]\s*["']?)([^"',\s}]+)/gi,
			'$1***'
		);
}

function normalizeError(value: unknown): string {
	const stripped = stripHtml(value).trim();
	const masked = maskSensitiveText(stripped);
	const lower = masked.toLowerCase();
	if (
		lower.includes('generativelanguage.googleapis.com') ||
		(lower.includes('request to') && lower.includes('failed'))
	) {
		return '上游服务连接异常，请稍后重试';
	}
	return masked || '调用失败';
}

function normalizeClientError(err: any): { message: string; code?: string } {
	const code = typeof err?.code === 'string' ? err.code : undefined;
	if (code === 'LLM_UPSTREAM_UNREACHABLE') {
		return {
			code,
			message: '上游服务连接异常，请稍后重试或在后台切换可用模型',
		};
	}
	const message = normalizeError(err?.error || err?.message || err?.errMsg || '调用失败');
	return { message, code };
}

function isQuotaErrorText(value: unknown): boolean {
	const text = String(value ?? '').toLowerCase();
	return text.includes('quota') || text.includes('limit') || text.includes('rate') || text.includes('额度');
}

function buildMessages(text: string) {
	const panel = panelRef.value;
	if (!panel) {
		return [{ role: 'user', content: text }];
	}
	
	// 获取历史消息（排除初始欢迎消息）
	const historyMessages = panel.getMessages();
	const messages: Array<{ role: string; content: string }> = [];
	
	// 只在第一次发送时添加系统消息（八字信息）
	if (!firstSendDone) {
		const payload = buildBaziExportPayload(userStore, baziStore, yunStore);
		const baziToon = payload ? encodeTOON(payload) : null;
		if (baziToon) {
			messages.push({
				role: 'system',
				content: `User Bazi profile (TOON): \n${baziToon}`
			});
		}
		firstSendDone = true;
	}
	
	// 添加历史对话（排除初始欢迎消息和等待/流式状态的消息）
	for (const msg of historyMessages) {
		// 跳过初始欢迎消息（id 为 'm-1'）
		if (msg.id === 'm-1') continue;
		// 跳过等待状态和流式状态的消息（这些是临时状态）
		if (msg.status === 'waiting' || msg.status === 'stream') continue;
		// 只添加已完成的消息
		if (msg.text && msg.text.trim()) {
			messages.push({
				role: msg.role === 'user' ? 'user' : 'assistant',
				content: msg.text
			});
		}
	}
	
	// 添加当前用户消息
	messages.push({ role: 'user', content: text });
	
	return messages;
}

async function sendToLLM(text: string) {
	const panel = panelRef.value;
	if (!panel) return;
	panel.setSending(true);
	
	// 立即创建等待状态的助手消息
	panel.createWaitingMessage();

	try {
		// 后端已统一处理配置，前端不需要重新加载
		const messages = buildMessages(text);
		const token = getAccessToken();
		if (token) {
			try {
				await sendWithWS(messages, token);
			} catch (wsErr) {
				// WebSocket 失败，回退到 HTTP
				await sendWithHttp(messages);
			}
		} else {
			await sendWithHttp(messages);
		}
	} catch (err: any) {
		const normalizedErr = normalizeClientError(err);
		console.error('调用大模型接口失败:', normalizedErr.message);
		if (err?.statusCode === 429 || isQuotaErrorText(normalizedErr.message)) {
			panel.appendAssistant(`⚠️ ${normalizedErr.message}`, 'error');
		} else {
			panel.appendAssistant(`调用失败：${normalizedErr.message}`, 'error');
		}
	} finally {
		panel.setSending(false);
	}
}

async function sendWithHttp(messages: Array<{ role: string; content: string }>) {
	const res = await request('/api/llm/chat', {
		method: 'POST',
		needAuth: true,
		data: {
			stream: false,
			messages
		}
	});

	if (!res?.success) {
		const errorMsg = normalizeError(res?.error || res?.message || '调用失败');
		if (isQuotaErrorText(errorMsg)) {
			throw { error: errorMsg, statusCode: 429, code: res?.code };
		}
		const error: any = new Error(errorMsg);
		if (res?.code) error.code = res.code;
		throw error;
	}
	
	// 后端已统一返回格式：{ reply: text }
	const reply = stripHtml(res.data?.reply || '');
	if (!reply || reply.trim() === '') {
		panelRef.value?.appendAssistant('回复为空，请检查后端配置', 'error');
		return;
	}
	panelRef.value?.appendAssistant(String(reply), 'ready');
	// 额度更新仅在后端执行，前端通过 API 读取
	setTimeout(() => {
		loadQuotaInfo();
	}, 300);
}

function getWsUrl() {
	// 将 HTTP/HTTPS 转换为 WS/WSS
	let wsBase = API_BASE_URL;
	if (wsBase.startsWith('https://')) {
		wsBase = wsBase.replace('https://', 'wss://');
	} else if (wsBase.startsWith('http://')) {
		wsBase = wsBase.replace('http://', 'ws://');
	}
	// 移除末尾的斜杠
	wsBase = wsBase.replace(/\/$/, '');
	return `${wsBase}/api/llm/chat/ws`;
}

function cleanHtml(str: string) {
	return stripHtml(str);
}

async function sendWithWS(messages: Array<{ role: string; content: string }>, token: string) {
	const wsUrl = getWsUrl();
	const wsProtocols = ['bearer', token];
	return new Promise<void>((resolve, reject) => {
		const panel = panelRef.value;
		if (!panel) return reject(new Error('no panel'));

		let lineBuffer = ''; // 按行缓冲
		let closed = false;
		
		// uni-app WebSocket 连接
		const socketTask = uni.connectSocket({
			url: wsUrl,
			protocols: wsProtocols,
			header: {
				Authorization: `Bearer ${token}`
			},
			fail: (err: any) => {
				if (!closed) {
					closed = true;
					const errorMsg = normalizeError(err?.errMsg || '连接失败');
					panel.appendAssistant(`连接失败：${errorMsg}`, 'error');
					reject(new Error(errorMsg));
				}
			}
		});

		// 设置超时：如果10分钟内没有收到任何消息，显示错误
		let timeoutId: ReturnType<typeof setTimeout> | null = null;
		let firstMessageReceived = false;
		
		// 监听连接打开
		socketTask.onOpen(() => {
			// 连接成功后发送消息
			socketTask.send({
				data: JSON.stringify({
					stream: true,
					messages
				}),
				success: () => {
					// 设置超时
					timeoutId = setTimeout(() => {
						if (!closed && !firstMessageReceived) {
							closed = true;
							panel.appendAssistant('请求超时，请检查网络连接或稍后重试', 'error');
							panel.setSending(false);
							socketTask.close();
							reject(new Error('请求超时'));
						}
					}, 10 * 60 * 1000); // 10分钟超时
				},
				fail: (err: any) => {
					if (!closed) {
						closed = true;
						const errorMsg = normalizeError(err?.errMsg || '发送失败');
						panel.appendAssistant(`发送失败：${errorMsg}`, 'error');
						if (timeoutId) clearTimeout(timeoutId);
						reject(new Error(errorMsg));
					}
				}
			});
		});

		// 监听消息 - 按行解析 NDJSON
		socketTask.onMessage((evt: any) => {
			if (!firstMessageReceived) {
				firstMessageReceived = true;
				if (timeoutId) {
					clearTimeout(timeoutId);
				}
			}
			
			const chunk = typeof evt?.data === 'string' ? evt.data : '';
			if (!chunk) {
				return;
			}

			// 累积到行缓冲
			lineBuffer += chunk;

			// 按行处理（NDJSON 格式：每行一个 JSON）
			let idx;
			while ((idx = lineBuffer.indexOf('\n')) >= 0) {
				const line = lineBuffer.slice(0, idx).trim();
				lineBuffer = lineBuffer.slice(idx + 1);

				if (!line) continue;

				let msg;
				try {
					msg = JSON.parse(line);
				} catch (err) {
					// 这一行解析失败，可能是数据不完整或格式错误
					// 简单地丢弃它，防止无限循环
					// 如果需要更复杂的重试逻辑，可以检查 line 是否以 '}' 结尾等
					console.warn('NDJSON parse error for line:', line);
					// lineBuffer = line + '\n' + lineBuffer; // 这种回退逻辑会导致无限循环
					continue;
				}

				// 处理不同事件类型
				if (msg.event === 'delta' && msg.text) {
					// 增量文本：使用流式模式追加
					const cleaned = cleanHtml(msg.text);
					if (cleaned) {
						panel.appendAssistant(cleaned, 'stream');
					}
				} else if (msg.event === 'done') {
					// 完成标记：将流式状态改为完成
					panel.finishStreaming();
					// 额度更新仅在后端执行，前端通过 API 读取
					setTimeout(() => {
						loadQuotaInfo();
					}, 300);
				} else if (msg.event === 'error') {
					const errorMsg = normalizeError(msg.message || msg.error || '未知错误');
					if (isQuotaErrorText(errorMsg)) {
						panel.appendAssistant(`⚠️ ${errorMsg}`, 'error');
					} else {
						panel.appendAssistant(`错误：${errorMsg}`, 'error');
					}
				} else if (msg.error) {
					// 错误消息
					const errorMsg = normalizeError(msg.error || '未知错误');
					if (isQuotaErrorText(errorMsg)) {
						panel.appendAssistant(`⚠️ ${errorMsg}`, 'error');
					} else {
						panel.appendAssistant(`错误：${errorMsg}`, 'error');
					}
				}
			}
		});

		// 监听连接关闭
		socketTask.onClose(() => {
			if (closed) return;
			closed = true;
			if (timeoutId) clearTimeout(timeoutId);
			// 处理剩余的 buffer
			if (lineBuffer.trim()) {
				try {
					const msg = JSON.parse(lineBuffer.trim());
					if (msg.event === 'delta' && msg.text) {
						const cleaned = cleanHtml(msg.text);
						if (cleaned) {
							panel.appendAssistant(cleaned, 'stream');
						}
					} else if (msg.event === 'error') {
						const errorMsg = normalizeError(msg.message || msg.error || '未知错误');
						if (isQuotaErrorText(errorMsg)) {
							panel.appendAssistant(`⚠️ ${errorMsg}`, 'error');
						} else {
							panel.appendAssistant(`错误：${errorMsg}`, 'error');
						}
					}
				} catch (e) {
					void 0;
				}
			}
			// 将流式状态改为完成
			panel.finishStreaming();
			resolve();
		});

		// 监听错误
		socketTask.onError((err: any) => {
			if (closed) return;
			closed = true;
			if (timeoutId) clearTimeout(timeoutId);
			const errorMsg = normalizeError(err?.errMsg || 'WebSocket 错误');
			if (isQuotaErrorText(errorMsg)) {
				panel.appendAssistant(`⚠️ ${errorMsg}`, 'error');
			} else {
				panel.appendAssistant(`连接错误：${errorMsg}`, 'error');
			}
			reject(new Error(errorMsg));
		});
	});
}
</script>

<style scoped>
.chat-page-shell {
	min-height: 100vh;
	background: #f3f4f6;
	display: flex;
	flex-direction: column;
}

.chat-panel-wrapper {
	flex: 1;
}
</style>
