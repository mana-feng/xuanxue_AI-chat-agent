<template>
	<tm-app>
		<view class="page-wrapper theme-page-bg">
			<yx-nav-header></yx-nav-header>

			<view class="page-content theme-container" :style="pageContentStyle">
				<view class="theme-card theme-card-glass">
				<view class="header">
					<tm-text :font-size="42" :bold="true" color="#2d3748" label="邮箱服务配置"></tm-text>
					<view class="header-actions">
						<tm-button
							class="btn-gradient"
							size="small"
							color="teal"
							linear="right"
							:round="12"
							:padding="[20, 24]"
							label="返回后台"
							@tap="goBack"
						></tm-button>
					</view>
				</view>

				<tm-sheet :round="16" :shadow="4" :padding="[32, 28]" class="config-card" :follow-dark="true">
					<view class="status-row">
						<tm-text :font-size="30" :bold="true" color="#2d3748" :label="configured ? '已配置' : '未配置'"></tm-text>
						<tm-tag
							:label="configured ? '可发送验证码' : '未启用'"
							:color="configured ? 'green' : 'grey'"
							size="small"
							:round="8"
						></tm-tag>
					</view>

					<view class="history-section">
						<view class="history-header">
							<tm-text :font-size="28" :bold="true" color="#4b5563" label="历史配置"></tm-text>
							<tm-text :font-size="22" color="#9ca3af" label="编辑、删除或切换以往记录"></tm-text>
						</view>
						<view v-if="historyLoading" class="history-hint">
							<tm-text :font-size="24" color="#9ca3af" label="加载中..."></tm-text>
						</view>
						<view v-else-if="historyList.length > 0" class="history-list">
							<view
								v-for="item in historyList"
								:key="item.id"
								class="history-item"
								:class="{ active: item.is_active === 1 }"
							>
								<view class="history-info">
									<tm-text :font-size="26" :bold="item.is_active === 1" :label="item.from || item.user"></tm-text>
									<tm-text :font-size="22" color="#6b7280" :label="`${item.host}:${item.port} / ${item.user}`"></tm-text>
									<tm-text
										v-if="item.created_at"
										:font-size="20"
										color="#9ca3af"
										:label="`创建时间: ${formatDate(item.created_at)}`"
									></tm-text>
								</view>
								<view class="history-actions">
									<tm-button
										v-if="item.is_active !== 1"
										size="small"
										type="primary"
										label="切换"
										:loading="activatingId === item.id"
										:disabled="activatingId === item.id || deletingId === item.id"
										:margin="[0, 8, 0, 0]"
										@tap="activateFromHistory(item.id)"
									></tm-button>
									<tm-button
										size="small"
										color="orange"
										label="编辑"
										@tap="editFromHistory(item)"
										:margin="[0, 8, 0, 0]"
									></tm-button>
									<tm-button
										v-if="item.is_active !== 1"
										size="small"
										color="red"
										label="删除"
										:loading="deletingId === item.id"
										:disabled="activatingId === item.id || deletingId === item.id"
										@tap="deleteFromHistory(item.id)"
									></tm-button>
									<tm-text v-else :font-size="22" color="#10b981" label="当前使用"></tm-text>
								</view>
							</view>
						</view>
						<view v-else class="history-hint">
							<tm-text :font-size="24" color="#9ca3af" label="暂无历史配置，保存后会出现在这里"></tm-text>
						</view>
					</view>

					<view class="responsive-form-grid-md-2">
						<tm-input 
							v-model="form.host" 
							label="SMTP 主机" 
							placeholder="如 smtp.qq.com" 
							:margin="[0, 0, 0, 0]"
							:round="12"
							:border="1"
						/>
						<tm-input
							v-model.number="form.port"
							label="SMTP 端口"
							type="number"
							placeholder="如 465"
							:margin="[0, 0, 0, 0]"
							:round="12"
							:border="1"
						/>
						<tm-input
							v-model="form.user"
							label="SMTP 账号"
							placeholder="邮箱账号"
							:margin="[0, 0, 0, 0]"
							:round="12"
							:border="1"
						/>
						<tm-input
							v-model="form.pass"
							label="SMTP 密码/授权码"
							type="password"
							placeholder="请输入密码或授权码"
							:margin="[0, 0, 0, 0]"
							:round="12"
							:border="1"
						/>
						<tm-input
							v-model="form.from"
							label="发件邮箱地址"
							placeholder="用于邮件 From 邮箱"
							:margin="[0, 0, 0, 0]"
							:round="12"
							:border="1"
						/>
						<tm-input
							v-model="form.fromName"
							label="发件人名称（可选，用于显示）"
							placeholder="如：Ai八字 或 你的姓名"
							:margin="[0, 0, 0, 0]"
							:round="12"
							:border="1"
						/>
					</view>

					<view class="tip-container">
						<tm-icon name="information-circle" :font-size="24" color="#667eea" :margin="[0, 12, 0, 0]"></tm-icon>
						<tm-text
							:font-size="24"
							color="#718096"
							label="填写后点击保存，密码不会回显；若需更换密码请重新填写。"
						></tm-text>
					</view>

					<tm-button
						class="btn-gradient"
						color="teal"
						linear="right"
						block
						:loading="saving"
						:margin="[32, 0, 0, 0]"
						:round="12"
						label="保存配置"
						@tap="handleSave"
					></tm-button>
				</tm-sheet>
				</view>
			</view>
		</view>
	</tm-app>
</template>

<script setup lang="ts">
import { onMounted, reactive, ref, computed } from 'vue';
import { useUserStore } from '@/store/user';
import {
	getAdminEmailConfig,
	updateAdminEmailConfig,
	getAdminEmailConfigHistory,
	activateAdminEmailConfig,
	deleteAdminEmailConfig,
	EmailConfigHistoryItem
} from '@/services/api/admin';

const userStore = useUserStore();

const configured = ref(false);
const form = reactive({
	host: '',
	port: 0,
	user: '',
	pass: '',
	from: '',
	fromName: ''
});

const loading = ref(false);
const saving = ref(false);
const historyList = ref<EmailConfigHistoryItem[]>([]);
const historyLoading = ref(false);
const activatingId = ref<number | null>(null);
const deletingId = ref<number | null>(null);

// navbar 高度（rpx），与 yx-nav-header 中的 navbarHeight 保持一致
const navbarHeight = 40;

// 计算页面内容的 padding-top，避免被 fixed 的 header 遮挡
const pageContentStyle = computed(() => {
	return {
		paddingTop: `${navbarHeight + 20}rpx` // navbar高度 + 原有padding
	};
});

function formatDate(dateStr: string) {
	const date = new Date(dateStr);
	return isNaN(date.getTime()) ? dateStr : date.toLocaleString('zh-CN');
}

onMounted(() => {
	userStore.restoreAuth();
	if (!userStore.isAdmin) {
		uni.reLaunch({
			url: '/pages/auth/auth'
		});
		return;
	}
	loadConfig();
	loadHistory();
});

async function loadConfig() {
	loading.value = true;
	try {
		const res = await getAdminEmailConfig();
		if (res.success && res.data) {
			const cfg = res.data;
			configured.value = !!cfg.configured;
			form.host = cfg.host || '';
			form.port = cfg.port || 0;
			form.user = cfg.user || '';
			form.from = cfg.from || '';
			form.fromName = cfg.fromName || '';
			form.pass = '';
		}
	} catch (err) {
		console.error('获取邮箱配置失败', err);
		uni.showToast({ title: '加载失败', icon: 'none' });
	} finally {
		loading.value = false;
	}
}

async function loadHistory() {
	historyLoading.value = true;
	try {
		const res = await getAdminEmailConfigHistory();
		if (res?.success && Array.isArray(res.data)) {
			historyList.value = res.data;
		} else {
			historyList.value = [];
		}
	} catch (err) {
		console.error('加载邮箱配置历史失败', err);
		uni.showToast({ title: '加载历史失败', icon: 'none' });
		historyList.value = [];
	} finally {
		historyLoading.value = false;
	}
}

function editFromHistory(item: EmailConfigHistoryItem) {
	form.host = item.host || '';
	form.port = Number(item.port) || 0;
	form.user = item.user || '';
	form.from = item.from || '';
	form.fromName = item.fromName || '';
	form.pass = item.pass || '';
	uni.pageScrollTo({ scrollTop: 0, duration: 300 });
	uni.showToast({ title: '已加载配置到表单', icon: 'none' });
}

async function activateFromHistory(id: number) {
	if (!id || activatingId.value !== null) return;
	activatingId.value = id;
	try {
		await activateAdminEmailConfig(id);
		uni.showToast({ title: '已切换', icon: 'success' });
		await loadConfig();
		await loadHistory();
	} catch (err: any) {
		console.error('切换邮箱配置失败', err);
		const msg = err?.error || err?.message || '切换失败';
		uni.showToast({ title: msg, icon: 'none' });
	} finally {
		activatingId.value = null;
	}
}

async function deleteFromHistory(id: number) {
	if (!id || deletingId.value !== null) return;
	const modal = await uni.showModal({
		title: '确认删除',
		content: '确认要删除该邮箱配置吗？此操作不可恢复',
		confirmText: '删除',
		confirmColor: '#ef4444'
	});
	if (!modal.confirm) return;
	deletingId.value = id;
	try {
		await deleteAdminEmailConfig(id);
		uni.showToast({ title: '已删除', icon: 'success' });
		await loadHistory();
	} catch (err: any) {
		console.error('删除邮箱配置失败', err);
		const msg = err?.error || err?.message || '删除失败';
		uni.showToast({ title: msg, icon: 'none' });
	} finally {
		deletingId.value = null;
	}
}

async function handleSave() {
	if (!form.host || !form.port || !form.user || !form.from) {
		uni.showToast({ title: '请填写完整配置', icon: 'none' });
		return;
	}
	if (Number(form.port) <= 0) {
		uni.showToast({ title: '端口必须为正数', icon: 'none' });
		return;
	}
	saving.value = true;
	try {
		await updateAdminEmailConfig({
			host: form.host.trim(),
			port: Number(form.port),
			user: form.user.trim(),
			pass: form.pass,
			from: form.from.trim(),
			fromName: form.fromName.trim()
		});
		uni.showToast({ title: '保存成功', icon: 'success' });
		await loadConfig();
		await loadHistory();
	} catch (err) {
		console.error('保存邮箱配置失败', err);
		const msg = err?.error || '保存失败';
		uni.showToast({ title: msg, icon: 'none' });
	} finally {
		saving.value = false;
	}
}

function goBack() {
	uni.navigateBack({
		fail: () => {
			uni.reLaunch({ url: '/pages/admin/dashboard' });
		}
	});
}
</script>

<style scoped>
.page-wrapper {
	padding-bottom: 40rpx;
}

.page-content {
	/* theme-container + pageContentStyle 控制内边距 */
}

.theme-card {
	padding: 24px 20px 28px;
}

.header {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 20rpx;
}

.header-actions {
	display: flex;
	flex-direction: row;
	align-items: center;
}

.status-row {
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 24rpx;
}

.history-section {
	display: flex;
	flex-direction: column;
	gap: 12rpx;
	margin-bottom: 24rpx;
}

.history-header {
	display: flex;
	flex-direction: column;
	gap: 4rpx;
}

.history-list {
	display: flex;
	flex-direction: column;
	gap: 12rpx;
}

.history-item {
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	padding: 16rpx 18rpx;
	border: 1px solid #e5e7eb;
	border-radius: 12rpx;
	background: #f9fafb;
}

.history-item.active {
	border-color: #10b981;
	background: #ecfdf3;
}

.history-info {
	display: flex;
	flex-direction: column;
	gap: 6rpx;
	flex: 1;
}

.history-actions {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-left: 12rpx;
}

.history-hint {
	padding: 16rpx;
	text-align: center;
	color: #9ca3af;
	border: 1px dashed #e5e7eb;
	border-radius: 12rpx;
}

.tip-text {
	margin-top: 20rpx;
}
</style>

