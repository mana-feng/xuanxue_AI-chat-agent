<template>
  <tm-app>
    <view class="page-wrapper theme-page-bg">
      <yx-nav-header></yx-nav-header>

      <view class="page-content theme-container">
        <view class="theme-card theme-card-glass">
          <view class="header">
            <tm-text :font-size="36" :bold="true" color="#2d3748" label="大模型管理"></tm-text>
            <tm-text :font-size="24" color="#6b7280" :label="sceneDescription"></tm-text>
          </view>

          <tm-sheet :round="12" :shadow="2" :padding="[24, 20]" class="form-card">
            <view class="scene-switch">
              <view
                v-for="scene in scopeOptions"
                :key="scene.value"
                class="scene-chip"
                :class="{ active: currentScope === scene.value }"
                @tap="switchScope(scene.value)"
              >
                <tm-text
                  :font-size="24"
                  :bold="currentScope === scene.value"
                  :color="currentScope === scene.value ? '#0f172a' : '#475569'"
                  :label="scene.label"
                ></tm-text>
                <tm-text
                  :font-size="20"
                  :color="currentScope === scene.value ? '#334155' : '#94a3b8'"
                  :label="scene.hint"
                ></tm-text>
              </view>
            </view>

            <view class="form-group">
              <tm-text :font-size="26" color="#4b5563" :label="`当前模型（${currentScopeLabel}）`"></tm-text>
              <tm-text :font-size="24" color="#111827" :label="currentModelDisplay"></tm-text>
              <tm-text
                v-if="modelHistory.length === 0 && !loading"
                :font-size="22"
                color="#9ca3af"
                label="暂无历史配置记录"
              ></tm-text>
            </view>

            <view class="form-group">
              <tm-text :font-size="26" color="#4b5563" label="历史模型配置"></tm-text>
              <view v-if="loading" class="loading-hint">
                <tm-text :font-size="22" color="#9ca3af" label="加载中..."></tm-text>
              </view>
              <view v-else-if="modelHistory.length > 0" class="model-list">
                <view
                  v-for="model in modelHistory"
                  :key="model.id"
                  class="model-item"
                  :class="{ active: model.is_active === 1 }"
                >
                  <view class="model-info">
                    <tm-text
                      :font-size="24"
                      :bold="model.is_active === 1"
                      :label="model.name || `${model.provider}-${model.model}`"
                    ></tm-text>
                    <tm-text
                      :font-size="22"
                      color="#6b7280"
                      :label="`${model.provider} / ${model.model}`"
                    ></tm-text>
                    <tm-text
                      v-if="model.created_at"
                      :font-size="20"
                      color="#9ca3af"
                      :label="`创建时间: ${new Date(model.created_at).toLocaleString('zh-CN')}`"
                    ></tm-text>
                  </view>
                  <view class="model-actions">
                    <tm-button
                      v-if="model.is_active !== 1"
                      size="small"
                      type="primary"
                      label="切换"
                      @tap="activateModel(model.id)"
                      :margin="[0, 10, 0, 0]"
                    ></tm-button>
                    <tm-button
                      size="small"
                      color="orange"
                      label="编辑"
                      @tap="editModel(model)"
                      :margin="[0, 10, 0, 0]"
                    ></tm-button>
                    <tm-button
                      v-if="model.is_active !== 1"
                      size="small"
                      color="red"
                      label="删除"
                      @tap="deleteModel(model.id)"
                    ></tm-button>
                    <tm-text v-else :font-size="22" color="#10b981" label="当前使用"></tm-text>
                  </view>
                </view>
              </view>
              <view v-else class="empty-hint">
                <tm-text
                  :font-size="22"
                  color="#9ca3af"
                  label="暂无历史配置，保存配置后将显示在此处"
                ></tm-text>
              </view>
            </view>

            <view class="responsive-form-grid-md-2">
              <view class="form-group">
                <tm-text :font-size="26" color="#4b5563" label="供应商"></tm-text>
                <picker
                  mode="selector"
                  :range="providerOptions"
                  range-key="label"
                  :value="providerIndex"
                  @change="onProviderChange"
                >
                  <view class="picker-trigger">
                    <tm-text :font-size="26" color="#111827" :label="currentProviderLabel"></tm-text>
                    <tm-icon name="arrow-down" :font-size="26" color="#9ca3af"></tm-icon>
                  </view>
                </picker>
              </view>

              <view class="form-group">
                <tm-text :font-size="26" color="#4b5563" label="API Base URL"></tm-text>
                <tm-input
                  v-model="form.baseUrl"
                  placeholder="https://api.example.com"
                  :margin="[0, 0, 0, 0]"
                  :round="10"
                ></tm-input>
              </view>

              <view class="form-group">
                <tm-text :font-size="26" color="#4b5563" label="API Key"></tm-text>
                <tm-input
                  v-model="form.apiKey"
                  placeholder="输入密钥"
                  :password="true"
                  :margin="[0, 0, 0, 0]"
                  :round="10"
                ></tm-input>
              </view>

              <view class="form-group">
                <tm-text :font-size="26" color="#4b5563" label="模型名称"></tm-text>
                <tm-input
                  v-model="form.model"
                  placeholder="如 gpt-4o, claude-3.5, qwen3.5:0.8b"
                  :margin="[0, 0, 0, 0]"
                  :round="10"
                ></tm-input>
              </view>

              <view class="form-group">
                <tm-text :font-size="26" color="#4b5563" label="配置名称（可选）"></tm-text>
                <tm-input
                  v-model="form.name"
                  placeholder="如：主页 Agent - Ollama"
                  :margin="[0, 0, 0, 0]"
                  :round="10"
                ></tm-input>
              </view>
            </view>

            <view class="form-group">
              <tm-text :font-size="26" color="#4b5563" label="额外参数（JSON，可选）"></tm-text>
              <tm-input
                v-model="form.extra"
                type="textarea"
                placeholder='如：{ "temperature": 0.7 }'
                :height="120"
                :margin="[0, 0, 0, 0]"
                :round="10"
              ></tm-input>
            </view>

            <view class="actions">
              <tm-button
                class="btn-gradient"
                color="teal"
                linear="right"
                :round="12"
                :padding="[18, 22]"
                :loading="saving"
                :disabled="saving"
                label="保存配置"
                @tap="handleSave"
              ></tm-button>
            </view>
          </tm-sheet>
        </view>
      </view>
    </view>
  </tm-app>
</template>

<script setup lang="ts">
import { computed, onMounted, reactive, ref } from 'vue';
import { useUserStore } from '@/store/user';
import { request } from '@/services/api/index';

type LlmScope = 'chat' | 'agent';

type HistoryModel = {
  id: number;
  scope?: string;
  name: string;
  provider: string;
  base_url: string;
  api_key: string;
  model: string;
  extra: string | null;
  is_active: number;
  created_at: string;
  updated_at: string;
};

const userStore = useUserStore();
const saving = ref(false);
const loading = ref(false);
const currentScope = ref<LlmScope>('chat');

const scopeOptions: Array<{ value: LlmScope; label: string; hint: string }> = [
  { value: 'chat', label: 'Chat 页面', hint: '登录后使用，保留额度校验' },
  { value: 'agent', label: '主页 Agent', hint: '匿名可用，不做额度检查' },
];

const form = reactive({
  provider: 'openai',
  baseUrl: '',
  apiKey: '',
  model: '',
  extra: '',
  name: '',
});

const modelHistory = ref<HistoryModel[]>([]);

const providerOptions = [
  { value: 'openai', label: 'OpenAI / DeepSeek 兼容' },
  { value: 'anthropic', label: 'Anthropic Claude' },
  { value: 'deepseek', label: 'DeepSeek' },
  { value: 'qwen', label: '通义千问 (兼容模式)' },
  { value: 'gemini', label: 'Google Gemini' },
  { value: 'ollama', label: 'Ollama (local /api/chat)' },
];

const providerIndex = ref(0);

const currentScopeLabel = computed(() => {
  return scopeOptions.find((item) => item.value === currentScope.value)?.label || 'Chat 页面';
});

const sceneDescription = computed(() => {
  return currentScope.value === 'chat'
    ? '配置聊天页调用的大模型 API，保留登录和额度校验'
    : '配置主页 Agent 调用的大模型 API，允许匿名直接使用';
});

const currentModelDisplay = computed(() => {
  const active = modelHistory.value.find((model) => model.is_active === 1);
  if (active) {
    return `${active.name || '未命名'} (${active.provider} / ${active.model})`;
  }

  if (form.provider && form.model) {
    const providerLabel = providerOptions.find((item) => item.value === form.provider)?.label || form.provider;
    return `${providerLabel} / ${form.model}${form.baseUrl ? ' (已配置)' : ' (未完整配置)'}`;
  }

  return '未配置';
});

const currentProviderLabel = computed(() => {
  const item = providerOptions.find((provider) => provider.value === form.provider);
  return item ? item.label : '选择供应商';
});

function buildScopeUrl(path: string) {
  const separator = path.includes('?') ? '&' : '?';
  return `${path}${separator}scope=${currentScope.value}`;
}

function normalizeConfigPayload(res: any) {
  return (res?.data && typeof res.data === 'object' ? res.data : res) || {};
}

function resetForm() {
  form.provider = 'openai';
  form.baseUrl = '';
  form.apiKey = '';
  form.model = '';
  form.extra = '';
  form.name = '';
  providerIndex.value = 0;
}

async function loadConfig() {
  loading.value = true;
  try {
    const res = await request(buildScopeUrl('/api/admin/llm-config'), { method: 'GET', needAuth: true });
    const payload = normalizeConfigPayload(res);

    if (payload?.provider !== undefined) {
      form.provider = payload.provider || 'openai';
      form.baseUrl = payload.baseUrl || '';
      form.apiKey = payload.apiKey || '';
      form.model = payload.model || '';
      form.extra = payload.extra || '';
      form.name = payload.name || '';
      const idx = providerOptions.findIndex((item) => item.value === form.provider);
      providerIndex.value = idx >= 0 ? idx : 0;
    } else {
      resetForm();
    }

    await loadModelHistory();
  } catch (err) {
    console.warn('load llm config failed:', err);
    uni.showToast({ title: '加载失败', icon: 'none' });
  } finally {
    loading.value = false;
  }
}

async function loadModelHistory() {
  try {
    const res = await request<HistoryModel[]>(buildScopeUrl('/api/admin/llm-models'), {
      method: 'GET',
      needAuth: true,
    });
    modelHistory.value = Array.isArray(res?.data) ? res.data : [];
  } catch (err) {
    console.error('load llm model history failed:', err);
    modelHistory.value = [];
  }
}

async function activateModel(modelId: number) {
  try {
    await request(buildScopeUrl(`/api/admin/llm-models/${modelId}/activate`), {
      method: 'POST',
      needAuth: true,
      data: { scope: currentScope.value },
    });
    uni.showToast({ title: '已切换', icon: 'success', duration: 1500 });
    await loadConfig();
  } catch (err) {
    console.error('activate model failed:', err);
    uni.showToast({ title: '切换失败', icon: 'none' });
  }
}

async function deleteModel(modelId: number) {
  try {
    const modal = await uni.showModal({
      title: '确认删除',
      content: '确定要删除该模型配置吗？此操作无法撤销。',
      confirmText: '删除',
      confirmColor: '#ef4444',
    });
    if (!modal.confirm) {
      return;
    }

    await request(buildScopeUrl(`/api/admin/llm-models/${modelId}`), {
      method: 'DELETE',
      needAuth: true,
      data: { scope: currentScope.value },
    });
    uni.showToast({ title: '已删除', icon: 'success' });
    await loadModelHistory();
  } catch (err) {
    console.error('delete model failed:', err);
    uni.showToast({ title: '删除失败', icon: 'none' });
  }
}

function editModel(model: HistoryModel) {
  form.provider = model.provider;
  form.baseUrl = model.base_url;
  form.apiKey = model.api_key;
  form.model = model.model;
  form.name = model.name;
  form.extra = model.extra || '';

  const idx = providerOptions.findIndex((item) => item.value === model.provider);
  providerIndex.value = idx >= 0 ? idx : 0;

  uni.pageScrollTo({ scrollTop: 0, duration: 300 });
  uni.showToast({ title: '已加载配置到表单', icon: 'none' });
}

function switchScope(scope: LlmScope) {
  if (currentScope.value === scope) {
    return;
  }
  currentScope.value = scope;
  resetForm();
  modelHistory.value = [];
  void loadConfig();
}

onMounted(() => {
  void loadConfig();
});

async function handleSave() {
  if (!userStore.isAdmin) {
    uni.showToast({ title: '仅管理员可操作', icon: 'none' });
    return;
  }

  saving.value = true;
  try {
    await request(buildScopeUrl('/api/admin/llm-config'), {
      method: 'PUT',
      needAuth: true,
      data: {
        ...form,
        scope: currentScope.value,
      },
    });
    uni.showToast({ title: '已保存', icon: 'success', duration: 1500 });
    await loadConfig();
  } catch (err) {
    console.error('save llm config failed:', err);
    uni.showToast({ title: '保存失败', icon: 'none' });
  } finally {
    saving.value = false;
  }
}

function onProviderChange(e: any) {
  const idx = Number(e?.detail?.value || 0);
  const item = providerOptions[idx];
  if (item) {
    form.provider = item.value;
    providerIndex.value = idx;
  }
}
</script>

<style scoped>
.page-wrapper {
  padding-bottom: 40rpx;
}

.page-content {
  /* theme-container controls width and spacing */
}

.theme-card {
  padding: 24px 20px 28px;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 8px;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.scene-switch {
  display: flex;
  flex-direction: row;
  gap: 12px;
  flex-wrap: wrap;
}

.scene-chip {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 220px;
  padding: 14px 16px;
  border-radius: 12px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
}

.scene-chip.active {
  background: #ecfeff;
  border-color: #14b8a6;
  box-shadow: 0 0 0 1px rgba(20, 184, 166, 0.12);
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 4px;
}

.picker-trigger {
  width: 100%;
}

.model-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 8px;
}

.model-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #f9fafb;
  border-radius: 8px;
  border: 1px solid #e5e7eb;
}

.model-item.active {
  background: #eff6ff;
  border-color: #3b82f6;
}

.model-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.model-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-left: 12px;
}

.loading-hint,
.empty-hint {
  padding: 16px;
  text-align: center;
  color: #9ca3af;
}
</style>
