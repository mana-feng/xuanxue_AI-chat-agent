<template>
	<tm-app>
		<view class="page-wrapper theme-page-bg">
			<yx-nav-header></yx-nav-header>

			<view class="page-content theme-container" :style="pageContentStyle">
				<view class="theme-card theme-card-glass">
					<view class="header">
						<tm-text :font-size="40" :bold="true" color="#2d3748" label="统计代码管理"></tm-text>
						<view class="header-actions">
							<tm-button
								class="btn-gradient"
								size="small"
								color="teal"
								linear="right"
								:round="12"
								:padding="[20, 24]"
								label="返回后台"
								@tap="goBack"
							></tm-button>
						</view>
					</view>

					<tm-sheet :round="16" :shadow="4" :padding="[28, 24]" class="config-card" :follow-dark="true">
						<view class="tip">
							<tm-icon name="information-circle" :font-size="24" color="#667eea" :margin="[0, 10, 0, 0]"></tm-icon>
							<tm-text
								:font-size="24"
								color="#718096"
								label="这里的代码会注入到所有 H5 页面。建议仅允许可信的统计脚本。留空可停用。"
							></tm-text>
						</view>

						<tm-input
							v-model="snippet"
							type="textarea"
							:height="360"
							label="统计代码"
							placeholder="粘贴完整的统计脚本片段"
							:margin="[0, 0, 0, 0]"
							:round="12"
							:border="1"
						/>

						<view class="actions">
							<tm-button
								size="small"
								color="orange"
								:round="10"
								:padding="[16, 20]"
								:margin="[0, 10, 0, 0]"
								:disabled="loading || saving"
								label="恢复默认"
								@tap="restoreDefault"
							></tm-button>
							<tm-button
								class="btn-gradient"
								color="teal"
								linear="right"
								:round="12"
								:padding="[16, 20]"
								:loading="saving"
								:disabled="saving"
								label="保存"
								@tap="handleSave"
							></tm-button>
						</view>
					</tm-sheet>
				</view>
			</view>
		</view>
	</tm-app>
</template>

<script setup lang="ts">
import { computed, onMounted, ref } from 'vue';
import { useUserStore } from '@/store/user';
import { getAdminAnalyticsSnippet, updateAdminAnalyticsSnippet } from '@/services/api/admin';

const userStore = useUserStore();
const snippet = ref('');
const loading = ref(false);
const saving = ref(false);

const DEFAULT_SNIPPET = [
	'<!-- Default Statcounter code for xuan -->',
	'<script type="text/javascript">',
	'var sc_project=13195480;', 
	'var sc_invisible=1;', 
	'var sc_security="98632ca4";', 
	'</scr' + 'ipt>',
	'<script type="text/javascript"',
	'src="https://www.statcounter.com/counter/counter.js"',
	'async></scr' + 'ipt>',
	'<noscript><div class="statcounter"><a title="Web Analytics"',
	'href="https://statcounter.com/" target="_blank"><img',
	'class="statcounter"',
	'src="https://c.statcounter.com/13195480/0/98632ca4/1/"',
	'alt="Web Analytics"',
	'referrerPolicy="no-referrer-when-downgrade"></a></div></noscript>',
	'<!-- End of Statcounter Code -->',
].join('\n');

const navbarHeight = 40;
const pageContentStyle = computed(() => ({
	paddingTop: `${navbarHeight + 20}rpx`,
}));

onMounted(() => {
	userStore.restoreAuth();
	if (!userStore.isAdmin) {
		uni.reLaunch({ url: '/pages/auth/auth' });
		return;
	}
	loadSnippet();
});

async function loadSnippet() {
	loading.value = true;
	try {
		const res = await getAdminAnalyticsSnippet();
		if (res.success && res.data) {
			snippet.value = res.data.snippet || '';
		} else {
			snippet.value = '';
		}
	} catch (err) {
		console.error('获取统计代码失败', err);
		uni.showToast({ title: '加载失败', icon: 'none' });
	} finally {
		loading.value = false;
	}
}

async function handleSave() {
	if (saving.value) return;
	saving.value = true;
	try {
		await updateAdminAnalyticsSnippet(snippet.value || '');
		uni.showToast({ title: '已保存', icon: 'success' });
	} catch (err) {
		console.error('保存统计代码失败', err);
		const msg = (err as any)?.error || '保存失败';
		uni.showToast({ title: msg, icon: 'none' });
	} finally {
		saving.value = false;
	}
}

function restoreDefault() {
	snippet.value = DEFAULT_SNIPPET;
	uni.showToast({ title: '已填充默认代码', icon: 'none' });
}

function goBack() {
	uni.navigateBack({
		fail: () => {
			uni.reLaunch({ url: '/pages/admin/dashboard' });
		},
	});
}
</script>

<style scoped>
.page-wrapper {
	padding-bottom: 40rpx;
}

.page-content {
	/* theme-container + pageContentStyle 控制内边距 */
}

.theme-card {
	padding: 24px 20px 28px;
}

.header {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 20rpx;
}

.header-actions {
	display: flex;
	flex-direction: row;
	align-items: center;
}

.config-card {
	display: flex;
	flex-direction: column;
	gap: 20rpx;
}

.tip {
	display: flex;
	flex-direction: row;
	align-items: center;
	gap: 8rpx;
	padding: 10rpx 12rpx;
	background: #f8fafc;
	border-radius: 10rpx;
	border: 1px solid #e2e8f0;
}

.actions {
	display: flex;
	flex-direction: row;
	justify-content: flex-end;
	margin-top: 8rpx;
}
</style>
