<template>
	<tm-app>
		<view class="app-shell">
			<yx-nav-header></yx-nav-header>
			<view class="app-main">
					<view class="page-shell">
					<view class="page-card history-card theme-card-glass">
						<view class="page-title-wrapper history-header">
							<view class="form-header-icon">
								<tm-icon name="tmicon-md-time" :font-size="40" color="#667eea"></tm-icon>
							</view>
							<view class="form-header-text">
								<h1 class="page-title">历史排盘记录</h1>
								<p class="page-subtitle">查看、筛选并管理已保存的排盘</p>
							</view>
							<view class="header-actions">
								<yx-teal-button
									size="small"
									:round="12"
									:padding="[18, 18]"
									icon="tmicon-md-refresh"
									label="刷新"
									@tap="fetchCharts"
								></yx-teal-button>
								<yx-teal-button
									v-if="isLoggedIn && user_store.isAdmin"
									size="small"
									:round="12"
									:padding="[18, 18]"
									label="管理员后台"
									@tap="goToAdmin"
								></yx-teal-button>
							</view>
						</view>

						<view v-if="!isLoggedIn" class="empty-state">
							<tm-icon name="account-circle" :font-size="80" color="#cbd5e0" :margin="[0, 0, 20, 0]"></tm-icon>
							<tm-text
								:font-size="28"
								color="#718096"
								label="登录后可查看和管理您保存的八字排盘记录"
								:margin="[0, 0, 30, 0]"
							></tm-text>
							<yx-teal-button
								size="small"
								:round="12"
								:padding="[28, 24]"
								:bold="true"
								label="去登录"
								@tap="goLogin"
							></yx-teal-button>
						</view>

						<view v-else>
							<view class="section filters-card">
								<header class="section__header">
									<tm-icon name="tmicon-md-search" :font-size="26" color="#667eea"></tm-icon>
									<h2 class="section__title">筛选与排序</h2>
								</header>
								<view class="section__body filters-grid">
									<view class="filter-block search-block">
										<tm-input
											v-model="searchKeyword"
											prefix="tmicon-md-search"
											placeholder="搜索姓名..."
											@input="onSearchInput"
											clearable
											:round="12"
											:border="1"
										></tm-input>
									</view>
									<view class="filter-block">
										<tm-text :font-size="22" color="#666666" label="性别：" class="mb-6"></tm-text>
										<tm-radio-group v-model="genderFilter">
											<tm-radio label="全部" :value="''"></tm-radio>
											<tm-radio label="男" :value="'0'"></tm-radio>
											<tm-radio label="女" :value="'1'"></tm-radio>
										</tm-radio-group>
									</view>
									<view class="filter-block">
										<tm-text :font-size="22" color="#666666" label="排序：" class="mb-6"></tm-text>
										<tm-segtab
											v-model="sortByIndex"
											:list="[
												{ text: '时间' },
												{ text: '姓名' }
											]"
											:margin="[0, 0]"
											:width="260"
										></tm-segtab>
									</view>
									<view class="filter-actions">
										<yx-teal-button
											size="small"
											:padding="[16, 14]"
											:round="12"
											:label="sortOrder === 'DESC' ? '↓ 降序' : '↑ 升序'"
											@tap="toggleSortOrder"
										></yx-teal-button>
										<yx-teal-button
											v-if="searchKeyword || genderFilter"
											size="small"
											:padding="[16, 14]"
											:round="12"
											label="清除筛选"
											@tap="clearFilters"
										></yx-teal-button>
										<tm-text
											v-if="totalCount > 0"
											class="filters-count"
											:font-size="22"
											color="#999999"
											:label="`共找到${totalCount} 条记录`"
										></tm-text>
									</view>
								</view>
							</view>

							<view v-if="loading" class="py-20 text-center">
								<tm-text label="加载中..." color="#999999"></tm-text>
							</view>
							<view v-else-if="charts.length === 0" class="py-20 text-center">
								<tm-text 
									:label="searchKeyword || genderFilter ? '未找到符合条件的记录' : '暂无保存记录，可在排盘结果页点击「保存到账号」哦'" 
									color="#999999"
								></tm-text>
							</view>
							<view v-else class="records-list">
								<tm-sheet
									v-for="item in charts"
									:key="item.id"
									:round="16"
									:shadow="2"
									:margin="[0, 0]"
									:padding="[24, 20]"
									class="record-card"
								>
									<view class="record-card__header">
										<view class="record-meta">
											<tm-text
												:bold="true"
												:font-size="30"
												color="#2d3748"
												:label="item.title || '未命名'"
												_class="text-overflow-1"
											></tm-text>
											<tm-text
												class="mt-6"
												:font-size="26"
												color="#718096"
												:label="formatBirth(item) || ''"
												_class="text-overflow-1"
											></tm-text>
											<view class="record-meta__row">
												<tm-text
													:font-size="22"
													color="#a0aec0"
													:label="'保存时间：' + (item.createdAtLabel || '')"
												></tm-text>
												<tm-text
													v-if="item.gender !== null && item.gender !== undefined"
													class="ml-12"
													:font-size="22"
													color="#a0aec0"
													:label="getGenderDisplayLabel(item.gender)"
												></tm-text>
											</view>
										</view>
										<view class="record-actions">
											<yx-teal-button
												size="mini"
												:padding="[12, 16]"
												:round="12"
												label="查看"
												@tap="openChart(item)"
											></yx-teal-button>
											<yx-teal-button
												size="mini"
												:padding="[12, 16]"
												:round="12"
												label="删除"
												@tap="removeChart(item)"
											></yx-teal-button>
										</view>
									</view>
								</tm-sheet>
							</view>
							<view v-if="error" class="mt-10">
								<tm-text :label="error" color="red"></tm-text>
							</view>
						</view>
					</view>
					<!-- 公告弹窗 -->
					<tm-overlay v-model:show="showAnnouncementModal" :opacity="0.4" :duration="200">
						<tm-sheet
							:round="18"
							:padding="[24, 24]"
							:margin="[40, 32]"
							:shadow="2"
							:width="600"
							class="announcement-modal"
						>
							<view class="modal-header">
								<tm-text :font-size="30" label="公告" bold></tm-text>
								<yx-teal-button
									size="small"
									:round="12"
									@tap="closeAnnouncements"
								>
									关闭
								</yx-teal-button>
							</view>
							<view v-if="annLoading" class="py-10">
								<tm-text label="加载中..." color="#999"></tm-text>
							</view>
							<view v-else-if="announcementList.length === 0" class="py-10">
								<tm-text label="暂无公告" color="#999"></tm-text>
							</view>
							<view v-else class="announcement-list">
								<tm-sheet
									v-for="item in announcementList"
									:key="item.id"
									:round="12"
									:padding="[18, 16]"
									:margin="[0, 0, 16, 0]"
									:shadow="1"
								>
									<tm-text :font-size="28" bold :label="item.title"></tm-text>
									<tm-text
										v-if="item.expiresAt"
										:font-size="22"
										color="#999"
										:label="`有效期至：${item.expiresAt}`"
										class="mt-4"
									></tm-text>
									<tm-text :font-size="24" color="#444" class="mt-6" :label="item.content"></tm-text>
								</tm-sheet>
							</view>
							<view v-if="annError" class="mt-6">
								<tm-text :label="annError" color="red"></tm-text>
							</view>
						</tm-sheet>
					</tm-overlay>
				</view>
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { ref, computed, onMounted, watch } from 'vue';
import { onLoad } from '@dcloudio/uni-app';
import { useUserStore } from '@/store/user';
import { useBaziStore } from '@/store/bazi';
import { request } from '@/services/api/index';
import { getAccessToken } from '@/utils/tokenStore';
import utils from '@/libs/utils/utils';
import { fetchAnnouncementMeta, fetchAnnouncements, Announcement, AnnouncementMeta } from '@/services/api/announcement';

interface ChartItem {
	id: number;
	title: string;
	gender?: string | null;
	birthDatetime: string;
	createdAt: string;
	createdAtLabel?: string;
	rawPayload?: any;
}

const user_store = useUserStore();
const bazi_store = useBaziStore();

const charts = ref<ChartItem[]>([]);
const loading = ref(false);
const error = ref('');
const totalCount = ref(0);

// 公告
const ANN_CACHE_KEY = 'announcements_cache_v1';
const showAnnouncementModal = ref(false);
const announcementList = ref<Announcement[]>([]);
const annLoading = ref(false);
const annError = ref('');

const searchKeyword = ref('');
const genderFilter = ref('');
const sortByIndex = ref(0); // 0: 时间, 1: 姓名
const sortBy = computed(() => (sortByIndex.value === 0 ? 'created_at' : 'name'));
const sortOrder = ref<'ASC' | 'DESC'>('DESC');

let searchTimer: any = null;

const isLoggedIn = computed(() => user_store.isLoggedIn);

function getGenderDisplayLabel(gender: any): string {
	// 数据库存储：'0'=男，'1'=女
	// 前端显示：0=男，1=女
	if (gender === '0' || gender === 0) {
		return '男';
	} else if (gender === '1' || gender === 1) {
		return '女';
	} else {
		console.warn('[WARN] 未知的 gender 值:', gender);
		return '未知';
	}
}

watch([genderFilter, sortByIndex, sortOrder], () => {
	if (user_store.isLoggedIn) {
		// 延迟一下，确保 token 已刷新
		setTimeout(() => {
			fetchCharts();
		}, 100);
	}
});

onMounted(() => {
	user_store.restoreAuth();
	// 延迟一下，确保 token 已恢复
	setTimeout(() => {
		if (user_store.isLoggedIn) {
			fetchCharts();
		}
	}, 100);
});

onLoad((options: any) => {
	// 从导航参数中判断是否需要自动打开公告
	if (options && options.showAnnouncements === '1') {
		openAnnouncements();
	}
});

function onSearchInput() {
	if (searchTimer) {
		clearTimeout(searchTimer);
	}
	searchTimer = setTimeout(() => {
		fetchCharts();
	}, 500);
}

function toggleSortOrder() {
	sortOrder.value = sortOrder.value === 'DESC' ? 'ASC' : 'DESC';
}

function clearFilters() {
	searchKeyword.value = '';
	genderFilter.value = '';
	sortByIndex.value = 0;
	sortOrder.value = 'DESC';
	fetchCharts();
}

async function fetchCharts() {
	if (!user_store.isLoggedIn) {
		return;
	}
	
	// 确保有有效的 token
	const token = getAccessToken();
	if (!token) {
		return;
	}
	
	loading.value = true;
	error.value = '';

	try {
		const params: Record<string, string> = {};
		if (searchKeyword.value) {
			params.keyword = searchKeyword.value;
		}
		if (genderFilter.value) {
			params.gender = genderFilter.value;
		}
		if (sortBy.value) {
			params.sortBy = sortBy.value as string;
		}
		if (sortOrder.value) {
			params.sortOrder = sortOrder.value;
		}

		const queryString = Object.keys(params)
			.map(key => `${encodeURIComponent(key)}=${encodeURIComponent(params[key])}`)
			.join('&');

		let res;
		try {
			res = await request('/api/charts' + (queryString ? '?' + queryString : ''), {
				method: 'GET',
				needAuth: true
			});
		} catch (requestError: any) {
			// 401错误会被自动处理（刷新token并重试），但如果最终失败会抛出错误
			// 如果是401且刷新失败，前端会自动跳转登录页，这里不需要特殊处理
			if (requestError?.error && requestError.error.includes('登录已失效')) {
				error.value = '登录已失效，请重新登录';
			} else {
				error.value = requestError?.error || '获取失败，请稍后重试';
			}
			charts.value = [];
			totalCount.value = 0;
			return;
		}

		if (res.success !== false) {
			let data = res.data || res;
			if (Array.isArray(data)) {
				charts.value = data.map((it: any) => {
					try {
						return {
							...it,
							createdAtLabel: formatDateTime(it.createdAt || '')
						};
					} catch (e) {
						return {
							...it,
							createdAtLabel: ''
						};
					}
				});
				totalCount.value = charts.value.length;
			} else if (data && data.list) {
				charts.value = data.list.map((it: any) => {
					try {
						return {
							...it,
							createdAtLabel: formatDateTime(it.createdAt || '')
						};
					} catch (e) {
						return {
							...it,
							createdAtLabel: ''
						};
					}
				});
				totalCount.value = data.total || charts.value.length;
			} else {
				charts.value = [];
				totalCount.value = 0;
			}
		} else {
			error.value = res.error || '获取失败，请稍后重试';
			charts.value = [];
			totalCount.value = 0;
		}
	} catch (e: any) {
		console.error('获取历史记录失败:', e);
		error.value = e?.error || '网络错误，请检查后端是否已启动';
		charts.value = [];
		totalCount.value = 0;
	} finally {
		loading.value = false;
	}
}

/**
 * 公告缓存与拉取
 */
function loadAnnouncementCache() {
	try {
		const cacheStr = uni.getStorageSync(ANN_CACHE_KEY);
		if (!cacheStr) return null;
		return JSON.parse(cacheStr);
	} catch (e) {
		return null;
	}
}

function saveAnnouncementCache(payload: { signature: string; list: Announcement[] }) {
	try {
		uni.setStorageSync(ANN_CACHE_KEY, JSON.stringify(payload));
	} catch (e) {
		// ignore
	}
}

function buildSignature(meta: AnnouncementMeta[]) {
	return meta.map((m) => `${m.id}-${m.updatedAt || ''}`).join('|');
}

async function refreshAnnouncements() {
	annError.value = '';
	annLoading.value = true;
	try {
		const metaRes = await fetchAnnouncementMeta();
		const metaList = (metaRes.data?.meta || []) as AnnouncementMeta[];
		const newSig = buildSignature(metaList);
		const cache = loadAnnouncementCache();
		if (cache && cache.signature === newSig) {
			announcementList.value = cache.list || [];
			return;
		}
		const fullRes = await fetchAnnouncements();
		const list = (fullRes.data?.list || []) as Announcement[];
		announcementList.value = list;
		saveAnnouncementCache({ signature: newSig, list });
	} catch (e: any) {
		annError.value = e?.error || e?.message || '获取公告失败';
		const cache = loadAnnouncementCache();
		if (cache?.list) {
			announcementList.value = cache.list;
		}
	} finally {
		annLoading.value = false;
	}
}

async function openAnnouncements() {
	const cache = loadAnnouncementCache();
	if (cache?.list) {
		announcementList.value = cache.list;
	}
	showAnnouncementModal.value = true;
	await refreshAnnouncements();
}

function closeAnnouncements() {
	showAnnouncementModal.value = false;
}

function formatDateTime(iso: string) {
	if (!iso) return '';
	try {
		const d = new Date(iso);
		if (isNaN(d.getTime())) {
			return '';
		}
		return utils.HideSecond(d.getTime()) || '';
	} catch (e) {
		return '';
	}
}

function formatBirth(item: ChartItem) {
	if (!item || !item.birthDatetime) return '';
	try {
		const d = new Date(item.birthDatetime);
		if (isNaN(d.getTime())) {
			return '';
		}
		const result = utils.HideSecond(d.getTime());
		return result ? '出生：' + result : '';
	} catch (e) {
		return '';
	}
}

function openChart(item: ChartItem) {
	try {
		let useRawPayload = false;
		if (item.rawPayload && item.rawPayload.user && item.rawPayload.bazi) {
			const u = item.rawPayload.user;
			const b = item.rawPayload.bazi;

			if (
				u.timestamp &&
				u.gender !== undefined &&
				u.gender !== null &&
				b.solar &&
				b.solar.year &&
				b.sizhu &&
				b.sizhu.year &&
				b.yinli &&
				b.xinzuo &&
				b.table &&
				Array.isArray(b.table) &&
				b.table.length > 0
			) {
				// 统一标准：0=男，1=女（数字）
				// rawPayload 中存储的是数字，直接使用
				let rawPayloadGender: number;
				if (u.gender === null || u.gender === undefined) {
					rawPayloadGender = 0;
				} else {
					rawPayloadGender = typeof u.gender === 'string' ? parseInt(u.gender) : u.gender;
				}

				// 数据库存储为字符串：'0'=男，'1'=女，转换为前端标准：0=男，1=女
				let dbGender: number;
				if (item.gender === null || item.gender === undefined) {
					dbGender = 0;
				} else if (typeof item.gender === 'string') {
					dbGender = item.gender === '0' ? 0 : (item.gender === '1' ? 1 : 0);
				} else {
					dbGender = item.gender === 0 ? 0 : (item.gender === 1 ? 1 : 0);
				}

				let dbTimestamp: number;
				if (typeof item.birthDatetime === 'string') {
					const date = new Date(item.birthDatetime);
					dbTimestamp = date.getTime();
				} else if (typeof item.birthDatetime === 'number') {
					dbTimestamp = item.birthDatetime;
				} else {
					dbTimestamp = 0;
				}

				const timestampDiff = Math.abs((u.timestamp || 0) - dbTimestamp);
				if (rawPayloadGender === dbGender && timestampDiff < 1000) {
					useRawPayload = true;
				}
			}
		}

		if (useRawPayload) {
			const u = item.rawPayload.user;
			user_store.set({
				realname: u.realname || item.title || '佚名',
				gender: u.gender,
				timestamp: u.timestamp,
				recordId: item.id // 设置记录ID
			});
			bazi_store.$patch(item.rawPayload.bazi);

			setTimeout(() => {
				uni.navigateTo({
					url: '/pages/index/detail'
				});
			}, 100);
			return;
		}

		if (!item.birthDatetime) {
			uni.showToast({
				title: '该记录缺少出生时间数据',
				icon: 'none',
				duration: 2000
			});
			return;
		}

		let timestamp: number;
		if (typeof item.birthDatetime === 'string') {
			const date = new Date(item.birthDatetime);
			timestamp = date.getTime();
			if (isNaN(timestamp)) {
				uni.showToast({
					title: '出生时间格式错误，无法解析',
					icon: 'none',
					duration: 2000
				});
				return;
			}
		} else if (typeof item.birthDatetime === 'number') {
			timestamp = item.birthDatetime;
			if (isNaN(timestamp) || timestamp <= 0) {
				uni.showToast({
					title: '出生时间无效',
					icon: 'none',
					duration: 2000
				});
				return;
			}
		} else {
			uni.showToast({
				title: '出生时间格式错误',
				icon: 'none',
				duration: 2000
			});
			return;
		}

		// 数据库存储为字符串：'0'=男，'1'=女，转换为前端标准：0=男，1=女
		let gender: number;
		if (item.gender === null || item.gender === undefined) {
			gender = 0;
		} else if (typeof item.gender === 'string') {
			gender = item.gender === '0' ? 0 : (item.gender === '1' ? 1 : 0);
		} else {
			gender = item.gender === 0 ? 0 : (item.gender === 1 ? 1 : 0);
		}

		uni.showLoading({
			title: '排盘中，请稍后！'
		});

		user_store.set({
			realname: item.title || '佚名',
			gender: gender,
			timestamp: timestamp,
			recordId: item.id // 设置记录ID
		});

		try {
			bazi_store.pull({
				timestamp: timestamp,
				gender: gender
			});
		} catch (pullError: any) {
			uni.hideLoading();
			uni.showToast({
				title: '排盘计算失败：' + (pullError?.message || '未知错误'),
				icon: 'none',
				duration: 2000
			});
			return;
		}

		setTimeout(() => {
			uni.hideLoading();
			if (!bazi_store.solar || !bazi_store.solar.year) {
				uni.showToast({
					title: '排盘数据不完整，请重试',
					icon: 'none',
					duration: 2000
				});
				return;
			}
			uni.navigateTo({
				url: '/pages/index/detail'
			});
		}, 200);
	} catch (e: any) {
		uni.hideLoading();
		uni.showToast({
			title: '打开排盘记录失败：' + (e?.message || '未知错误'),
			icon: 'none',
			duration: 2000
		});
	}
}

function removeChart(item: ChartItem) {
	uni.showModal({
		title: '删除确认',
		content: '确定要删除这条排盘记录吗？',
		success(res) {
			if (res.confirm) {
				doRemove(item);
			}
		}
	});
}

async function doRemove(item: ChartItem) {
	if (!user_store.isLoggedIn) return;

	try {
		const res = await request(`/api/charts/${item.id}`, {
			method: 'DELETE',
			needAuth: true
		});

		if (res.success !== false) {
			charts.value = charts.value.filter(c => c.id !== item.id);
			totalCount.value = charts.value.length;
			uni.showToast({
				title: '已删除',
				icon: 'none',
				duration: 1500
			});
		} else {
			error.value = res.error || '删除失败，请稍后重试';
		}
	} catch (e: any) {
		console.error('删除失败:', e);
		error.value = e?.error || '网络错误，请检查后端是否已启动';
	}
}

function goToHome() {
	uni.reLaunch({
		url: '/pages/index/index'
	});
}

function goToAdmin() {
	uni.navigateTo({
		url: '/pages/auth/auth'
	});
}

function goLogin() {
	uni.navigateTo({
		url: '/pages/auth/auth?mode=login'
	});
}
</script>

