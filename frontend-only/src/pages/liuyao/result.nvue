	display: flex;
	align-items: center;
	gap: 8px;
	margin-top: 4px;
	color: #94a3b8;
}

.page-liuyao-result .table-wrapper {
	width: 100%;
	overflow-x: auto;
	box-sizing: border-box;
	scrollbar-width: thin;
}

.page-liuyao-result .yao-table {
	min-width: 820px;
	width: 100%;
	border: 1px solid #e5e7eb;
	border-radius: 12px;
	overflow: hidden;
	background: #fff;
}

.page-liuyao-result .yao-row {
	display: grid;
	/* 爻位 | 六神 | 原卦六亲(含伏神) | 原卦 | 变卦六亲 | 变卦爻(含世应) */
	grid-template-columns: 70px 80px 140px 180px 180px 140px;
	gap: 0;
	align-items: center;
	border-bottom: 1px solid #f1f5f9;
}

.page-liuyao-result .yao-row:last-child {
	border-bottom: none;
}

.page-liuyao-result .yao-row.head {
	background: #f8fafc;
}

.page-liuyao-result .cell {
	padding: 12px 10px;
	font-size: 18px;
	color: #334155;
