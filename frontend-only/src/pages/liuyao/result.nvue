<template>
	<tm-app>
		<view class="app-shell page-liuyao-result">
			<yx-nav-header></yx-nav-header>
			<view class="app-main">
				<view class="page-shell">
					<view class="page-card detail-card liuyao-card">
						<view class="page-title-wrapper">
							<view class="form-header-text">
								<h1 class="page-title">六爻排盘结果</h1>
								<p class="page-subtitle">查看卦象、六爻明细与卦辞</p>
							</view>
						</view>

						<view v-if="!compiled || !display" class="section empty-state">
							<tm-icon name="tmicon-md-time" :font-size="72" color="#cbd5e0"></tm-icon>
							<tm-text :font-size="26" color="#718096" label="暂无排盘数据，请先返回起卦页面进行排盘。" class="mt-4"></tm-text>
							<tm-button type="primary" :round="12" :padding="[22, 16]" class="mt-4" label="返回起卦" @tap="goStart"></tm-button>
						</view>

						<template v-else>
							<view class="section info-summary">
								<header class="section__header">
									<tm-icon name="tmicon-md-planet" :font-size="26" color="#667eea"></tm-icon>
									<h2 class="section__title">起卦概要</h2>
								</header>
								<view class="section__body info-grid">
									<view v-for="item in summaryTiles" :key="item.label" class="info-tile">
										<tm-text :font-size="24" color="#718096" :label="item.label"></tm-text>
										<tm-text :font-size="30" :bold="true" color="#2d3748" :label="item.value"></tm-text>
									</view>
								</view>
							</view>

							<view class="actions-bar">
								<tm-button
									:round="12"
									:margin="[0, 0]"
									:padding="[24, 20]"
									:font-size="28"
									:bold="true"
									type="primary"
									label="保存到账号"
									icon="tmicon-md-save"
									@tap="handleAction('save')"
								></tm-button>
								<tm-button
									:round="12"
									:margin="[0, 0]"
									:padding="[24, 20]"
									:font-size="28"
									type="primary"
									label="复制排盘"
									icon="tmicon-md-copy"
									@tap="handleAction('copy')"
								></tm-button>
								<tm-button
									:round="12"
									:margin="[0, 0]"
									:padding="[24, 20]"
									:font-size="28"
									type="primary"
									label="AI解读"
									icon="tmicon-md-bulb"
									@tap="handleAction('ai')"
								></tm-button>
							</view>



							<view class="section gua-overview">
								<header class="section__header">
									<tm-icon name="tmicon-md-grid" :font-size="26" color="#667eea"></tm-icon>
									<h2 class="section__title">卦象总览</h2>
								</header>
								<view class="section__body gua-grid">
									<view class="gua-card">
										<view class="gua-card__header">
											<view>
												<p class="card-label">本卦</p>
												<h3 class="gua-name">{{ guaOverview.main.name }}</h3>
												<p class="gua-meta">{{ guaOverview.main.palace }} · {{ guaOverview.main.type }}</p>
											</view>
											<tm-tag type="primary" :round="8" label="主卦"></tm-tag>
										</view>
										<view class="gua-tags">
											<tm-tag :round="8" type="white" :font-size="24" :label="guaOverview.main.wuxing"></tm-tag>
											<tm-tag :round="8" type="white" :font-size="24" :label="guaOverview.main.shiying"></tm-tag>
										</view>
										<view class="gua-note">
											<tm-text :font-size="24" color="#4a5568" :label="guaOverview.main.trend"></tm-text>
										</view>
									</view>

									<view class="gua-card secondary">
										<view class="gua-card__header">
											<view>
												<p class="card-label">变卦</p>
												<h3 class="gua-name">{{ guaOverview.changed.name }}</h3>
												<p class="gua-meta">{{ guaOverview.changed.palace }} · {{ guaOverview.changed.type }}</p>
											</view>
											<tm-tag type="grey" :round="8" label="变卦"></tm-tag>
										</view>
										<view class="gua-tags">
											<tm-tag :round="8" type="white" :font-size="24" :label="guaOverview.changed.wuxing"></tm-tag>
											<tm-tag :round="8" type="white" :font-size="24" :label="guaOverview.changed.shiying"></tm-tag>
										</view>
										<view class="gua-note">
											<tm-text :font-size="24" color="#4a5568" :label="guaOverview.changed.trend"></tm-text>
										</view>
									</view>
								</view>
								<view class="gua-footnote">
									<tm-icon name="tmicon-md-information-circle" :font-size="22" color="#94a3b8"></tm-icon>
									<tm-text :font-size="22" color="#94a3b8" :label="guaOverview.note"></tm-text>
								</view>
							</view>

							<!-- 生成的卦象预览已移除（按要求） -->

							<view class="section yao-section">
								<header class="section__header">
									<tm-icon name="tmicon-md-list" :font-size="26" color="#667eea"></tm-icon>
									<h2 class="section__title">六爻明细</h2>
								</header>
								<view class="section__body">
									<view class="yao-info-bar">
										<text class="info-text">
											<text class="info-label">干支：</text>
											{{ compiled?.lunar?.gz?.year }}年 <text class="text-red">{{ compiled?.lunar?.gz?.month }}月</text> <text class="text-red">{{ compiled?.lunar?.gz?.day }}日</text> {{ compiled?.lunar?.gz?.hour }}时
										</text>
										<text class="info-text">
											<text class="info-label">空亡：</text>
											{{ compiled?.lunar?.xkong || '—' }}
										</text>
									</view>
									<view class="table-wrapper draggable-scroll">
										<view class="yao-table">
											<view class="yao-row head">
												<text class="cell col-yao">爻位</text>
												<text class="cell col-god">六神</text>
												<text class="cell col-qin">原卦六亲</text>
												<text class="cell col-main">原卦</text>
												<text class="cell col-bian-qin">变卦六亲</text>
												<text class="cell col-bian-yao">变卦爻</text>
								</view>
								<view v-for="row in yaoRows" :key="row.id" class="yao-row">
												<text class="cell col-yao">{{ row.order }}</text>
												<text class="cell col-god">{{ formatDisplay(row.liushen) }}</text>
												<view class="cell col-qin-wrapper">
													<text class="col-qin-text">{{ formatDisplay(row.relation) }}</text>
													<text v-if="row.hidden && row.hidden.trim()" class="col-hide-text">{{ row.hidden }}</text>
												</view>
												<text class="cell col-main">
													<view class="main-cell">
														<text class="yao-symbol">{{ row.mainSymbol || '—' }}</text>
														<text v-if="row.mainRole" class="yao-meta">{{ row.mainRole }}</text>
														<text v-if="row.moving" class="yao-meta">动</text>
													</view>
												</text>
												<text class="cell col-bian-qin">{{ formatDisplay(row.bianRelation) }}</text>
											<text class="cell col-bian-yao">
												<view class="bian-cell">
													<text class="yao-symbol">{{ row.bianSymbol || '—' }}</text>
													<text v-if="row.bianRole" class="yao-meta">{{ row.bianRole }}</text>
												</view>
											</text>
										</view>
										</view>
									</view>
								</view>
							</view>

							<view class="section guaci-section">
								<header class="section__header">
									<tm-icon name="tmicon-md-book" :font-size="26" color="#667eea"></tm-icon>
									<h2 class="section__title">卦辞与解读</h2>
								</header>
								<view class="section__body">
									<view class="guaci-card">
										<tm-text :font-size="26" color="#1f2937" :label="guaciText"></tm-text>
									</view>
								</view>
							</view>
						</template>
					</view>
				</view>
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { computed, ref } from 'vue';
import { onShow } from '@dcloudio/uni-app';
import { useLiuyaoStore } from '@/store/liuyao';
import { useUserStore } from '@/store/user';
import { getPersistentItem, setPersistentItem } from '@/utils/persistentStorage';
import { GUAS, GUA5, XING5, TRIGRAM_LABEL } from '@/features/liuyao/najiaConst';
import { getYaoSymbol } from '@/features/liuyao/uiHelpers';
import ParamPreview from '@/components/liuyao/ParamPreview.vue';
import { getGuaName as getGuaciGuaName, getCanonicalNameByName } from '@/features/liuyao/guaci';
import { SYMBOL } from '@/features/liuyao/najiaConst';
import { setShiYao } from '@/features/liuyao/najiaCore';
import { buildLiuyaoExportPayload } from '@/utils/liuyaoExport';

type ActionType = 'save' | 'copy' | 'ai';
const liuyaoStore = useLiuyaoStore();
const user_store = useUserStore();
const saving = ref(false);

const compiled = computed(() => liuyaoStore.compiled);
const display = computed(() => liuyaoStore.display);
const profile = computed(() => liuyaoStore.profile);

const summaryTiles = computed(() => {
	const p = profile.value;
	if (!p) return [];
	return [
		{ label: '起卦主题', value: p.title || '—' },
		{ label: '性别', value: p.gender || '—' },
		{ label: '起卦时间', value: p.timeLabel || '—' }
	];
});

function formatDisplay(value: string) {
	return value && value.trim() ? value : '—';
}

function buildShiyLabel(d: any) {
	const shiIndex = d?.shiyDisplay?.findIndex((x: string) => x.trim() === '世') ?? -1;
	const yingIndex = d?.shiyDisplay?.findIndex((x: string) => x.trim() === '应') ?? -1;
	const map = ['初爻', '二爻', '三爻', '四爻', '五爻', '上爻'];
	const shi = shiIndex >= 0 ? map[shiIndex] : '—';
	const ying = yingIndex >= 0 ? map[yingIndex] : '—';
	return `世：${shi} · 应：${ying}`;
}

const guaOverview = computed(() => {
	const c = compiled.value;
	const d = display.value;
	if (!c || !d) {
		return {
			main: { name: '—', palace: '—', type: '—', wuxing: '—', shiying: '—', trend: '—' },
			changed: { name: '—', palace: '—', type: '—', wuxing: '—', shiying: '—', trend: '—' },
			note: '暂无数据'
		};
	}
	const gongIndex = GUAS.indexOf(c.gong);
	const wuxing = gongIndex >= 0 ? XING5[GUA5[gongIndex]] : '—';
	const bianGongIndex = c.bian ? GUAS.indexOf(c.bian.gong) : -1;
	const bianWuxing = bianGongIndex >= 0 ? XING5[GUA5[bianGongIndex]] : '—';
	const preferName = (mark: string, fallback: string) => {
		const n = getGuaciGuaName(mark);
		return n && n.trim() ? n : (fallback || '—');
	};

	return {
		main: {
			name: preferName(c.mark, c.name),
			palace: c.gong || '—',
			type: d?.main?.type || '—',
			wuxing: `卦宫：${c.gong || '—'} · 五行：${wuxing}`,
			shiying: buildShiyLabel(d),
			trend: '可结合世应、动爻与变卦解读'
		},
		changed: {
			name: (() => {
				if (!c.bian) return '无变卦';
				// try to resolve mark in several formats
				const rawMark = c.bian.mark;
				let resolvedMark = '';
				if (typeof rawMark === 'string' && /^[01]{6}$/.test(rawMark)) {
					resolvedMark = rawMark;
				} else if (Array.isArray(rawMark) && rawMark.length === 6) {
					// try map symbol back to bit (symbol index % 2)
					const bits = rawMark.map((s: string) => {
						const idx = SYMBOL.indexOf(s);
						if (idx === -1) return '';
						return String(idx % 2);
					});
					if (bits.every((b: string) => b === '0' || b === '1')) {
						resolvedMark = bits.join('');
					}
				}
				if (resolvedMark) {
					const byMark = getGuaciGuaName(resolvedMark);
					if (byMark && byMark.trim()) return byMark;
				}
				// fallback: try canonical by name
				const byName = getCanonicalNameByName(c.bian?.name || '');
				if (byName && byName.trim()) return byName;
				// last resort: original name
				return c.bian?.name || '无变卦';
			})(),
			palace: c.bian?.gong || '—',
			type: d?.bian?.type || '—',
			wuxing: c.bian ? `卦宫：${c.bian.gong || '—'} · 五行：${bianWuxing}` : '—',
			shiying: c.bian ? '变卦已生成' : '本卦静卦',
			trend: c.bian ? '动爻生成的变卦，建议结合世应及动爻解读' : '无动爻，静观其变'
		},
		note: c.guaci ? '已加载卦辞，可结合 AI 解读使用' : '暂无卦辞文本'
	};
});

const yaoRows = computed(() => {
	const d = display.value;
	if (!d) return [];
	const orderLabels = ['初爻', '二爻', '三爻', '四爻', '五爻', '上爻'];
	const rows: any[] = [];
	const mainShiy = compiled.value?.shiy || [];
	const bianMark = compiled.value?.bian?.mark || '';
	const bianShiyArr = bianMark ? setShiYao(bianMark) : [-1, -1, -1];
	const bianShiy = { shi: bianShiyArr[0] || -1, ying: bianShiyArr[1] || -1 };

	for (let i = 5; i >= 0; i--) {
		const order = orderLabels[i];
		const mainParam = compiled.value?.params?.[i];
		const mainSymbol = mainParam !== undefined ? getYaoSymbol(mainParam) : '';
		const mainRole = mainShiy[0] - 1 === i ? '世' : mainShiy[1] - 1 === i ? '应' : '';
		const moving = mainParam !== undefined && mainParam > 2;

		let bianRelation = '';
		let bRole = '';
		let bianSymbol = '';

		if (compiled.value?.bian) {
			let markStr = '';
			const rawMark = compiled.value.bian.mark;
			if (typeof rawMark === 'string') {
				markStr = rawMark;
			} else if (Array.isArray(rawMark) && rawMark.length === 6) {
				markStr = rawMark.join('');
			}
			
			// Calculate bianSymbol
			if (markStr && markStr.length > i) {
				const bit = markStr[i];
				bianSymbol = getYaoSymbol(bit);
			}

			const relMain = (compiled.value.bian.qin6?.[i] || '').trim();
			const relExtra = (compiled.value.bian.qinx?.[i] || '').trim();
			if (relMain && relExtra) {
				if (relMain.includes(relExtra) || relExtra.includes(relMain)) {
					bianRelation = relMain || relExtra;
				} else {
					bianRelation = `${relMain} ${relExtra}`.trim();
				}
			} else {
				bianRelation = relMain || relExtra;
			}

			if (bianShiy.shi - 1 === i) bRole = '世';
			else if (bianShiy.ying - 1 === i) bRole = '应';
		}

		rows.push({
			id: `${6 - i}`,
			order,
			liushen: formatDisplay(d?.god6?.[i] || ''),
			relation: formatDisplay(`${d?.qin6?.[i] || ''}${d?.qinx?.[i] || ''}`),
			hidden: formatDisplay(d?.hide?.qin6?.[i] || ''),
			moving,
			mainSymbol,
			mainRole,
			bianRelation: formatDisplay(bianRelation),
			bianSymbol,
			bianRole: bRole
		});
	}
	return rows;
});

const guaciText = computed(() => {
	const entry = compiled.value?.guaciEntry;
	if (entry) {
		// prefer enriched text, fall back to guaci string
		return entry.text || entry.guaci || compiled.value?.guaci || '暂无卦辞，可后续接入 AI 解读。';
	}
	return compiled.value?.guaci || '暂无卦辞，可后续接入 AI 解读。';
});

const bianParams = computed(() => {
	const mark = compiled.value?.bian?.mark || '';
	if (!mark) return [];
	return mark.split('').map((ch: string) => parseInt(ch, 10) || 0);
});

function copyLiuyaoInfo() {
	if (!compiled.value) {
		uni.showToast({ title: '暂无数据', icon: 'none' });
		return;
	}
	const text = buildLiuyaoExportPayload(liuyaoStore);
	if (!text) {
		uni.showToast({ title: '复制失败', icon: 'none' });
		return;
	}
	uni.setClipboardData({
		data: text,
		success: () => uni.showToast({ title: '排盘信息已复制', icon: 'none' })
	});
}

async function saveLiuyao() {
	if (!compiled.value || !profile.value) {
		uni.showToast({ title: '无数据可保存', icon: 'none' });
		return;
	}

	if (saving.value) return;
	saving.value = true;

	try {
		const p = profile.value;
		const c = compiled.value;
		
		let rawPayload;
		
		try {
			const recordTime = liuyaoStore.createdAt || Date.now();
			
			let params = c.params;
			if ((!params || !Array.isArray(params)) && c.mark) {
				const markArr = c.mark.split('');
				const dongArr = c.dong || [];
				
				params = markArr.map((bit, index) => {
					const isYang = bit === '1';
					const isDong = dongArr.includes(index);
					if (isDong) {
						return isYang ? 3 : 4;
					} else {
						return isYang ? 1 : 0;
					}
				});
			}

			if (!params || !Array.isArray(params) || params.length !== 6) {
				throw new Error('无法获取有效的卦爻参数');
			}

			rawPayload = {
				lite: true,
				params: params,
				options: {
					gender: c.gender || p.gender,
					title: c.title || p.title,
					date: new Date(recordTime).toISOString(),
					dayGz: c.dayGz
				},
				profile: p,
				ts: recordTime
			};
		} catch (e) {
			console.error('构造精简数据失败', e);
			uni.showToast({ title: '数据处理失败，无法保存', icon: 'none' });
			saving.value = false;
			return;
		}

		const entry = {
			id: Date.now(),
			title: p.title || '六爻排盘',
			type: 'liuyao',
			gender: p.gender === '男' ? '0' : (p.gender === '女' ? '1' : null),
			birthDatetime: new Date(liuyaoStore.createdAt || Date.now()).toISOString(),
			createdAt: new Date().toISOString(),
			rawPayload
		};

		const LOCAL_LIUYAO_RECORDS_KEY = 'local_liuyao_records';
		const records = getPersistentItem<any[]>(LOCAL_LIUYAO_RECORDS_KEY) || [];
		records.unshift(entry);
		setPersistentItem(LOCAL_LIUYAO_RECORDS_KEY, records.slice(0, 200), 365 * 24 * 60 * 60 * 1000);

		uni.showToast({ title: '保存成功', icon: 'success' });
	} catch (e: any) {
		console.error('保存失败:', e);
		uni.showToast({ title: '保存失败: ' + (e.message || '未知错误'), icon: 'none' });
	} finally {
		saving.value = false;
	}
}

function handleAction(action: ActionType) {
	if (action === 'copy') {
		copyLiuyaoInfo();
		return;
	}
	if (action === 'save') {
		saveLiuyao();
		return;
	}
	if (action === 'ai') {
		if (!liuyaoStore.compiled) {
			uni.showToast({ title: '暂无排盘数据', icon: 'none' });
			return;
		}
		uni.navigateTo({
			url: '/pages/chat/index?from=liuyao'
		});
		return;
	}
	const messageMap: Partial<Record<ActionType, string>> = {
	};
	uni.showToast({
		title: messageMap[action] || '功能待接入',
		icon: 'none',
		duration: 1800
	});
}

function goStart() {
	uni.redirectTo({ url: '/pages/liuyao/index' });
}

onShow(() => {
	if (!liuyaoStore.compiled || !liuyaoStore.display || !liuyaoStore.profile) {
		liuyaoStore.restoreLastResult();
	}
});
</script>

<style scoped>
.page-liuyao-result .app-main {
	width: 100%;
	display: flex;
	justify-content: center;
	align-items: flex-start;
	padding: var(--page-pad-y) var(--page-pad-x);
	padding-bottom: calc(var(--page-pad-y) + var(--safe-bottom) + var(--bottom-nav-height));
	box-sizing: border-box;
	background: radial-gradient(circle at 20% 20%, rgba(102, 126, 234, 0.08), transparent 40%),
		radial-gradient(circle at 80% 10%, rgba(118, 75, 162, 0.08), transparent 38%),
		#f6f8fc;
}

.page-liuyao-result .page-shell {
	width: 100%;
	max-width: var(--page-max);
	display: flex;
	justify-content: center;
	box-sizing: border-box;
	margin: 0 auto;
}

.page-liuyao-result .page-card {
	width: 100%;
	max-width: var(--page-max);
	margin-inline: auto;
	background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
	border: 1px solid #e5e9f2;
	border-radius: 16px;
	box-shadow: 0 12px 32px rgba(31, 41, 55, 0.1);
	padding: 18px 16px;
	position: relative;
	overflow: hidden;
}

.page-liuyao-result .page-card::before {
	content: '';
	position: absolute;
	inset: 0;
	background: radial-gradient(circle at 12% 12%, rgba(102, 126, 234, 0.08), transparent 35%),
		radial-gradient(circle at 88% 6%, rgba(118, 75, 162, 0.07), transparent 32%);
	pointer-events: none;
}

.page-liuyao-result .detail-card {
	gap: 14px;
	display: flex;
	flex-direction: column;
}

/* 
	底部操作栏样式
	移动到顶部标题栏右侧
*/


.page-liuyao-result .section {
	background: #ffffff;
	border-radius: 14px;
	border: 1px solid #e2e8f0;
	padding: 14px 12px 12px;
	margin-bottom: 14px;
	box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
	position: relative;
	z-index: 1;
}

.page-liuyao-result .section__header {
	display: flex;
	align-items: center;
	gap: 12px;
	margin-bottom: 12px;
	border-bottom: 1px dashed #e5e7eb;
	padding-bottom: 12px;
}

.page-liuyao-result .section__title {
	font-size: 22px;
	color: #2d3748;
}

.page-liuyao-result .section__body {
	display: flex;
	flex-direction: column;
	gap: 14px;
}

.page-liuyao-result .info-summary .info-grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 12px;
}

@media (min-width: 720px) {
	.page-liuyao-result .info-summary .info-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}
}

.layout-medium .page-liuyao-result .info-summary .info-grid,
.layout-wide .page-liuyao-result .info-summary .info-grid {
	grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.page-liuyao-result .info-tile {
	padding: 14px 16px;
	border: 1px solid #e5e7eb;
	border-radius: 12px;
	background: #f8fafc;
}

.page-liuyao-result .actions-bar {
	display: flex;
	flex-direction: row;
	gap: 12px;
	align-items: center;
	justify-content: flex-start;
	flex-wrap: wrap;
	margin-bottom: 12px;
	padding: 0 4px;
}

.page-liuyao-result .gua-grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 12px;
}

@media (min-width: 720px) {
	.page-liuyao-result .gua-grid {
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	}
}

.layout-medium .page-liuyao-result .gua-grid,
.layout-wide .page-liuyao-result .gua-grid {
	grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

.page-liuyao-result .gua-card {
	padding: 12px;
	border: 1px solid #e5e7eb;
	border-radius: 12px;
	background: #f9fafb;
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.page-liuyao-result .gua-card.secondary {
	background: #fdfcfb;
}

.page-liuyao-result .gua-card__header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 8px;
}

.page-liuyao-result .gua-name {
	margin: 0;
	font-size: 22px;
	color: #111827;
}

.page-liuyao-result .card-label {
	margin: 0;
	font-size: 13px;
	color: #9ca3af;
}

.page-liuyao-result .gua-meta {
	margin: 2px 0 0;
	font-size: 14px;
	color: #6b7280;
}

.page-liuyao-result .gua-tags {
	display: flex;
	flex-wrap: wrap;
	gap: 6px;
}

.page-liuyao-result .gua-note {
	padding: 8px 10px;
