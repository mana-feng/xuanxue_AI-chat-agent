:global(.layout-wide) .filters-grid {
	flex-direction: row;
	flex-wrap: wrap;
	gap: 0;
}

:global(.layout-medium) .filters-grid > view,
:global(.layout-wide) .filters-grid > view {
	width: calc(50% - 6px);
	margin-right: 12px;
	margin-bottom: 12px;
}

:global(.layout-medium) .filters-grid > view:nth-child(2n),
:global(.layout-wide) .filters-grid > view:nth-child(2n) {
	margin-right: 0;
}

