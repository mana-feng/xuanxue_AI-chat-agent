# Backend server
PORT=3001
JWT_SECRET=please_change_me
# 允许的前端来源（逗号分隔，留空为不限制，生产建议写死域名）
CORS_ORIGINS=https://your-frontend.example.com,https://h5.example.com

# Frontend build-time API base
# 为 uni-app 前端注入后端域名，示例：VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=http://localhost:3001

# Database configuration
# MySQL 配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=bazi_app

# Email SMTP 不再从环境变量读取，请在后台管理中配置


