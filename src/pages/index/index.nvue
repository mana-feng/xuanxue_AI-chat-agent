	background: linear-gradient(135deg, #4c51bf 0%, #2a3fb8 100%) !important;
	color: #ffffff !important;
	box-shadow: 0 14rpx 28rpx rgba(44, 64, 180, 0.28) !important;
}

.submit-button-wrapper.disabled .submit-button :deep(.tm-button) {
	background: #d2d6dc !important;
	color: #a0aec0 !important;
	box-shadow: none !important;
}

.submit-button:active {
	transform: scale(0.98);
}

.submit-button-glow {
	position: absolute;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	width: 100%;
	height: 100%;
	background: linear-gradient(135deg, rgba(102, 126, 234, 0.4) 0%, rgba(118, 75, 162, 0.4) 100%);
	border-radius: 16rpx;
	filter: blur(20rpx);
	z-index: 1;
	opacity: 0.6;
	animation: pulse-glow 2s ease-in-out infinite;
}

.submit-button-wrapper.disabled .submit-button-glow {
	opacity: 0.15;
	filter: blur(10rpx);
}

@keyframes pulse-glow {
	0%, 100% {
		opacity: 0.4;
		transform: translate(-50%, -50%) scale(1);
	}
	50% {
		opacity: 0.8;
		transform: translate(-50%, -50%) scale(1.05);
	}
}

.error-container {
	padding: 16rpx 20rpx;
	background: rgba(245, 101, 101, 0.1);
