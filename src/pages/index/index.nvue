<template>
	<tm-app>
		<view class="page-wrapper">
			<yx-nav-header @open-auth="openAuth"></yx-nav-header>
			
			<view class="page-content">
				<!-- 欢迎 & 说明 -->
				<tm-sheet
					:round="16"
					:shadow="3"
					:margin="[0, 20]"
					:padding="[32, 28]"
					class="welcome-card"
				>
					<view class="welcome-content">
						<tm-text
							:font-size="38"
							label="欢迎使用八字排盘"
							:bold="true"
							color="#2d3748"
						></tm-text>
						<tm-text
							class="mt-8"
							:font-size="26"
							color="#718096"
							:label="isLoggedIn ? '已登录账号，可随时保存与查看排盘记录' : '登录后可保存排盘到账号，在多设备间同步与管理历史记录'"
						></tm-text>
					</view>
				</tm-sheet>

				<!-- 登录 / 注册区域（卡片） -->
				<tm-sheet
					:round="16"
					:shadow="4"
					:margin="[0, 20]"
					:padding="[32, 28]"
					class="auth-card"
				>
					<!-- 已登录状态 -->
					<view v-if="isLoggedIn" class="auth-logged-in">
						<view class="auth-header">
							<view class="auth-avatar">
								<tm-icon name="account-circle" :font-size="60" color="#667eea"></tm-icon>
							</view>
							<view class="auth-info">
								<tm-text
									:font-size="32"
									:bold="true"
									color="#2d3748"
									:label="'您好，' + (user_store.email || '已登录用户')"
								></tm-text>
								<tm-text
									class="mt-6"
									:font-size="24"
									color="#718096"
									label="当前登录账号将自动保存您的排盘记录"
								></tm-text>
							</view>
						</view>
						<view class="auth-actions">
							<tm-button
								size="small"
								type="primary"
								:margin="[0, 8, 0, 0]"
								:padding="[24, 32]"
								:round="12"
								label="历史查询"
								@tap="goToHistory"
							></tm-button>
							<tm-button
								v-if="user_store.isAdmin"
								size="small"
								type="warning"
								:margin="[0, 8, 0, 0]"
								:padding="[24, 32]"
								:round="12"
								label="管理员后台"
								@tap="goToAdmin"
							></tm-button>
							<tm-button
								size="small"
								type="danger"
								:margin="[0, 0]"
								:padding="[24, 32]"
								:round="12"
								label="退出登录"
								@tap="user_store.logout()"
							></tm-button>
						</view>
					</view>

					<!-- 未登录状态 -->
					<view v-else class="auth-not-logged-in">
						<view class="auth-header">
							<tm-text
								:font-size="32"
								:bold="true"
								color="#2d3748"
								label="账号登录 / 注册"
							></tm-text>
							<tm-text
								class="mt-6"
								:font-size="24"
								color="#718096"
								label="只需邮箱和密码，即可轻松管理您的八字排盘历史"
							></tm-text>
						</view>
						<tm-button
							type="primary"
							block
							:round="12"
							:height="88"
							:font-size="30"
							:bold="true"
							label="登录 / 注册"
							@tap="showAuthForm = true"
						></tm-button>
					</view>

					<!-- 登录/注册表单（未登录时显示） -->
					<view
						v-if="!isLoggedIn && showAuthForm"
						class="auth-form-container"
					>
						<!-- 登录 / 注册切换 -->
						<view class="auth-tabs">
							<view 
								class="auth-tab"
								:class="{ active: authMode === 'login' }"
								@tap="authMode = 'login'; authError = ''"
							>
								<tm-text
									:font-size="30"
									:bold="authMode === 'login'"
									:color="authMode === 'login' ? '#667eea' : '#718096'"
									label="登录"
								></tm-text>
							</view>
							<view 
								class="auth-tab"
								:class="{ active: authMode === 'register' }"
								@tap="authMode = 'register'; authError = ''"
							>
								<tm-text
									:font-size="30"
									:bold="authMode === 'register'"
									:color="authMode === 'register' ? '#667eea' : '#718096'"
									label="注册"
								></tm-text>
							</view>
						</view>

						<!-- 表单输入 -->
						<view class="auth-form-fields">
							<tm-input
								v-model="authEmail"
								:margin="[0, 0, 20, 0]"
								prefix="tmicon-md-mail"
								type="text"
								:round="12"
								:border="1"
								placeholder="请输入常用邮箱，用于登录与找回账号"
							></tm-input>
							<tm-input
								v-model="authPassword"
								:margin="[0, 0, 20, 0]"
								prefix="tmicon-md-lock"
								type="password"
								:round="12"
								:border="1"
								placeholder="设置登录密码（建议不少于 6 位，包含字母和数字）"
							></tm-input>
						</view>

						<view class="auth-form-hint">
							<tm-text
								:font-size="22"
								color="#a0aec0"
								:label="authMode === 'login' ? '为保障安全，请在私人环境下登录账号' : '注册即表示同意相关服务条款'"
							></tm-text>
							<tm-text
								v-if="authMode === 'login'"
								:font-size="22"
								color="#667eea"
								label="忘记密码？"
							></tm-text>
						</view>

						<view v-if="authError" class="auth-error">
							<tm-icon name="close-circle" :font-size="24" color="#f56565" :margin="[0, 8, 0, 0]"></tm-icon>
							<tm-text
								:label="authError"
								color="#f56565"
								:font-size="24"
							></tm-text>
						</view>

						<view class="auth-form-actions">
							<tm-button
								block
								:loading="authLoading"
								:disabled="authLoading"
								:margin="[0, 0]"
								:type="authMode === 'login' ? 'primary' : 'success'"
								:round="12"
								:height="88"
								:font-size="30"
								:bold="true"
								:label="authMode === 'login' ? '登录' : '注册并登录'"
								@tap="submitAuth"
							></tm-button>
							<tm-button
								class="mt-16"
								type="grey"
								block
								:margin="[0, 0]"
								:round="12"
								:height="88"
								:font-size="30"
								label="取消"
								@tap="showAuthForm = false"
							></tm-button>
						</view>
					</view>
				</tm-sheet>

				<!-- 排盘表单 -->
				<tm-sheet :round="16" :shadow="4" :margin="[0, 20]" :padding="[32, 28]" class="form-card">
					<view class="form-header">
						<view class="form-header-icon">
							<tm-icon name="calendar-alt" :font-size="44" color="#667eea"></tm-icon>
						</view>
						<view class="form-header-text">
							<tm-text
								:font-size="38"
								:bold="true"
								color="#2d3748"
								label="排盘信息"
							></tm-text>
							<tm-text
								:font-size="24"
								color="#a0aec0"
								label="请填写以下信息进行八字排盘"
								:margin="[8, 0, 0, 0]"
							></tm-text>
						</view>
					</view>
					
					<!-- 基本信息区块 -->
					<view class="form-section form-section-card">
						<view class="section-title">
							<tm-icon name="tmicon-md-person" :font-size="28" color="#667eea" :margin="[0, 8, 0, 0]"></tm-icon>
							<tm-text
								:font-size="28"
								color="#2d3748"
								:bold="true"
								label="基本信息"
							></tm-text>
						</view>
						
						<view class="section-content">
							<tm-input
								v-model="realname"
								:margin="[0, 0, 24, 0]"
								placeholder="请输入姓名（可选）"
								prefix="tmicon-md-person"
								:round="12"
								:border="1"
								:padding="[24, 20]"
							></tm-input>

							<view class="form-group-single">
								<view class="form-label">
									<tm-icon name="tmicon-md-people" :font-size="24" color="#718096" :margin="[0, 6, 0, 0]"></tm-icon>
									<tm-text
										:font-size="26"
										color="#718096"
										label="性别"
									></tm-text>
								</view>
								<view class="form-control">
									<tm-radio-group v-model="gender">
										<tm-radio label="男" :value="0" :margin="[0, 16, 0, 0]"></tm-radio>
										<tm-radio label="女" :value="1"></tm-radio>
									</tm-radio-group>
								</view>
							</view>
						</view>
					</view>

					<!-- 出生时间区块 -->
					<view class="form-section form-section-card">
						<view class="section-title">
							<tm-icon name="tmicon-time" :font-size="28" color="#667eea" :margin="[0, 8, 0, 0]"></tm-icon>
							<tm-text
								:font-size="28"
								color="#2d3748"
								:bold="true"
								label="出生时间"
							></tm-text>
						</view>
						
						<view class="section-content">
							<!-- 日历类型选择 -->
							<view class="form-group-single calendar-type-selector">
								<view class="form-label">
									<tm-icon name="tmicon-calendar-alt" :font-size="24" color="#718096" :margin="[0, 6, 0, 0]"></tm-icon>
									<tm-text
										:font-size="26"
										color="#718096"
										label="日历类型"
									></tm-text>
								</view>
								<view class="form-control segtab-wrapper">
									<tm-segtab
										v-model="model"
										:default-value="0"
										:list="[{ text: '阳历' }, { text: '阴历' }]"
										:margin="[0, 0]"
										:width="300"
									></tm-segtab>
								</view>
							</view>
							
							<!-- 日期时间选择 -->
							<tm-input
								:placeholder="model === 0 ? '请选择阳历出生日期和时间（精确到分钟）' : '请选择阴历出生日期和时间（精确到分钟）'"
								prefix="tmicon-calendar-alt"
								suffix="tmicon-angle-right"
								v-model="datetime_label"
								:margin="[0, 0, 20, 0]"
								:round="12"
								:border="1"
								:padding="[24, 20]"
								@tap="SelectTime"
							></tm-input>

							<!-- 显示信息卡片组 -->
							<view v-if="lunar_label || bazi_label" class="info-cards">
								<view v-if="lunar_label" class="info-card">
									<view class="info-card-header">
										<tm-icon name="tmicon-integral" :font-size="32" color="#48bb78"></tm-icon>
										<tm-text
											:font-size="24"
											color="#718096"
											label="对应阴历"
											:margin="[0, 0, 0, 12]"
										></tm-text>
									</view>
									<tm-text
										:font-size="28"
										color="#2d3748"
										:bold="true"
										:label="lunar_label"
									></tm-text>
								</view>
								
								<view v-if="bazi_label" class="info-card">
									<view class="info-card-header">
										<tm-icon name="tmicon-calendar" :font-size="32" color="#667eea"></tm-icon>
										<tm-text
											:font-size="24"
											color="#718096"
											label="四柱八字"
											:margin="[0, 0, 0, 12]"
										></tm-text>
									</view>
									<view class="bazi-display">
										<tm-tag
											v-for="(item, index) in bazi_label.split(' ')"
											:key="index"
											:label="item"
											type="primary"
											:round="8"
											:margin="[0, 8, 0, 0]"
											:font-size="26"
											:bold="true"
										></tm-tag>
									</view>
								</view>
							</view>
						</view>
					</view>

					<!-- 提交按钮 -->
					<view class="form-submit">
						<view class="submit-button-wrapper">
							<tm-button 
								block 
								label="开始排盘" 
								type="primary"
								:round="16"
								:height="108"
								:font-size="36"
								:bold="true"
								:linear="true"
								:linearDeep="'accent'"
								:shadow="8"
								icon="tmicon-calendar-alt"
								@tap="Sumbit"
								class="submit-button"
							></tm-button>
							<view class="submit-button-glow"></view>
						</view>
					</view>
				</tm-sheet>

				<tm-time-picker
					v-model:show="solar_select_show"
					:round="6"
					:default-value="solar_default_value"
					:start="time_pick.start"
					:end="time_pick.end"
					:format="time_pick.format"
					:showDetail="time_pick.detail"
					:showSuffix="time_suffix.solar"
					@confirm="SolarConfirm"
				></tm-time-picker>
				<tm-time-picker
					v-model:show="lunar_select_show"
					:round="6"
					:default-value="lunar_default_value"
					:start="time_pick.start"
					:end="time_pick.end"
					:format="time_pick.format"
					:showDetail="time_pick.detail"
					:showSuffix="time_suffix.lunar"
					@confirm="LunarConfirm"
				></tm-time-picker>
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { ref, computed, watch } from 'vue';
import { onLoad } from '@dcloudio/uni-app';
import { Solar, Lunar } from 'lunar-javascript';
import {useUserStore} from '@/store/user.ts'
import {useBaziStore} from '@/store/bazi.ts'
import utils from '@/shared/utils/utils.ts';
import { API_BASE_URL } from '@/config/config.ts';

let realname = ref('');
let gender = ref(0);
let model = ref(0);
let timestamp = ref(null);
let datetime_label = ref('');
let lunar_label = ref(null);
let bazi_label = ref('');

const user_store = useUserStore();
const bazi_store = useBaziStore();

// 登录 / 注册相关
const authMode = ref<'login' | 'register'>('login');
const showAuthForm = ref(false);
const authEmail = ref('');
const authPassword = ref('');
const authLoading = ref(false);
const authError = ref('');
const isLoggedIn = computed(() => user_store.isLoggedIn);

let solar_select_show = ref(false);
let lunar_select_show = ref(false);

let solar_default_value = ref("")
let lunar_default_value = ref("");

const time_pick = {
	start: '1900/01/01 00:00',
	end: '2099/12/30 00:00',
	// 使用24小时制与分钟，避免月份/分钟混淆
	format: 'YYYY/MM/DD HH:mm',
	detail: {
		year: true,
		month: true,
		day: true,
		hour: true,
		minute: true,
		second: false
	}
};

const time_suffix = {
	solar: {
		year: '年',
		month: '月',
		day: '日',
		hour: '时',
		minute: '分',
		second: '秒'
	},
	lunar: {
		year: '年',
		month: '月',
		day: '日',
		hour: '时辰',
		minute: '分',
		second: '秒'
	}
};

watch(model, () => PullDatatimeLabel());
watch(timestamp, () => PullDatatimeLabel());
onLoad(() =>{
	// 恢复登录状态
	user_store.restoreAuth();

	const cache = uni.getStorageSync('info');
	if (cache) {
		let data = null
		try {
			data = JSON.parse(cache);
			realname.value = data.realname
			gender.value = data.gender== 0 ? 1 : 0
			timestamp.value = data.timestamp
			PullDatatimeLabel()
		} catch (e) {
			uni.removeStorageSync('info');
		}
	} else {
		// 如果没有缓存，默认设置为当前日期时间
		timestamp.value = new Date().getTime();
		PullDatatimeLabel();
	}
})

function openAuth(mode: 'login' | 'register') {
	uni.navigateTo({
		url: `/pages/auth/auth?mode=${mode}`
	});
}

function goToHistory() {
	uni.navigateTo({
		url: '/pages/history/list'
	});
}

function goToAdmin() {
	uni.navigateTo({
		url: '/pages/auth/auth'
	});
}

function submitAuth() {
	if (!authEmail.value || !authPassword.value) {
		authError.value = '请输入邮箱和密码';
		return;
	}
	authLoading.value = true;
	authError.value = '';

	const url = API_BASE_URL + (authMode.value === 'login' ? '/api/login' : '/api/register');

	uni.request({
		url,
		method: 'POST',
		data: {
			email: authEmail.value,
			password: authPassword.value
		},
		success(res: any) {
			if (res.statusCode >= 200 && res.statusCode < 300 && res.data?.token) {
				user_store.setAuth({
					username: res.data.user?.username || null,
					email: res.data.user?.email || authEmail.value,
					token: res.data.token,
					role: res.data.user?.role || 'user'
				});
				uni.showToast({
					title: authMode.value === 'login' ? '登录成功' : '注册并登录成功',
					icon: 'success',
					duration: 1500
				});
				showAuthForm.value = false;
				authPassword.value = '';
				// 登录成功后，延迟刷新页面以更新登录状态显示
				setTimeout(() => {
					// 页面会自动刷新显示登录状态，无需跳转
				}, 500);
			} else {
				authError.value = res.data?.error || '请求失败，请稍后重试';
			}
		},
		fail() {
			authError.value = '网络错误，请检查后端是否已启动';
		},
		complete() {
			authLoading.value = false;
		}
	});
}

function SelectTime  ()  {
	uni.hideKeyboard();
	setTimeout(()=>{
		if (model.value === 0) {
			solar_select_show.value = true;
		} else {
			lunar_select_show.value = true;
		}
	},400)
};

const SolarConfirm = time => timestamp.value = new Date(time).getTime();
const LunarConfirm = time => timestamp.value = new Date(time).getTime();

function PullDatatimeLabel  ()  {
	const time = timestamp.value;
	if (time === null) return;
	const index = model.value;
	const solar = Solar.fromDate(new Date(time));
	const lunar = solar.getLunar();
	
	// 计算四柱
	const bazi = lunar.getEightChar();
	const baziList = [bazi.getYear(), bazi.getMonth(), bazi.getDay(), bazi.getTime()];
	bazi_label.value = baziList.join(' ');
	
	if (index === 0) {
		// 阳历模式：显示阳历日期时间
		let date = utils.HideSecond(time);
		datetime_label.value = date;
		solar_default_value.value = date;
		lunar_default_value.value = date;
		// 显示对应的阴历信息
		lunar_label.value = `${lunar.toString()} ${lunar.getTimeZhi()}时`;
	} else {
		// 阴历模式：显示阴历日期时间
		const lunarStr = `${lunar.toString()} ${lunar.getTimeZhi()}时`;
		datetime_label.value = lunarStr;
		// 设置默认值为对应的阳历时间（用于时间选择器）
		let date = utils.HideSecond(time);
		solar_default_value.value = date;
		lunar_default_value.value = date;
		// 显示对应的阳历信息
		lunar_label.value = date;
	}
};

function Sumbit ()  {
	const datetime = timestamp.value;
	if(datetime === null){
		uni.showToast({
			title: "请先选择出生日期和时间",
			icon: "none",
			duration: 2000
		});
		SelectTime();
		return;
	}

	const params = {
		realname: realname.value??"不知名网友",
		timestamp: datetime,
		gender: gender.value == 0 ? 1 : 0
	}
	uni.showLoading({
		title:"排盘中，请稍后！"
	})
	uni.setStorageSync('info', JSON.stringify(params));
	user_store.set(params)
	bazi_store.pull(params);
	setTimeout(()=>{
		uni.hideLoading()
		uni.navigateTo({
			url:"/pages/index/detail"
		})
	},0)
};
</script>

<style scoped>
.page-wrapper {
	min-height: 100vh;
	width: 100%;
	background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
	padding-bottom: 40rpx;
	box-sizing: border-box;
}

.page-content {
	width: 100%;
	max-width: 100%;
	padding: 30rpx;
	box-sizing: border-box;
	margin: 0 auto;
}

/* 响应式容器 */
@media screen and (min-width: 750px) {
	.page-content {
		max-width: 750rpx;
		padding: 30rpx 40rpx;
	}
}

.welcome-card {
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	width: 100%;
	box-sizing: border-box;
}

.welcome-content {
	width: 100%;
	display: flex;
	flex-direction: column;
}

.welcome-card :deep(.tm-text) {
