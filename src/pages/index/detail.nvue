							<tm-text :font-size="30" :bold="true" :follow-dark="true" :label="bazi_store.start_yun.solar"></tm-text>
						</view>
					</view>
				</tm-sheet>

				<!-- 增强分析信息 -->
				<tm-sheet v-if="bazi_store.enhanced" :round="16" :shadow="4" :margin="[20, 0]" :padding="[32, 28]" class="analysis-card" :follow-dark="true">
					<view class="px-0 py-0 mb-24">
						<tm-text :label="'增强分析'" :font-size="38" :bold="true" color="#667eea"></tm-text>
					</view>
					
					<!-- 神煞 -->
					<view v-if="bazi_store.enhanced.shensha && bazi_store.enhanced.shensha.all && bazi_store.enhanced.shensha.all.length > 0" class="px-0 pb-16 analysis-section">
						<tm-text :font-size="30" color="#718096" label="神煞" :margin="[0, 0, 8, 0]"></tm-text>
						<tm-text :label="bazi_store.enhanced.shensha.all.join('、')" :font-size="32" color="#2d3748" :bold="true"></tm-text>
					</view>
					
					<!-- 格局 -->
					<view v-if="bazi_store.enhanced.geju && bazi_store.enhanced.geju.type" class="px-0 pb-16 analysis-section">
						<tm-text :font-size="30" color="#718096" label="格局" :margin="[0, 0, 8, 0]"></tm-text>
						<tm-text :label="bazi_store.enhanced.geju.type" :font-size="32" color="#2d3748" :bold="true"></tm-text>
						<view v-if="bazi_store.enhanced.geju.description" class="mt-8">
							<tm-text :label="bazi_store.enhanced.geju.description" :font-size="28" color="#718096"></tm-text>
						</view>
					</view>
					
					<!-- 日主强弱 -->
					<view v-if="bazi_store.enhanced.rizhuQiangruo && bazi_store.enhanced.rizhuQiangruo.level" class="px-0 pb-16 analysis-section">
						<tm-text :font-size="30" color="#718096" label="日主强弱" :margin="[0, 0, 8, 0]"></tm-text>
						<tm-text :label="bazi_store.enhanced.rizhuQiangruo.level" :font-size="32" color="#2d3748" :bold="true"></tm-text>
						<view v-if="bazi_store.enhanced.rizhuQiangruo.description" class="mt-8">
							<tm-text :label="bazi_store.enhanced.rizhuQiangruo.description" :font-size="28" color="#718096"></tm-text>
						</view>
					</view>
					
					<!-- 五行旺衰 -->
					<view v-if="bazi_store.enhanced.wuxingWangshuai" class="px-0 pb-16 analysis-section">
						<tm-text label="五行旺衰" :font-size="30" color="#718096" :margin="[0, 0, 12, 0]"></tm-text>
						<view class="mt-8 flex flex-wrap">
							<view 
								v-for="(value, key) in bazi_store.enhanced.wuxingWangshuai" 
								:key="key"
								class="wuxing-tag"
							>
								<tm-text 
									:label="key + '：' + value" 
									:font-size="28" 
									color="#2d3748"
									:bold="true"
								></tm-text>
							</view>
						</view>
					</view>
					
					<!-- 用神建议 -->
					<view v-if="bazi_store.enhanced.yongshen && bazi_store.enhanced.yongshen.description" class="px-0 pb-16 analysis-section">
						<tm-text :font-size="30" color="#718096" label="用神建议" :margin="[0, 0, 8, 0]"></tm-text>
						<tm-text :label="bazi_store.enhanced.yongshen.description" :font-size="32" color="#2d3748" :bold="true"></tm-text>
						<view v-if="bazi_store.enhanced.yongshen.suggested && bazi_store.enhanced.yongshen.suggested.length > 0" class="mt-12">
							<tm-text :label="'宜用：' + bazi_store.enhanced.yongshen.suggested.join('、')" :font-size="28" color="#48bb78" :bold="true"></tm-text>
						</view>
						<view v-if="bazi_store.enhanced.yongshen.avoid && bazi_store.enhanced.yongshen.avoid.length > 0" class="mt-8">
							<tm-text :label="'忌用：' + bazi_store.enhanced.yongshen.avoid.join('、')" :font-size="28" color="#f56565" :bold="true"></tm-text>
						</view>
					</view>
					
					<!-- 天干地支关系 -->
					<view v-if="combinedGanZhiRelations" class="px-0 pb-16 analysis-section">
						<tm-text label="天干地支关系" :font-size="30" color="#718096" :margin="[0, 0, 16, 0]"></tm-text>
						
						<!-- 三合 -->
						<view v-if="combinedGanZhiRelations.sanHe && combinedGanZhiRelations.sanHe.length > 0" class="relation-item">
							<tm-text :font-size="28" color="#718096" label="三合" :margin="[0, 12, 0, 0]"></tm-text>
							<tm-text :label="combinedGanZhiRelations.sanHe.join('、')" :font-size="30" color="#667eea" :bold="true"></tm-text>
						</view>
						
						<!-- 三刑 -->
						<view v-if="combinedGanZhiRelations.sanXing && combinedGanZhiRelations.sanXing.length > 0" class="relation-item">
							<tm-text :font-size="28" color="#718096" label="三刑" :margin="[0, 12, 0, 0]"></tm-text>
							<tm-text :label="combinedGanZhiRelations.sanXing.join('、')" :font-size="30" color="#ed8936" :bold="true"></tm-text>
						</view>
						
						<!-- 三会 -->
						<view v-if="combinedGanZhiRelations.sanHui && combinedGanZhiRelations.sanHui.length > 0" class="relation-item">
							<tm-text :font-size="28" color="#718096" label="三会" :margin="[0, 12, 0, 0]"></tm-text>
							<tm-text :label="combinedGanZhiRelations.sanHui.join('、')" :font-size="30" color="#667eea" :bold="true"></tm-text>
						</view>
						
						<!-- 天干合化 -->
						<view v-if="combinedGanZhiRelations.ganHe && combinedGanZhiRelations.ganHe.length > 0" class="relation-item">
							<tm-text :font-size="28" color="#718096" label="天干合化" :margin="[0, 12, 0, 0]"></tm-text>
							<tm-text :label="combinedGanZhiRelations.ganHe.join('、')" :font-size="30" color="#48bb78" :bold="true"></tm-text>
						</view>
						
						<!-- 地支六合 -->
						<view v-if="combinedGanZhiRelations.zhiHe && combinedGanZhiRelations.zhiHe.length > 0" class="relation-item">
							<tm-text :font-size="28" color="#718096" label="地支六合" :margin="[0, 12, 0, 0]"></tm-text>
							<tm-text :label="combinedGanZhiRelations.zhiHe.join('、')" :font-size="30" color="#48bb78" :bold="true"></tm-text>
						</view>
						
						<!-- 冲 -->
						<view v-if="combinedGanZhiRelations.chong && combinedGanZhiRelations.chong.length > 0" class="relation-item">
							<tm-text :font-size="28" color="#718096" label="冲" :margin="[0, 12, 0, 0]"></tm-text>
							<tm-text :label="combinedGanZhiRelations.chong.join('、')" :font-size="30" color="#f56565" :bold="true"></tm-text>
						</view>
						
						<!-- 害 -->
						<view v-if="combinedGanZhiRelations.hai && combinedGanZhiRelations.hai.length > 0" class="relation-item">
							<tm-text :font-size="28" color="#718096" label="害" :margin="[0, 12, 0, 0]"></tm-text>
							<tm-text :label="combinedGanZhiRelations.hai.join('、')" :font-size="30" color="#ed8936" :bold="true"></tm-text>
						</view>
					</view>
				</tm-sheet>

				<yx-yun-scroll-list></yx-yun-scroll-list>
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { ref, computed } from 'vue';
import { useBaziStore } from '@/store/bazi.ts';
import { useYunStore } from '@/store/yun.ts';
import { useUserStore } from '@/store/user.ts';
import { calculateGanZhiRelationsForList } from '@/libs/utils/bazi-enhanced.ts';
import utils from '@/libs/utils/utils.ts';
import { API_BASE_URL } from '@/config/config.ts';

const bazi_store = useBaziStore();
const yun_store = useYunStore();
const user_store = useUserStore();

// 四柱 + 当前大运/流年联合计算天干地支关系（用于增强分析展示）
const combinedGanZhiRelations = computed(() => {
	const list: string[] = [];
	if (bazi_store.sizhu?.year) list.push(bazi_store.sizhu.year);
	if (bazi_store.sizhu?.month) list.push(bazi_store.sizhu.month);
	if (bazi_store.sizhu?.day) list.push(bazi_store.sizhu.day);
	if (bazi_store.sizhu?.time) list.push(bazi_store.sizhu.time);

	const dayun = yun_store.dayun_list?.[yun_store.current_index]?.ganzhi;
	const liunian = yun_store.year_list?.[yun_store.year_index]?.ganzhi;
	if (dayun) list.push(dayun);
	if (liunian) list.push(liunian);

	if (list.length < 2) return null;
	return calculateGanZhiRelationsForList(list);
});

const saving = ref(false);
const saveError = ref('');
const exportError = ref('');

if (user_store.timestamp === null) {
	uni.redirectTo({
		url: '/pages/index/index'
	});
}

function saveToAccount() {
	if (!user_store.isLoggedIn || !user_store.token) {
		uni.showToast({
			title: '请先登录账号后再保存',
			icon: 'none',
			duration: 2000
		});
		return;
	}

	if (!user_store.timestamp) {
		uni.showToast({
			title: '缺少出生时间，无法保存',
			icon: 'none',
			duration: 2000
		});
		return;
	}

	saving.value = true;
	saveError.value = '';

	// 准备 rawPayload，确保可以序列化
	let rawPayload = null;
	try {
		// 使用 JSON.parse(JSON.stringify()) 来确保数据可序列化
		rawPayload = JSON.parse(JSON.stringify({
			user: {
				realname: user_store.realname,
				gender: user_store.gender,
				timestamp: user_store.timestamp
			},
			bazi: bazi_store.$state
		}));
	} catch (e) {
		// 如果序列化失败，使用简化版本
		rawPayload = {
			user: {
				realname: user_store.realname,
				gender: user_store.gender,
				timestamp: user_store.timestamp
			},
			bazi: {
				solar: bazi_store.solar,
				lunar: bazi_store.lunar,
				sizhu: bazi_store.sizhu
			}
		};
	}

	// 准备要发送的数据对象，确保所有值都是可序列化的
	const requestData = {
		name: user_store.realname || '佚名',
		gender: user_store.gender !== undefined && user_store.gender !== null ? String(user_store.gender) : null,
		birthDatetime: user_store.timestamp !== undefined && user_store.timestamp !== null ? Number(user_store.timestamp) : null,
		calendarType: 'solar',
		rawPayload: rawPayload
	};

	// 验证数据是否可以序列化
	try {
		JSON.stringify(requestData);
	} catch (e) {
		saveError.value = '数据格式错误，无法保存: ' + e.message;
		saving.value = false;
		return;
	}

	uni.request({
		url: API_BASE_URL + '/api/bazi',
		method: 'POST',
		header: {
			'Content-Type': 'application/json; charset=utf-8',
			'Authorization': 'Bearer ' + user_store.token
		},
		data: requestData,
		success(res) {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				uni.showToast({
					title: '已保存到账号',
					icon: 'success',
					duration: 1500
				});
				saveError.value = '';
				// 保存成功后，延迟跳转回主页
				setTimeout(() => {
					goToHome();
				}, 1500);
			} else if (res.statusCode === 401) {
				user_store.clearAuth();
				uni.showToast({
					title: '登录已失效，请重新登录',
					icon: 'none',
					duration: 2000
				});
				saveError.value = '';
			} else {
				const errorMsg = (res.data && res.data.error) || `保存失败 (${res.statusCode})`;
				saveError.value = errorMsg;
				uni.showToast({
					title: errorMsg,
					icon: 'none',
					duration: 2000
				});
			}
		},
		fail(err) {
			const errorMsg = '网络错误，请检查后端是否已启动';
			saveError.value = errorMsg;
			uni.showToast({
				title: errorMsg,
				icon: 'none',
				duration: 2000
			});
		},
		complete() {
			saving.value = false;
		}
	});
}

function buildExportPayload() {
	const baseTime = user_store.timestamp;
	const birthStr = baseTime ? utils.HideSecond(baseTime) : '';
	return {
		meta: {
			exportedAt: new Date().toISOString()
		},
		user: {
			name: user_store.realname || '佚名',
			gender: user_store.gender ? '男' : '女',
			timestamp: baseTime,
			birthDatetime: birthStr
		},
		bazi: {
			solar: bazi_store.solar,
			lunar: bazi_store.lunar,
			sizhu: bazi_store.sizhu,
			tiangan: bazi_store.tiangan,
			dizhi: bazi_store.dizhi,
			wuxing: bazi_store.wuxing,
			nayin: bazi_store.nayin,
			dishi: bazi_store.dishi,
			canggan: bazi_store.canggan,
			zhuxing: bazi_store.zhuxing,
			fuxing: bazi_store.fuxing,
			start_yun: bazi_store.start_yun,
			table: bazi_store.table,
			enhanced: bazi_store.enhanced
		},
		yun: {
			dayun_list: yun_store.dayun_list,
			year_list: yun_store.year_list,
			current_index: yun_store.current_index,
			year_index: yun_store.year_index
		}
	};
}

function exportJson() {
	exportError.value = '';
	if (!user_store.timestamp) {
		uni.showToast({
			title: '缺少出生时间，无法导出',
			icon: 'none',
			duration: 2000
		});
		return;
	}

	let payload;
	try {
		payload = buildExportPayload();
	} catch (e) {
		exportError.value = '生成导出数据失败：' + (e?.message || e);
		return;
	}

	let jsonStr = '';
	try {
		jsonStr = JSON.stringify(payload, null, 2);
	} catch (e) {
		exportError.value = 'JSON 序列化失败：' + (e?.message || e);
		return;
	}

	const filename = `bazi-${(utils.HideSecond(user_store.timestamp) || '').replace(/[^0-9]/g, '') || 'export'}.json`;

	// H5 优先下载文件
	// #ifdef H5
	try {
		const blob = new Blob([jsonStr], { type: 'application/json' });
		const url = URL.createObjectURL(blob);
		const link = document.createElement('a');
		link.href = url;
		link.download = filename;
		link.click();
		URL.revokeObjectURL(url);
		uni.showToast({
			title: '已下载 JSON 文件',
			icon: 'none',
			duration: 2000
		});
		return;
	} catch (e) {
		// 如果下载失败，继续走剪贴板兜底
	}
	// #endif

	// 其他平台或兜底：复制到剪贴板
	uni.setClipboardData({
		data: jsonStr,
		success() {
			uni.showToast({
				title: 'JSON 已复制，可粘贴保存',
				icon: 'none',
				duration: 2000
			});
		},
		fail(err) {
			exportError.value = '导出失败：' + (err?.errMsg || '剪贴板不可用');
		}
	});
}

function GetStartYunLabel() {
	let str = '出生后';
	const { start_yun } = bazi_store;
	if (start_yun.year) str += start_yun.year + '年';
	if (start_yun.month) str += start_yun.month + '月';
	if (start_yun.day) str += start_yun.day + '日';
	if (start_yun.hour) str += start_yun.hour + '时';
	str += '后起运';
	return str;
}

const GetChineseZodiac = year => utils.GetChineseZodiac(year);
</script>
