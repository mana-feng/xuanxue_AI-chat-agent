								<tm-text
									:font-size="30"
									:bold="true"
									:follow-dark="true"
									:label="utils.HideSecond(user_store.timestamp)"
								></tm-text>
							</view>
							<view class="info-item">
								<tm-text 
									:font-size="28"
									:follow-dark="true"
									label="星座"
								></tm-text>
								<tm-text 
									:font-size="30"
									:bold="true"
									:follow-dark="true"
									:label="bazi_store.xinzuo + '座'"
								></tm-text>
							</view>
						</view>
					</view>

					<view class="px-0 pb-0 mt-24">
						<tm-button
							block
							type="primary"
							:loading="saving"
							:disabled="saving"
							:round="12"
							:height="88"
							:font-size="30"
							:bold="true"
							label="保存到账号"
