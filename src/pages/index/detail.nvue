<template>
	<tm-app>
		<view class="page-wrapper">
			<view class="page-content-scale">
				<yx-nav-header></yx-nav-header>

				<tm-sheet :round="16" :shadow="4" :margin="[20, 20]" :padding="[32, 28]" class="info-card" :follow-dark="true">
					<tm-text
						:font-size="36"
						:bold="true"
						:follow-dark="true"
						label="基本信息"
						:margin="[0, 0, 24, 0]"
					></tm-text>
					
					<view class="flex flex-wrap px-0 py-0">
						<view style="width: 100%; max-width: 360px;" class="mb-16">
							<view class="info-item">
								<tm-text
									:font-size="28"
