}

.detail-card :deep(.section__header) {
	margin-bottom: 6px;
	padding-bottom: 6px;
}

.detail-card :deep(.section__body) {
	gap: 8px;
}

.info-summary .info-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
	gap: 10px;
}

.info-tile {
	padding: 10px 12px;
	border: 1px solid #e5e7eb;
	border-radius: 12px;
	background: #f9fafb;
}

.actions-row {
	display: flex;
	gap: 10px;
	flex-wrap: wrap;
	margin-top: 12px;
	align-items: center;
	flex-direction: row;
}

.actions-row :deep(.tm-button) {
	width: auto !important;
	min-width: 0 !important;
	flex: 0 0 auto;
}

.actions-row :deep(.tm-button__body) {
	width: auto !important;
}

.table-section .start-yun {
	margin-top: 16px;
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	gap: 12px;
	padding-top: 12px;
	border-top: 1px solid #e2e8f0;
}

.table-wrapper {
	width: 100%;
	overflow-x: auto;
