									label="姓名"
								></tm-text>
								<tm-text
									:font-size="30"
									:bold="true"
									:follow-dark="true"
									:label="user_store.realname || '佚名'"
									_class="text-overflow-1"
								></tm-text>
							</view>
							<view class="info-item">
								<tm-text
									:font-size="28"
									:follow-dark="true"
									label="生肖"
								></tm-text>
								<tm-text
									:font-size="30"
									:bold="true"
									:follow-dark="true"
