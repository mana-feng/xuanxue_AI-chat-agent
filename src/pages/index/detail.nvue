<template>
	<tm-app>
		<view class="app-shell">
			<yx-nav-header></yx-nav-header>
			<view class="app-main">
				<view class="page-shell">
					<view class="page-card detail-card">
            <view class="page-title-wrapper">
              <view class="form-header-text">
                <h1 class="page-title">排盘结果</h1>
                <p class="page-subtitle">查看、保存或导出您的排盘信息</p>
              </view>
            </view>

						<view class="section info-summary">
							<header class="section__header">
								<tm-icon name="tmicon-md-person" :font-size="26" color="#667eea"></tm-icon>
								<h2 class="section__title">基本信息</h2>
							</header>
							<view class="section__body info-grid">
								<view class="info-tile">
									<tm-text :font-size="24" color="#718096" label="姓名"></tm-text>
									<tm-text :font-size="30" :bold="true" color="#2d3748" :label="user_store.realname || '佚名'"></tm-text>
								</view>
								<view class="info-tile">
									<tm-text :font-size="24" color="#718096" label="生肖"></tm-text>
									<tm-text :font-size="30" :bold="true" color="#2d3748" :label="GetChineseZodiac(bazi_store.solar.year)"></tm-text>
								</view>
								<view class="info-tile">
									<tm-text :font-size="24" color="#718096" label="性别"></tm-text>
									<tm-text :font-size="30" :bold="true" color="#2d3748" :label="user_store.gender ? '男' : '女'"></tm-text>
								</view>
								<view class="info-tile">
									<tm-text :font-size="24" color="#718096" label="阴历"></tm-text>
									<tm-text :font-size="30" :bold="true" color="#2d3748" :label="bazi_store.yinli"></tm-text>
								</view>
								<view class="info-tile">
									<tm-text :font-size="24" color="#718096" label="阳历"></tm-text>
									<tm-text :font-size="30" :bold="true" color="#2d3748" :label="utils.HideSecond(user_store.timestamp)"></tm-text>
								</view>
								<view class="info-tile">
									<tm-text :font-size="24" color="#718096" label="星座"></tm-text>
									<tm-text :font-size="30" :bold="true" color="#2d3748" :label="bazi_store.xinzuo + '座'"></tm-text>
								</view>
							</view>
							<view class="actions-row">
								<tm-button
									type="primary"
									:loading="saving"
									:disabled="saving"
									:round="12"
									:padding="[24, 20]"
									:bold="true"
									label="保存到账号"
									@tap="saveToAccount"
								></tm-button>
                <tm-button
                  type="grey"
                  :round="12"
                  :padding="[24, 20]"
                  label="导出为 JSON"
                  @tap="exportJson"
                ></tm-button>
                <tm-button
                  type="primary"
                  :round="12"
                  :padding="[24, 20]"
                  label="AI 解答"
                  @tap="goToChat"
                ></tm-button>
							</view>
							<view v-if="saveError" class="mt-12 error-message">
								<tm-text :label="saveError" color="#f56565" :font-size="24"></tm-text>
							</view>
							<view v-if="exportError" class="mt-12 error-message">
								<tm-text :label="exportError" color="#f56565" :font-size="24"></tm-text>
							</view>
						</view>

						<view class="section table-section">
							<header class="section__header">
								<tm-icon name="tmicon-md-grid" :font-size="26" color="#667eea"></tm-icon>
								<h2 class="section__title">排盘详情</h2>
							</header>
							<view class="section__body">
								<view class="table-wrapper draggable-scroll" ref="tableWrapperRef">
									<yx-detail-table></yx-detail-table>
								</view>
								<view class="start-yun">
									<view class="info-item">
										<tm-text :font-size="24" color="#718096" label="起运"></tm-text>
										<tm-text :font-size="28" :bold="true" color="#2d3748" :label="GetStartYunLabel()"></tm-text>
									</view>
									<view class="info-item">
										<tm-text :font-size="24" color="#718096" label="起运公历"></tm-text>
										<tm-text :font-size="28" :bold="true" color="#2d3748" :label="bazi_store.start_yun.solar"></tm-text>
									</view>
								</view>
							</view>
						</view>

						<view v-if="bazi_store.enhanced" class="section analysis-card">
							<header class="section__header">
								<tm-icon name="tmicon-md-stats" :font-size="26" color="#667eea"></tm-icon>
								<h2 class="section__title">增强分析</h2>
							</header>
							<view class="section__body analysis-grid">
								<view class="analysis-block">
									<tm-text :font-size="24" color="#718096" label="格局"></tm-text>
									<tm-text :label="bazi_store.enhanced.geju.type" :font-size="28" color="#2d3748" :bold="true"></tm-text>
									<tm-text v-if="bazi_store.enhanced.geju.description" :label="bazi_store.enhanced.geju.description" :font-size="24" color="#718096" class="mt-4"></tm-text>
								</view>
								<view class="analysis-block">
									<tm-text :font-size="24" color="#718096" label="日主强弱"></tm-text>
									<tm-text :label="bazi_store.enhanced.rizhuQiangruo.level" :font-size="28" color="#2d3748" :bold="true"></tm-text>
									<tm-text v-if="bazi_store.enhanced.rizhuQiangruo.description" :label="bazi_store.enhanced.rizhuQiangruo.description" :font-size="24" color="#718096" class="mt-4"></tm-text>
								</view>
								<view class="analysis-block">
									<tm-text label="五行旺衰" :font-size="24" color="#718096"></tm-text>
									<view class="wuxing-tags">
										<view 
											v-for="(value, key) in bazi_store.enhanced.wuxingWangshuai" 
											:key="key"
											class="wuxing-tag"
										>
											<tm-text 
												:label="key + '：' + value" 
												:font-size="24" 
												color="#2d3748" 
												:bold="true"
											></tm-text>
										</view>
									</view>
								</view>
							</view>
						</view>

						

						<view class="section flow-section">
							<header class="section__header">
								<tm-icon name="tmicon-md-time" :font-size="26" color="#667eea"></tm-icon>
								<h2 class="section__title">流运流年</h2>
							</header>
							<view class="section__body flow-section__body draggable-scroll" ref="flowWrapperRef">
								<yx-yun-scroll-list></yx-yun-scroll-list>
							</view>
						</view>
					</view>
				</view>
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { ref, computed, onMounted, onUnmounted, nextTick } from 'vue';
import { useBaziStore } from '@/store/bazi.ts';
import { useYunStore } from '@/store/yun.ts';
import { useUserStore } from '@/store/user.ts';
import { calculateGanZhiRelationsForList, buildGanZhiDiagram } from '@/libs/utils/bazi-enhanced.ts';
import utils from '@/libs/utils/utils.ts';
import { API_BASE_URL } from '@/config/config.ts';

const bazi_store = useBaziStore();
const yun_store = useYunStore();
const user_store = useUserStore();
const tableWrapperRef = ref<any>(null);
const flowWrapperRef = ref<any>(null);
const dragCleanups: Array<() => void> = [];

const combinedGanZhiRelations = computed(() => {
	const list: string[] = [];
	if (bazi_store.sizhu?.year) list.push(bazi_store.sizhu.year);
	if (bazi_store.sizhu?.month) list.push(bazi_store.sizhu.month);
	if (bazi_store.sizhu?.day) list.push(bazi_store.sizhu.day);
	if (bazi_store.sizhu?.time) list.push(bazi_store.sizhu.time);

	const dayun = yun_store.dayun_list?.[yun_store.current_index]?.ganzhi;
	const liunian = yun_store.year_list?.[yun_store.year_index]?.ganzhi;
	if (dayun) list.push(dayun);
	if (liunian) list.push(liunian);

	if (list.length < 2) return null;
	return calculateGanZhiRelationsForList(list);
});

const baziRelationData = computed(() => {
	const pillarsOrder: { key: 'liunian' | 'dayun' | 'year' | 'month' | 'day' | 'hour'; title: string }[] = [
		{ key: 'liunian', title: '流年' },
		{ key: 'dayun', title: '大运' },
		{ key: 'year', title: '年柱' },
		{ key: 'month', title: '月柱' },
		{ key: 'day', title: '日柱' },
		{ key: 'hour', title: '时柱' }
	];

	const liunianGz = yun_store.year_list?.[yun_store.year_index]?.ganzhi || '';
	const dayunGz = yun_store.dayun_list?.[yun_store.current_index]?.ganzhi || '';

	const pillars = pillarsOrder
		.map(p => {
			if (p.key === 'liunian') {
				return {
					key: p.key,
					title: p.title,
					stem: liunianGz ? liunianGz[0] : '',
					branch: liunianGz ? liunianGz[1] : ''
				};
			}
			if (p.key === 'dayun') {
				return {
					key: p.key,
					title: p.title,
					stem: dayunGz ? dayunGz[0] : '',
					branch: dayunGz ? dayunGz[1] : ''
				};
			}
			const stem = (bazi_store.tiangan as any)?.[p.key === 'hour' ? 'time' : p.key] || '';
			const branch = (bazi_store.dizhi as any)?.[p.key === 'hour' ? 'time' : p.key] || '';
			return {
				key: p.key,
				title: p.title,
				stem: stem || '',
				branch: branch || ''
			};
		})
		.filter(p => p.stem && p.branch);

	if (pillars.length < 2) return { pillars: [], relations: [] };

	const gzList = pillars.map(p => `${p.stem}${p.branch}`);
	const labels = pillars.map(p => p.title);
	const diagram = buildGanZhiDiagram(gzList, labels);

	type RelationType =
		| 'ke'
		| 'he'
		| 'hua'
		| 'sanhe'
		| 'sanmeeting'
		| 'xing'
		| 'po'
		| 'hai'
		| 'chong'
		| 'banhe'
		| 'anhe'
		| 'gonghe';

	const mapType = (edgeType: string): RelationType => {
		if (edgeType === 'ganHe' || edgeType === 'zhiHe') return 'he';
		if (edgeType === 'ganKe' || edgeType === 'zhiKe') return 'ke';
		if (edgeType === 'sanHe') return 'sanhe';
		if (edgeType === 'sanHui') return 'sanmeeting';
		if (edgeType === 'banHe') return 'banhe';
		if (edgeType === 'anHe') return 'anhe';
		if (edgeType === 'chong') return 'chong';
		if (edgeType === 'xing') return 'xing';
		if (edgeType === 'hai') return 'hai';
		return 'he';
	};

	const relations: any[] = [];
	diagram.ganEdges.forEach((edge, idx) => {
		const fromPillar = pillars[edge.from];
		const toPillar = pillars[edge.to];
		if (!fromPillar || !toPillar) return;
		relations.push({
			id: `gan-${idx}`,
			type: mapType(edge.type),
			label: edge.label,
			from: { pillarKey: fromPillar.key, level: 'stem', char: fromPillar.stem },
			to: { pillarKey: toPillar.key, level: 'stem', char: toPillar.stem }
		});
	});

	diagram.zhiEdges.forEach((edge, idx) => {
		const fromPillar = pillars[edge.from];
		const toPillar = pillars[edge.to];
		if (!fromPillar || !toPillar) return;
		relations.push({
			id: `zhi-${idx}`,
			type: mapType(edge.type),
			label: edge.label,
			from: { pillarKey: fromPillar.key, level: 'branch', char: fromPillar.branch },
			to: { pillarKey: toPillar.key, level: 'branch', char: toPillar.branch }
		});
	});

	return { pillars, relations };
});

const saving = ref(false);
const saveError = ref('');
const exportError = ref('');

if (user_store.timestamp === null) {
	uni.redirectTo({
		url: '/pages/index/index'
	});
}

function enableDragScroll(el: HTMLElement | null) {
	if (!el || typeof (el as any).addEventListener !== 'function') return;
	let isDown = false;
	let startX = 0;
	let scrollLeft = 0;

	const onMouseDown = (e: MouseEvent) => {
		isDown = true;
		(el as any).classList?.add('dragging');
		const rect = (el as any).getBoundingClientRect ? (el as any).getBoundingClientRect() : { left: (el as any).offsetLeft || 0 };
		startX = e.pageX - rect.left;
		scrollLeft = el.scrollLeft;
	};

	const onMouseLeave = () => {
		isDown = false;
		(el as any).classList?.remove('dragging');
	};

	const onMouseUp = () => {
		isDown = false;
		(el as any).classList?.remove('dragging');
	};

	const onMouseMove = (e: MouseEvent) => {
		if (!isDown) return;
		e.preventDefault();
		const x = e.pageX - el.offsetLeft;
		const walk = x - startX;
		el.scrollLeft = scrollLeft - walk;
	};

	el.addEventListener('mousedown', onMouseDown);
	el.addEventListener('mouseleave', onMouseLeave);
	el.addEventListener('mouseup', onMouseUp);
	el.addEventListener('mousemove', onMouseMove);

	dragCleanups.push(() => {
		el.removeEventListener('mousedown', onMouseDown);
		el.removeEventListener('mouseleave', onMouseLeave);
		el.removeEventListener('mouseup', onMouseUp);
		el.removeEventListener('mousemove', onMouseMove);
		(el as any).classList?.remove('dragging');
	});
}

onMounted(() => {
	// 仅在 H5/有 DOM 的环境启用拖拽
	if (typeof window === 'undefined') return;
	nextTick(() => {
		enableDragScroll(tableWrapperRef.value as any);
		const flowTarget = (flowWrapperRef.value as any)?.querySelector?.('.scroll-view') || (flowWrapperRef.value as any);
		enableDragScroll(flowTarget as any);
	});
});

onUnmounted(() => {
	dragCleanups.forEach(fn => fn());
});

function saveToAccount() {
	if (!user_store.isLoggedIn || !user_store.token) {
		uni.showToast({
			title: '请先登录账号后再保存',
			icon: 'none',
			duration: 2000
		});
		return;
	}

	if (!user_store.timestamp) {
		uni.showToast({
			title: '缺少出生时间，无法保存',
			icon: 'none',
			duration: 2000
		});
		return;
	}

	saving.value = true;
	saveError.value = '';

	let rawPayload = null;
	try {
		rawPayload = JSON.parse(JSON.stringify({
			user: {
				realname: user_store.realname,
				gender: user_store.gender,
				timestamp: user_store.timestamp
			},
			bazi: bazi_store.$state
		}));
	} catch (e) {
		rawPayload = {
			user: {
				realname: user_store.realname,
				gender: user_store.gender,
				timestamp: user_store.timestamp
			},
			bazi: {
				solar: bazi_store.solar,
				lunar: bazi_store.lunar,
				sizhu: bazi_store.sizhu
			}
		};
	}

	const requestData = {
		name: user_store.realname || '佚名',
		gender: user_store.gender !== undefined && user_store.gender !== null ? String(user_store.gender) : null,
		birthDatetime: user_store.timestamp !== undefined && user_store.timestamp !== null ? Number(user_store.timestamp) : null,
		calendarType: 'solar',
		rawPayload: rawPayload
	};

	try {
		JSON.stringify(requestData);
	} catch (e: any) {
		saveError.value = '数据格式错误，无法保存: ' + e.message;
		saving.value = false;
		return;
	}

	uni.request({
		url: API_BASE_URL + '/api/bazi',
		method: 'POST',
		header: {
			'Content-Type': 'application/json; charset=utf-8',
			'Authorization': 'Bearer ' + user_store.token
		},
		data: requestData,
		success(res) {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				uni.showToast({
					title: '已保存到账号',
					icon: 'success',
					duration: 1500
				});
				saveError.value = '';
				setTimeout(() => {
					goToHome();
				}, 1500);
			} else if (res.statusCode === 401) {
				user_store.clearAuth();
				uni.showToast({
					title: '登录已失效，请重新登录',
					icon: 'none',
					duration: 2000
				});
				saveError.value = '';
			} else {
				const errorMsg = (res.data && res.data.error) || `保存失败 (${res.statusCode})`;
				saveError.value = errorMsg;
				uni.showToast({
					title: errorMsg,
					icon: 'none',
					duration: 2000
				});
			}
		},
		fail(err) {
			const errorMsg = '网络错误，请检查后端是否已启动';
			saveError.value = errorMsg;
			uni.showToast({
				title: errorMsg,
				icon: 'none',
				duration: 2000
			});
		},
		complete() {
			saving.value = false;
		}
	});
}

function buildExportPayload() {
	const baseTime = user_store.timestamp;
	const birthStr = baseTime ? utils.HideSecond(baseTime) : '';
	return {
		meta: {
			exportedAt: new Date().toISOString()
		},
		user: {
			name: user_store.realname || '佚名',
			gender: user_store.gender ? '男' : '女',
			timestamp: baseTime,
			birthDatetime: birthStr
		},
		bazi: {
			solar: bazi_store.solar,
			lunar: bazi_store.lunar,
			sizhu: bazi_store.sizhu,
			tiangan: bazi_store.tiangan,
			dizhi: bazi_store.dizhi,
			wuxing: bazi_store.wuxing,
			nayin: bazi_store.nayin,
			dishi: bazi_store.dishi,
			canggan: bazi_store.canggan,
			zhuxing: bazi_store.zhuxing,
			fuxing: bazi_store.fuxing,
			start_yun: bazi_store.start_yun,
			table: bazi_store.table,
			enhanced: bazi_store.enhanced
		},
		yun: {
			dayun_list: yun_store.dayun_list,
			year_list: yun_store.year_list,
			current_index: yun_store.current_index,
			year_index: yun_store.year_index
		}
	};
}

function exportJson() {
	exportError.value = '';
	if (!user_store.timestamp) {
		uni.showToast({
			title: '缺少出生时间，无法导出',
			icon: 'none',
			duration: 2000
		});
		return;
	}

	let payload;
	try {
		payload = buildExportPayload();
	} catch (e: any) {
		exportError.value = '生成导出数据失败：' + (e?.message || e);
		return;
	}

	let jsonStr = '';
	try {
		jsonStr = JSON.stringify(payload, null, 2);
	} catch (e: any) {
		exportError.value = 'JSON 序列化失败：' + (e?.message || e);
		return;
	}

	const filename = `bazi-${(utils.HideSecond(user_store.timestamp) || '').replace(/[^0-9]/g, '') || 'export'}.json`;

	// #ifdef H5
	try {
		const blob = new Blob([jsonStr], { type: 'application/json' });
		const url = URL.createObjectURL(blob);
		const link = document.createElement('a');
		link.href = url;
		link.download = filename;
		link.click();
		URL.revokeObjectURL(url);
		uni.showToast({
			title: '已下载 JSON 文件',
			icon: 'none',
			duration: 2000
		});
		return;
	} catch (e) {
		// fallback to clipboard
	}
	// #endif

	uni.setClipboardData({
		data: jsonStr,
		success() {
			uni.showToast({
				title: 'JSON 已复制，可粘贴保存',
				icon: 'none',
				duration: 2000
			});
		},
		fail(err) {
			exportError.value = '导出失败：' + (err?.errMsg || '剪贴板不可用');
		}
	});
}

function goToChat() {
	uni.navigateTo({
		url: '/pages/chat/index'
	});
}

function goToHome() {
	uni.reLaunch({
		url: '/pages/index/index'
	});
}

function GetStartYunLabel() {
	let str = '出生后';
	const { start_yun } = bazi_store;
	if (start_yun.year) str += start_yun.year + '年';
	if (start_yun.month) str += start_yun.month + '月';
	if (start_yun.day) str += start_yun.day + '日';
	if (start_yun.hour) str += start_yun.hour + '时';
	str += '后起运';
	return str;
}

const GetChineseZodiac = year => utils.GetChineseZodiac(year);
</script>

