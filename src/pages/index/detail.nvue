							label="导出为 JSON"
							@tap="exportJson"
						></tm-button>
						<tm-button
							class="mt-16"
							block
							type="success"
							:round="12"
							:height="88"
							:font-size="30"
							icon="tmicon-md-home"
							label="返回主页"
							@tap="goToHome"
						></tm-button>
						<view v-if="saveError" class="mt-12 error-message">
							<tm-text :label="saveError" color="#f56565" :font-size="24"></tm-text>
						</view>
						<view v-if="exportError" class="mt-12 error-message">
							<tm-text :label="exportError" color="#f56565" :font-size="24"></tm-text>
						</view>
					</view>
				</tm-sheet>

				<tm-sheet :round="16" :shadow="4" :margin="[20, 0]" :padding="[32, 28]" class="table-card" :follow-dark="true">
					<yx-detail-table></yx-detail-table>
					<view class="px-0 py-24 mt-20 border-top">
						<view class="info-item">
							<tm-text :font-size="28" :follow-dark="true" label="起运"></tm-text>
							<tm-text :font-size="30" :bold="true" :follow-dark="true" :label="GetStartYunLabel()"></tm-text>
						</view>
						<view class="info-item mt-12">
