<template>
	<tm-app>
		<view class="page-wrapper">
			<yx-nav-header></yx-nav-header>
			
			<view class="page-content" :style="pageContentStyle">
				<!-- 顶部操作栏 -->
				<view class="top-bar">
					<view class="search-bar">
						<tm-input
							v-model="searchKeyword"
							placeholder="搜索姓名、邮箱或用户名"
							prefix="search"
							clearable
							@input="handleSearch"
						></tm-input>
					</view>
					<view class="top-bar-buttons">
						<tm-button
							type="success"
							label="返回主页"
							icon="tmicon-md-home"
							@tap="goToHome"
							:margin="[0, 12, 0, 0]"
						></tm-button>
						<tm-button
							type="success"
							label="创建记录"
							@tap="handleCreateRecord"
							:margin="[0, 0, 0, 0]"
						></tm-button>
					</view>
				</view>
				
				<!-- 记录列表 -->
				<view class="record-list">
					<tm-sheet
						v-for="record in recordList"
						:key="record.id"
						:round="4"
						:shadow="2"
						:padding="[20, 20]"
						:margin="[0, 0, 20, 0]"
					>
						<view class="record-header">
							<view class="record-info">
								<tm-text
									:font-size="28"
									:bold="true"
									:label="record.name || '未命名排盘'"
								></tm-text>
								<tm-text
									class="mt-8"
									:font-size="22"
									color="#666"
									:label="'用户：' + (record.userUsername || record.userEmail)"
								></tm-text>
							</view>
							<view class="record-actions">
								<tm-button
									size="small"
									type="primary"
									label="详情"
									:margin="[0, 10, 0, 0]"
									@tap="() => handleViewDetail(record.id)"
								></tm-button>
								<tm-button
									size="small"
									type="primary"
									label="编辑"
									:margin="[0, 10, 0, 0]"
									@tap="() => handleEditRecord(record)"
								></tm-button>
								<tm-button
									size="small"
									type="danger"
									label="删除"
									@tap="() => handleDeleteRecord(record.id)"
								></tm-button>
							</view>
						</view>
						
						<view class="record-details">
							<tm-text
								:font-size="22"
								color="#666"
								:label="'性别：' + (record.gender === '1' || record.gender === 1 ? '男' : record.gender === '0' || record.gender === 0 ? '女' : '未知')"
							></tm-text>
							<tm-text
								class="mt-8"
								:font-size="22"
								color="#666"
								:label="'出生时间：' + record.birthDatetime"
							></tm-text>
							<tm-text
								class="mt-8"
								:font-size="22"
								color="#666"
								:label="'历法：' + (record.calendarType === 'solar' ? '阳历' : '阴历')"
							></tm-text>
							<tm-text
								class="mt-8"
								:font-size="22"
								color="#666"
								:label="'创建时间：' + formatDate(record.createdAt)"
							></tm-text>
						</view>
					</tm-sheet>
					
					<tm-text
						v-if="recordList.length === 0 && !loading"
						class="empty-text"
						:font-size="24"
						color="#999"
						label="暂无记录数据"
					></tm-text>
				</view>
				
				<!-- 分页 -->
				<view class="pagination" v-if="totalPages > 1">
					<tm-button
						:disabled="currentPage === 1"
						label="上一页"
						@tap="handlePrevPage"
					></tm-button>
					<tm-text
						:margin="[0, 20]"
						:label="`${currentPage} / ${totalPages}`"
					></tm-text>
					<tm-button
						:disabled="currentPage === totalPages"
						label="下一页"
						@tap="handleNextPage"
					></tm-button>
				</view>
			</view>
			
			<!-- 创建/编辑记录弹窗 -->
			<tm-drawer
				v-model:show="showRecordDialog"
				:title="editingRecord ? '编辑记录' : '创建记录'"
				:height="700"
			>
				<view class="record-form">
					<tm-input
						v-model.number="recordForm.userId"
						label="用户ID"
						placeholder="请输入用户ID"
						type="number"
						:margin="[0, 0, 20, 0]"
						required
					></tm-input>
					
					<tm-input
						v-model="recordForm.name"
						label="姓名（可选）"
						placeholder="请输入姓名"
						:margin="[0, 0, 20, 0]"
					></tm-input>
					
					<view class="form-item">
						<tm-text
							:font-size="24"
							:margin="[0, 0, 10, 0]"
							label="性别"
						></tm-text>
						<tm-radio-group v-model="recordForm.gender" model="button">
							<tm-radio label="男" value="1"></tm-radio>
							<tm-radio label="女" value="0"></tm-radio>
						</tm-radio-group>
					</view>
					
					<tm-input
						v-model="recordForm.birthDatetime"
						label="出生时间"
						placeholder="格式：YYYY-MM-DD HH:mm:ss"
						:margin="[0, 0, 20, 0]"
						required
					></tm-input>
					
					<view class="form-item">
						<tm-text
							:font-size="24"
							:margin="[0, 0, 10, 0]"
							label="历法类型"
						></tm-text>
						<tm-radio-group v-model="recordForm.calendarType" model="button">
							<tm-radio label="阳历" value="solar"></tm-radio>
							<tm-radio label="阴历" value="lunar"></tm-radio>
						</tm-radio-group>
					</view>
					
					<view v-if="recordFormError" class="error-text">
						<tm-text
							:label="recordFormError"
							color="#ff4d4f"
						></tm-text>
					</view>
					
					<view class="form-actions">
						<tm-button
							block
							type="primary"
							:loading="recordFormLoading"
							:label="editingRecord ? '保存' : '创建'"
							@tap="handleSubmitRecord"
							:margin="[20, 0, 0, 0]"
						></tm-button>
						<tm-button
							block
							type="default"
							label="取消"
							@tap="handleCancelRecord"
							:margin="[20, 0, 0, 0]"
						></tm-button>
					</view>
				</view>
			</tm-drawer>
			
			<!-- 记录详情弹窗 -->
			<tm-drawer
				v-model:show="showDetailDialog"
				title="记录详情"
				:height="700"
			>
				<view class="record-detail" v-if="recordDetail">
					<view class="detail-item">
						<tm-text :font-size="24" color="#666" label="ID"></tm-text>
						<tm-text :label="recordDetail.id.toString()"></tm-text>
					</view>
					<view class="detail-item">
						<tm-text :font-size="24" color="#666" label="姓名"></tm-text>
						<tm-text :label="recordDetail.name || '未命名'"></tm-text>
					</view>
					<view class="detail-item">
						<tm-text :font-size="24" color="#666" label="性别"></tm-text>
						<tm-text :label="recordDetail.gender === '1' || recordDetail.gender === 1 ? '男' : recordDetail.gender === '0' || recordDetail.gender === 0 ? '女' : '未知'"></tm-text>
					</view>
					<view class="detail-item">
						<tm-text :font-size="24" color="#666" label="出生时间"></tm-text>
						<tm-text :label="recordDetail.birthDatetime"></tm-text>
					</view>
					<view class="detail-item">
						<tm-text :font-size="24" color="#666" label="历法类型"></tm-text>
						<tm-text :label="recordDetail.calendarType === 'solar' ? '阳历' : '阴历'"></tm-text>
					</view>
					<view class="detail-item">
						<tm-text :font-size="24" color="#666" label="用户"></tm-text>
						<tm-text :label="(recordDetail.userUsername || recordDetail.userEmail) + ' (ID: ' + recordDetail.userId + ')'"></tm-text>
					</view>
					<view class="detail-item">
						<tm-text :font-size="24" color="#666" label="创建时间"></tm-text>
						<tm-text :label="formatDate(recordDetail.createdAt)"></tm-text>
					</view>
					<view class="detail-item" v-if="recordDetail.rawPayload">
						<tm-text :font-size="24" color="#666" label="原始数据"></tm-text>
						<view class="raw-payload">
							<tm-text 
								:label="JSON.stringify(recordDetail.rawPayload, null, 2)"
								:font-size="20"
							></tm-text>
						</view>
					</view>
				</view>
			</tm-drawer>
		</view>
	</tm-app>
</template>

<script setup lang="ts">
import { ref, onMounted, computed } from 'vue';
import { useUserStore } from '@/store/user';
import { getRecordList, deleteRecord, createRecord, updateRecord, getRecordDetail, type BaziRecordInfo } from '@/api/admin';

const userStore = useUserStore();
const recordList = ref<BaziRecordInfo[]>([]);
const searchKeyword = ref('');
const currentPage = ref(1);
const pageSize = ref(20);
const total = ref(0);
const totalPages = ref(0);
const loading = ref(false);

// navbar 高度（rpx），与 yx-nav-header 中的 navbarHeight 保持一致
const navbarHeight = 40;

// 计算页面内容的 padding-top，避免被 fixed 的 header 遮挡
const pageContentStyle = computed(() => {
	return {
		paddingTop: `${navbarHeight + 20}rpx` // navbar高度 + 原有padding
	};
});

// 记录表单相关
const showRecordDialog = ref(false);
const editingRecord = ref<BaziRecordInfo | null>(null);
const recordForm = ref({
	userId: null as number | null,
	name: '',
	gender: '0',
	birthDatetime: '',
	calendarType: 'solar'
});
const recordFormError = ref('');
const recordFormLoading = ref(false);

// 记录详情相关
const showDetailDialog = ref(false);
const recordDetail = ref<any>(null);

onMounted(() => {
	if (!userStore.isAdmin) {
		uni.reLaunch({
			url: '/pages/auth/auth'
		});
		return;
	}
	
	loadRecords();
});

async function loadRecords() {
	loading.value = true;
	try {
		const res = await getRecordList({
			page: currentPage.value,
			pageSize: pageSize.value,
			search: searchKeyword.value || undefined
		});
		
		if (res.success && res.data) {
			recordList.value = res.data.list;
			total.value = res.data.total;
			totalPages.value = res.data.totalPages;
		}
	} catch (err) {
		console.error('加载记录列表失败:', err);
		uni.showToast({
			title: '加载失败',
			icon: 'none'
		});
	} finally {
		loading.value = false;
	}
}

function handleSearch() {
	currentPage.value = 1;
	loadRecords();
}

function handlePrevPage() {
	if (currentPage.value > 1) {
		currentPage.value--;
		loadRecords();
	}
}

function handleNextPage() {
	if (currentPage.value < totalPages.value) {
		currentPage.value++;
		loadRecords();
	}
}

async function handleDeleteRecord(recordId: number) {
	uni.showModal({
		title: '确认删除',
		content: '确定要删除这条八字记录吗？此操作不可恢复。',
		success: async (res) => {
			if (res.confirm) {
				try {
					const result = await deleteRecord(recordId);
					if (result.success) {
						uni.showToast({
							title: '删除成功',
							icon: 'success'
						});
						loadRecords();
					} else {
						uni.showToast({
							title: result.error || '删除失败',
							icon: 'none'
						});
					}
				} catch (err: any) {
					uni.showToast({
						title: err.error || '删除失败',
						icon: 'none'
					});
				}
			}
		}
	});
}

function goToHome() {
	uni.reLaunch({
		url: '/pages/index/index'
	});
}

function formatDate(dateStr: string) {
	if (!dateStr) return '';
	const date = new Date(dateStr);
	return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
}

function handleCreateRecord() {
	editingRecord.value = null;
	recordForm.value = {
		userId: null,
		name: '',
		gender: '1',
		birthDatetime: '',
		calendarType: 'solar'
	};
	recordFormError.value = '';
	showRecordDialog.value = true;
}

function handleEditRecord(record: BaziRecordInfo) {
	editingRecord.value = record;
	recordForm.value = {
		userId: record.userId,
		name: record.name || '',
		gender: record.gender || '1',
		birthDatetime: record.birthDatetime || '',
		calendarType: record.calendarType || 'solar'
	};
	recordFormError.value = '';
	showRecordDialog.value = true;
}

function handleCancelRecord() {
	showRecordDialog.value = false;
	editingRecord.value = null;
	recordFormError.value = '';
}

async function handleSubmitRecord() {
	recordFormError.value = '';
	
	if (!recordForm.value.userId) {
		recordFormError.value = '请输入用户ID';
		return;
	}
	
	if (!recordForm.value.birthDatetime) {
		recordFormError.value = '请输入出生时间';
		return;
	}
	
	recordFormLoading.value = true;
	try {
		if (editingRecord.value) {
			// 编辑记录
			// 检查是否修改了会影响八字计算的字段
			const birthDatetimeChanged = editingRecord.value.birthDatetime !== recordForm.value.birthDatetime;
			const genderChanged = editingRecord.value.gender !== recordForm.value.gender;
			const calendarTypeChanged = editingRecord.value.calendarType !== recordForm.value.calendarType;
			
			// 如果修改了关键字段，需要清除 rawPayload，让历史页面重新计算
			const shouldClearRawPayload = birthDatetimeChanged || genderChanged || calendarTypeChanged;
			
			const result = await updateRecord(editingRecord.value.id, {
				userId: recordForm.value.userId,
				name: recordForm.value.name || null,
				gender: recordForm.value.gender,
				birthDatetime: recordForm.value.birthDatetime,
				calendarType: recordForm.value.calendarType || null,
				// 如果关键字段被修改，清除 rawPayload
				rawPayload: shouldClearRawPayload ? null : undefined
			});
			if (result.success) {
				uni.showToast({
					title: '保存成功',
					icon: 'success'
				});
				showRecordDialog.value = false;
				loadRecords();
			} else {
				recordFormError.value = result.error || '保存失败';
			}
		} else {
			// 创建记录
			const result = await createRecord({
				userId: recordForm.value.userId,
				name: recordForm.value.name || undefined,
				gender: recordForm.value.gender,
				birthDatetime: recordForm.value.birthDatetime,
				calendarType: recordForm.value.calendarType
			});
			if (result.success) {
				uni.showToast({
					title: '创建成功',
					icon: 'success'
				});
				showRecordDialog.value = false;
				loadRecords();
			} else {
				recordFormError.value = result.error || '创建失败';
			}
		}
	} catch (err: any) {
		recordFormError.value = err.error || '操作失败';
	} finally {
		recordFormLoading.value = false;
	}
}

async function handleViewDetail(recordId: number) {
	try {
		const res = await getRecordDetail(recordId);
		if (res.success && res.data) {
			recordDetail.value = res.data;
			showDetailDialog.value = true;
		} else {
			uni.showToast({
				title: res.error || '加载失败',
				icon: 'none'
			});
		}
	} catch (err: any) {
		uni.showToast({
			title: err.error || '加载失败',
			icon: 'none'
		});
	}
}
</script>

<style scoped>
.page-wrapper {
	min-height: 100vh;
	background-color: #f5f5f5;
}

.page-content {
	padding: 20rpx;
	/* padding-top 通过 :style 动态设置，与 navbar 高度联动 */
}

.top-bar {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-bottom: 20rpx;
	flex-wrap: wrap;
	gap: 12rpx;
}

.search-bar {
	flex: 1;
	min-width: 200rpx;
}

.top-bar-buttons {
	display: flex;
	flex-direction: row;
	align-items: center;
	flex-wrap: wrap;
	gap: 12rpx;
}

.record-actions {
	display: flex;
	flex-direction: row;
}

.record-form {
	padding: 20rpx;
}

.form-item {
	margin-bottom: 20rpx;
}

.error-text {
	margin-top: 20rpx;
}

.form-actions {
	margin-top: 40rpx;
}

.record-detail {
	padding: 20rpx;
}

.detail-item {
	margin-bottom: 30rpx;
	padding-bottom: 20rpx;
	border-bottom: 1px solid #eee;
}

.raw-payload {
	margin-top: 10rpx;
	padding: 20rpx;
	background-color: #f5f5f5;
	border-radius: 8rpx;
	max-height: 400rpx;
	overflow-y: auto;
}

.record-list {
	margin-bottom: 40rpx;
}

.record-header {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: flex-start;
	margin-bottom: 16rpx;
}

.record-info {
	flex: 1;
}

.record-details {
	margin-top: 16rpx;
	padding-top: 16rpx;
	border-top: 1px solid #eee;
}

.empty-text {
	text-align: center;
	padding: 60rpx 0;
}

.pagination {
	display: flex;
	flex-direction: row;
	justify-content: center;
	align-items: center;
	padding: 20rpx 0;
}
</style>

