<template>
	<tm-app>
		<view class="page-wrapper">
			<view class="page-content-scale">
				<!-- 管理员登录表单 -->
				<view class="login-container">
					<tm-text
						font-size="36"
						:bold="true"
						label="管理员登录"
						:margin="[0, 40, 0, 0]"
					></tm-text>
					
					<tm-sheet
						:round="4"
						:shadow="3"
						:margin="[0, 30]"
						:padding="[24, 24]"
					>
						<tm-input
							v-model="identifier"
							placeholder="请输入邮箱或用户名"
							:margin="[0, 0, 0, 0]"
							prefix="account"
							clearable
						></tm-input>
						
						<tm-input
							v-model="password"
							type="password"
							placeholder="请输入密码"
							:margin="[20, 0, 0, 0]"
							prefix="lock"
							clearable
						></tm-input>
						
						<tm-text
							v-if="error"
							class="mt-12"
							font-size="22"
							color="#F56C6C"
							:label="error"
						></tm-text>
						
						<tm-button
							:margin="[30, 0, 0, 0]"
							type="primary"
							block
							:loading="loading"
							label="登录"
							@tap="handleLogin"
						></tm-button>
					</tm-sheet>
					
					<tm-text
						class="mt-20"
						font-size="22"
						color="#999999"
						label="提示：只有管理员账号才能登录后台"
					></tm-text>
				</view>
			</view>
		</view>
	</tm-app>
</template>

<script setup lang="ts">
import { ref, onMounted } from 'vue';
import { login } from '@/api/auth';
import { useUserStore } from '@/store/user';
import { useRouter } from 'vue-router';

const userStore = useUserStore();
const router = useRouter();

const identifier = ref('');
const password = ref('');
const error = ref('');
const loading = ref(false);

onMounted(() => {
	// 恢复登录状态
	userStore.restoreAuth();
	
	// 如果已经登录了管理员账号，直接跳转到后台
	if (userStore.isAdmin) {
		uni.reLaunch({
			url: '/pages/admin/dashboard'
		});
	}
});

async function handleLogin() {
	if (!identifier.value || !password.value) {
		error.value = '请输入账号和密码';
		return;
	}
	
	error.value = '';
	loading.value = true;
	
	try {
		const res = await login({
			identifier: identifier.value,
			password: password.value
		});
		
		if (res.success && res.data) {
			const user = res.data.user;
			
			// 检查是否为管理员
			if (user.role !== 'admin') {
				error.value = '该账号不是管理员，无法登录后台';
				loading.value = false;
				return;
			}
			
			// 保存登录信息
			userStore.setAuth({
				email: user.email,
				username: user.username || null,
				token: res.data.token,
				role: user.role
			});
			
			// 跳转到管理员后台
			uni.reLaunch({
				url: '/pages/admin/dashboard'
			});
		} else {
			error.value = res.error || '登录失败';
		}
	} catch (err: any) {
		error.value = err.error || '登录失败，请检查网络连接';
	} finally {
		loading.value = false;
	}
}
</script>

<style scoped>
.page-wrapper {
	min-height: 100vh;
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.page-content-scale {
	padding: 40rpx;
}

.login-container {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	min-height: 60vh;
}
</style>

