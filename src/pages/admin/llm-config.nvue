<template>
  <tm-app>
    <view class="page-wrapper">
      <yx-nav-header></yx-nav-header>

      <view class="page-content">
        <view class="header">
          <tm-text :font-size="36" :bold="true" color="#2d3748" label="大模型管理"></tm-text>
          <tm-text :font-size="24" color="#6b7280" label="配置聊天界面对接的大模型 API"></tm-text>
        </view>

        <tm-sheet :round="12" :shadow="4" :padding="[24, 20]" class="form-card">
          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="当前模型"></tm-text>
            <tm-text :font-size="24" color="#111827" :label="currentModelDisplay"></tm-text>
            <tm-text v-if="modelHistory.length === 0 && !loading" :font-size="22" color="#9ca3af" label="暂无历史配置记录"></tm-text>
          </view>

          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="历史模型配置"></tm-text>
            <view v-if="loading" class="loading-hint">
              <tm-text :font-size="22" color="#9ca3af" label="加载中..."></tm-text>
            </view>
            <view v-else-if="modelHistory.length > 0" class="model-list">
              <view
                v-for="model in modelHistory"
                :key="model.id"
                class="model-item"
                :class="{ active: model.is_active === 1 }"
              >
                <view class="model-info">
                  <tm-text :font-size="24" :bold="model.is_active === 1" :label="model.name || `${model.provider}-${model.model}`"></tm-text>
                  <tm-text :font-size="22" color="#6b7280" :label="`${model.provider} / ${model.model}`"></tm-text>
                  <tm-text v-if="model.created_at" :font-size="20" color="#9ca3af" :label="`创建时间: ${new Date(model.created_at).toLocaleString('zh-CN')}`"></tm-text>
                </view>
                <view class="model-actions">
                  <tm-button
                    v-if="model.is_active !== 1"
                    size="small"
                    type="primary"
                    label="切换"
                    @tap="activateModel(model.id)"
                  ></tm-button>
                  <tm-text v-else :font-size="22" color="#10b981" label="当前使用"></tm-text>
                </view>
              </view>
            </view>
            <view v-else class="empty-hint">
              <tm-text :font-size="22" color="#9ca3af" label="暂无历史配置，保存配置后将显示在此处"></tm-text>
            </view>
          </view>

          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="供应商"></tm-text>
            <picker
              mode="selector"
              :range="providerOptions"
              range-key="label"
              :value="providerIndex"
              @change="onProviderChange"
            >
              <view class="picker-trigger">
                <tm-text :font-size="26" :color="'#111827'" :label="currentProviderLabel"></tm-text>
                <tm-icon name="arrow-down" :font-size="26" color="#9ca3af"></tm-icon>
              </view>
            </picker>
          </view>

          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="API Base URL"></tm-text>
            <tm-input v-model="form.baseUrl" placeholder="https://api.example.com" :margin="[0, 12, 0, 0]" :round="10"></tm-input>
          </view>

          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="API Key"></tm-text>
            <tm-input
              v-model="form.apiKey"
              placeholder="输入密钥"
              :password="true"
              :margin="[0, 12, 0, 0]"
              :round="10"
            ></tm-input>
          </view>

          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="模型名称"></tm-text>
            <tm-input v-model="form.model" placeholder="如 gpt-4o, claude-3.5" :margin="[0, 12, 0, 0]" :round="10"></tm-input>
          </view>

          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="配置名称（可选）"></tm-text>
            <tm-input v-model="form.name" placeholder="如：生产环境-GPT-4" :margin="[0, 12, 0, 0]" :round="10"></tm-input>
          </view>

          <view class="form-group">
            <tm-text :font-size="26" color="#4b5563" label="额外参数（JSON 可选）"></tm-text>
            <tm-input
              v-model="form.extra"
              type="textarea"
              placeholder='如：{ "temperature": 0.7 }'
              :height="120"
              :margin="[0, 12, 0, 0]"
              :round="10"
            ></tm-input>
          </view>

          <view class="actions">
            <tm-button
              type="primary"
              :round="12"
              :padding="[20, 22]"
              :loading="saving"
              :disabled="saving"
              label="保存配置"
              @tap="handleSave"
            ></tm-button>
          </view>
        </tm-sheet>
      </view>
    </view>
  </tm-app>
</template>

<script setup lang="ts">
import { reactive, ref, onMounted, computed } from 'vue';
import { useUserStore } from '@/store/user';
import { request } from '@/api/index';

const userStore = useUserStore();
const saving = ref(false);
const loading = ref(false);

const form = reactive({
  provider: 'openai', // openai | anthropic | deepseek | qwen | gemini
  baseUrl: '',
  apiKey: '',
  model: '',
  extra: '',
  name: ''
});

const modelHistory = ref<Array<{
  id: number;
  name: string;
  provider: string;
  base_url: string;
  api_key: string;
  model: string;
  extra: string | null;
  is_active: number;
  created_at: string;
  updated_at: string;
}>>([]);

const currentModelDisplay = computed(() => {
  // 优先从历史记录中查找激活的模型
  const active = modelHistory.value.find(m => m.is_active === 1);
  if (active) {
    return `${active.name || '未命名'} (${active.provider} / ${active.model})`;
  }
  // 如果没有历史记录，从表单中显示当前配置
  if (form.provider && form.model) {
    const providerLabel = providerOptions.find(p => p.value === form.provider)?.label || form.provider;
    return `${providerLabel} / ${form.model}${form.baseUrl ? ' (已配置)' : ' (未完整配置)'}`;
  }
  return '未配置';
});

const providerOptions = [
  { value: 'openai', label: 'OpenAI / DeepSeek 兼容' },
  { value: 'anthropic', label: 'Anthropic Claude' },
  { value: 'deepseek', label: 'DeepSeek' },
  { value: 'qwen', label: '通义千问 (兼容模式)' },
  { value: 'gemini', label: 'Google Gemini' }
];

const providerIndex = ref(0);

const currentProviderLabel = computed(() => {
  const item = providerOptions.find((p) => p.value === form.provider);
  return item ? item.label : '选择供应商';
});

async function loadConfig() {
  loading.value = true;
  try {
    const res = await request('/api/admin/llm-config', { method: 'GET', needAuth: true });
    if (res?.provider !== undefined) {
      form.provider = res.provider || 'openai';
      form.baseUrl = res.baseUrl || '';
      form.apiKey = res.apiKey || '';
      form.model = res.model || '';
      form.extra = res.extra || '';
      form.name = res.name || '';
      const idx = providerOptions.findIndex((p) => p.value === form.provider);
      providerIndex.value = idx >= 0 ? idx : 0;
    }
    // 加载历史模型
    await loadModelHistory();
  } catch (err) {
    console.warn('加载 LLM 配置失败:', err);
    uni.showToast({ title: '加载失败', icon: 'none' });
  } finally {
    loading.value = false;
  }
}

async function loadModelHistory() {
  try {
    const res = await request('/api/admin/llm-models', { method: 'GET', needAuth: true });
    console.log('[DEBUG] 加载模型历史响应:', res);
    if (res?.success && res?.data) {
      modelHistory.value = Array.isArray(res.data) ? res.data : [];
      console.log('[DEBUG] 模型历史数量:', modelHistory.value.length);
    } else {
      console.warn('[DEBUG] 模型历史响应格式异常:', res);
      modelHistory.value = [];
    }
  } catch (err: any) {
    console.error('加载模型历史失败:', err);
    // 如果是 404 或表不存在，静默处理（表可能还未创建）
    if (err?.error?.includes('404') || err?.error?.includes('不存在')) {
      console.warn('模型历史表可能还未创建，跳过加载');
      modelHistory.value = [];
    } else {
      // 其他错误显示提示
      uni.showToast({ title: '加载模型历史失败', icon: 'none', duration: 2000 });
      modelHistory.value = [];
    }
  }
}

async function activateModel(modelId: number) {
  try {
    await request(`/api/admin/llm-models/${modelId}/activate`, {
      method: 'POST',
      needAuth: true
    });
    uni.showToast({ title: '已切换', icon: 'success', duration: 1500 });
    await loadConfig();
  } catch (err) {
    console.error('切换模型失败:', err);
    uni.showToast({ title: '切换失败', icon: 'none' });
  }
}

onMounted(() => {
  loadConfig();
});

async function handleSave() {
  if (!userStore.isAdmin) {
    uni.showToast({ title: '仅管理员可操作', icon: 'none' });
    return;
  }
  saving.value = true;
  try {
    await request('/api/admin/llm-config', {
      method: 'PUT',
      needAuth: true,
      data: { ...form }
    });
    uni.showToast({ title: '已保存', icon: 'success', duration: 1500 });
    await loadConfig();
  } catch (err) {
    console.error(err);
    uni.showToast({ title: '保存失败', icon: 'none' });
  } finally {
    saving.value = false;
  }
}

function onProviderChange(e: any) {
  const idx = Number(e?.detail?.value || 0);
  const item = providerOptions[idx];
  if (item) {
    form.provider = item.value;
    providerIndex.value = idx;
  }
}
</script>

<style scoped>
.page-wrapper {
  min-height: 100vh;
  background: #f8fafc;
}

.page-content {
  padding: 20px 16px 32px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 8px;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 4px;
}

.picker-trigger {
  width: 100%;
}

.model-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 8px;
}

.model-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #f9fafb;
  border-radius: 8px;
  border: 1px solid #e5e7eb;
}

.model-item.active {
  background: #eff6ff;
  border-color: #3b82f6;
}

.model-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.model-actions {
  display: flex;
  align-items: center;
  margin-left: 12px;
}

.loading-hint,
.empty-hint {
  padding: 16px;
  text-align: center;
  color: #9ca3af;
}
</style>
