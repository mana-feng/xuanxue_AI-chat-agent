<template>
	<tm-app>
		<view class="app-shell">
			<yx-nav-header></yx-nav-header>
			<view class="app-main">
				<view class="page-shell">
					<view class="page-card history-card">
						<view class="page-title-wrapper history-header">
							<view class="form-header-icon">
								<tm-icon name="tmicon-md-time" :font-size="40" color="#667eea"></tm-icon>
							</view>
							<view class="form-header-text">
								<h1 class="page-title">历史排盘记录</h1>
								<p class="page-subtitle">查看、筛选并管理已保存的排盘</p>
							</view>
							<view class="header-actions">
								<tm-button
									size="small"
									type="grey"
									:round="12"
									:padding="[18, 18]"
									icon="tmicon-md-refresh"
									label="刷新"
									@tap="fetchCharts"
								></tm-button>
								<tm-button
									v-if="isLoggedIn && user_store.isAdmin"
									size="small"
									type="warning"
									:round="12"
									:padding="[18, 18]"
									label="管理员后台"
									@tap="goToAdmin"
								></tm-button>
							</view>
						</view>

						<view v-if="!isLoggedIn" class="empty-state">
							<tm-icon name="account-circle" :font-size="80" color="#cbd5e0" :margin="[0, 0, 20, 0]"></tm-icon>
							<tm-text
								:font-size="28"
								color="#718096"
								label="登录后可查看和管理您保存的八字排盘记录"
								:margin="[0, 0, 30, 0]"
							></tm-text>
							<tm-button
								type="primary"
								:round="12"
								:padding="[28, 24]"
								:bold="true"
								label="去登录"
								@tap="goLogin"
							></tm-button>
						</view>

						<view v-else>
							<view class="section filters-card">
								<header class="section__header">
									<tm-icon name="tmicon-md-search" :font-size="26" color="#667eea"></tm-icon>
									<h2 class="section__title">筛选与排序</h2>
								</header>
								<view class="section__body filters-grid">
									<view class="filter-block search-block">
										<tm-input
											v-model="searchKeyword"
											prefix="tmicon-md-search"
											placeholder="搜索姓名..."
											@input="onSearchInput"
											clearable
											:round="12"
											:border="1"
										></tm-input>
									</view>
									<view class="filter-block">
										<tm-text :font-size="22" color="#666666" label="性别：" class="mb-6"></tm-text>
										<tm-radio-group v-model="genderFilter">
											<tm-radio label="全部" :value="''"></tm-radio>
											<tm-radio label="男" :value="'0'"></tm-radio>
											<tm-radio label="女" :value="'1'"></tm-radio>
										</tm-radio-group>
									</view>
									<view class="filter-block">
										<tm-text :font-size="22" color="#666666" label="排序：" class="mb-6"></tm-text>
										<tm-segtab
											v-model="sortByIndex"
											:list="[
												{ text: '时间' },
												{ text: '姓名' }
											]"
											:margin="[0, 0]"
											:width="260"
										></tm-segtab>
									</view>
									<view class="filter-actions">
										<tm-button
											:type="sortOrder === 'DESC' ? 'primary' : 'grey'"
											size="small"
											:padding="[16, 14]"
											:round="12"
											:label="sortOrder === 'DESC' ? '↓ 降序' : '↑ 升序'"
											@tap="toggleSortOrder"
										></tm-button>
										<tm-button
											v-if="searchKeyword || genderFilter"
											type="danger"
											size="small"
											:padding="[16, 14]"
											:round="12"
											label="清除筛选"
											@tap="clearFilters"
										></tm-button>
										<tm-text
											v-if="totalCount > 0"
											class="filters-count"
											:font-size="22"
											color="#999999"
											:label="`共找到${totalCount} 条记录`"
										></tm-text>
									</view>
								</view>
							</view>

							<view v-if="loading" class="py-20 text-center">
								<tm-text label="加载中..." color="#999999"></tm-text>
							</view>
							<view v-else-if="charts.length === 0" class="py-20 text-center">
								<tm-text 
									:label="searchKeyword || genderFilter ? '未找到符合条件的记录' : '暂无保存记录，可在排盘结果页点击「保存到账号」哦'" 
									color="#999999"
								></tm-text>
							</view>
							<view v-else class="records-list">
								<tm-sheet
									v-for="item in charts"
									:key="item.id"
									:round="16"
									:shadow="2"
									:margin="[0, 0]"
									:padding="[24, 20]"
									class="record-card"
								>
									<view class="record-card__header">
										<view class="record-meta">
											<tm-text
												:bold="true"
												:font-size="30"
												color="#2d3748"
												:label="item.title || '未命名'"
												_class="text-overflow-1"
											></tm-text>
											<tm-text
												class="mt-6"
												:font-size="26"
												color="#718096"
												:label="formatBirth(item) || ''"
												_class="text-overflow-1"
											></tm-text>
											<view class="record-meta__row">
												<tm-text
													:font-size="22"
													color="#a0aec0"
													:label="'保存时间：' + (item.createdAtLabel || '')"
												></tm-text>
												<tm-text
													v-if="item.gender !== null && item.gender !== undefined"
													class="ml-12"
													:font-size="22"
													color="#a0aec0"
													:label="item.gender === '1' || item.gender === 1 ? '男' : '女'"
												></tm-text>
											</view>
										</view>
										<view class="record-actions">
											<tm-button
												size="small"
												type="primary"
												:padding="[18, 20]"
												:round="12"
												label="查看"
												@tap="openChart(item)"
											></tm-button>
											<tm-button
												size="small"
												type="danger"
												:padding="[18, 20]"
												:round="12"
												label="删除"
												@tap="removeChart(item)"
											></tm-button>
										</view>
									</view>
								</tm-sheet>
							</view>
							<view v-if="error" class="mt-10">
								<tm-text :label="error" color="red"></tm-text>
							</view>
						</view>
					</view>
				</view>
			</view>
		</view>
	</tm-app>
</template>

<script lang="ts" setup>
import { ref, computed, onMounted, watch } from 'vue';
import { useUserStore } from '@/store/user.ts';
import { useBaziStore } from '@/store/bazi.ts';
import { API_BASE_URL } from '@/config/config.ts';
import utils from '@/libs/utils/utils.ts';

interface ChartItem {
	id: number;
	title: string;
	gender?: string | null;
	birthDatetime: string;
	createdAt: string;
	createdAtLabel?: string;
	rawPayload?: any;
}

const user_store = useUserStore();
const bazi_store = useBaziStore();

const charts = ref<ChartItem[]>([]);
const loading = ref(false);
const error = ref('');
const totalCount = ref(0);

const searchKeyword = ref('');
const genderFilter = ref('');
const sortByIndex = ref(0); // 0: 时间, 1: 姓名
const sortBy = computed(() => (sortByIndex.value === 0 ? 'created_at' : 'name'));
const sortOrder = ref<'ASC' | 'DESC'>('DESC');

let searchTimer: any = null;

const isLoggedIn = computed(() => user_store.isLoggedIn);

watch([genderFilter, sortByIndex, sortOrder], () => {
	if (user_store.isLoggedIn) {
		fetchCharts();
	}
});

onMounted(() => {
	user_store.restoreAuth();
	if (user_store.isLoggedIn) {
		fetchCharts();
	}
});

function onSearchInput() {
	if (searchTimer) {
		clearTimeout(searchTimer);
	}
	searchTimer = setTimeout(() => {
		fetchCharts();
	}, 500);
}

function toggleSortOrder() {
	sortOrder.value = sortOrder.value === 'DESC' ? 'ASC' : 'DESC';
}

function clearFilters() {
	searchKeyword.value = '';
	genderFilter.value = '';
	sortByIndex.value = 0;
	sortOrder.value = 'DESC';
	fetchCharts();
}

function fetchCharts() {
	if (!user_store.isLoggedIn || !user_store.token) {
		return;
	}
	loading.value = true;
	error.value = '';

	const params: Record<string, string> = {};
	if (searchKeyword.value) {
		params.keyword = searchKeyword.value;
	}
	if (genderFilter.value) {
		params.gender = genderFilter.value;
	}
	if (sortBy.value) {
		params.sortBy = sortBy.value as string;
	}
	if (sortOrder.value) {
		params.sortOrder = sortOrder.value;
	}

	const queryString = Object.keys(params)
		.map(key => `${encodeURIComponent(key)}=${encodeURIComponent(params[key])}`)
		.join('&');

	uni.request({
		url: API_BASE_URL + '/api/charts' + (queryString ? '?' + queryString : ''),
		method: 'GET',
		header: {
			Authorization: 'Bearer ' + user_store.token
		},
		success(res: any) {
			try {
				if (res.statusCode >= 200 && res.statusCode < 300) {
					let data = res.data;
					if (Array.isArray(data)) {
						charts.value = data.map((it: any) => {
							try {
								return {
									...it,
									createdAtLabel: formatDateTime(it.createdAt || '')
								};
							} catch (e) {
								return {
									...it,
									createdAtLabel: ''
								};
							}
						});
						totalCount.value = charts.value.length;
					} else if (data && data.list) {
						charts.value = data.list.map((it: any) => {
							try {
								return {
									...it,
									createdAtLabel: formatDateTime(it.createdAt || '')
								};
							} catch (e) {
								return {
									...it,
									createdAtLabel: ''
								};
							}
						});
						totalCount.value = data.total || charts.value.length;
					} else {
						charts.value = [];
						totalCount.value = 0;
					}
				} else if (res.statusCode === 401) {
					uni.showToast({
						title: '登录已失效，请重新登录',
						icon: 'none',
						duration: 2000
					});
				} else {
					error.value = (res.data && res.data.error) || '获取失败，请稍后重试';
				}
			} catch (e) {
				error.value = '数据处理失败，请稍后重试';
			}
		},
		fail() {
			error.value = '网络错误，请检查后端是否已启动';
		},
		complete() {
			loading.value = false;
		}
	});
}

function formatDateTime(iso: string) {
	if (!iso) return '';
	try {
		const d = new Date(iso);
		if (isNaN(d.getTime())) {
			return '';
		}
		return utils.HideSecond(d.getTime()) || '';
	} catch (e) {
		return '';
	}
}

function formatBirth(item: ChartItem) {
	if (!item || !item.birthDatetime) return '';
	try {
		const d = new Date(item.birthDatetime);
		if (isNaN(d.getTime())) {
			return '';
		}
		const result = utils.HideSecond(d.getTime());
		return result ? '出生：' + result : '';
	} catch (e) {
		return '';
	}
}

function openChart(item: ChartItem) {
	try {
		let useRawPayload = false;
		if (item.rawPayload && item.rawPayload.user && item.rawPayload.bazi) {
			const u = item.rawPayload.user;
			const b = item.rawPayload.bazi;

			if (
				u.timestamp &&
				u.gender !== undefined &&
				u.gender !== null &&
				b.solar &&
				b.solar.year &&
				b.sizhu &&
				b.sizhu.year &&
				b.yinli &&
				b.xinzuo &&
				b.table &&
				Array.isArray(b.table) &&
				b.table.length > 0
			) {
				let rawPayloadGender: number;
				if (u.gender === null || u.gender === undefined) {
					rawPayloadGender = 0;
				} else if (typeof u.gender === 'string') {
					rawPayloadGender = u.gender === '1' ? 1 : 0;
				} else {
					rawPayloadGender = u.gender === 1 ? 1 : 0;
				}

				let dbGender: number;
				if (item.gender === null || item.gender === undefined) {
					dbGender = 0;
				} else if (typeof item.gender === 'string') {
					dbGender = item.gender === '1' ? 1 : 0;
				} else {
					dbGender = item.gender === 1 ? 1 : 0;
				}

				let dbTimestamp: number;
				if (typeof item.birthDatetime === 'string') {
					const date = new Date(item.birthDatetime);
					dbTimestamp = date.getTime();
				} else if (typeof item.birthDatetime === 'number') {
					dbTimestamp = item.birthDatetime;
				} else {
					dbTimestamp = 0;
				}

				const timestampDiff = Math.abs((u.timestamp || 0) - dbTimestamp);
				if (rawPayloadGender === dbGender && timestampDiff < 1000) {
					useRawPayload = true;
				}
			}
		}

		if (useRawPayload) {
			const u = item.rawPayload.user;
			user_store.set({
				realname: u.realname || item.title || '佚名',
				gender: u.gender,
				timestamp: u.timestamp
			});
			bazi_store.$patch(item.rawPayload.bazi);

			setTimeout(() => {
				uni.navigateTo({
					url: '/pages/index/detail'
				});
			}, 100);
			return;
		}

		if (!item.birthDatetime) {
			uni.showToast({
				title: '该记录缺少出生时间数据',
				icon: 'none',
				duration: 2000
			});
			return;
		}

		let timestamp: number;
		if (typeof item.birthDatetime === 'string') {
			const date = new Date(item.birthDatetime);
			timestamp = date.getTime();
			if (isNaN(timestamp)) {
				uni.showToast({
					title: '出生时间格式错误，无法解析',
					icon: 'none',
					duration: 2000
				});
				return;
			}
		} else if (typeof item.birthDatetime === 'number') {
			timestamp = item.birthDatetime;
			if (isNaN(timestamp) || timestamp <= 0) {
				uni.showToast({
					title: '出生时间无效',
					icon: 'none',
					duration: 2000
				});
				return;
			}
		} else {
			uni.showToast({
				title: '出生时间格式错误',
				icon: 'none',
				duration: 2000
			});
			return;
		}

		let gender: number;
		if (item.gender === null || item.gender === undefined) {
			gender = 0;
		} else if (typeof item.gender === 'string') {
			gender = item.gender === '1' ? 1 : 0;
		} else {
			gender = item.gender === 1 ? 1 : 0;
		}

		uni.showLoading({
			title: '排盘中，请稍后！'
		});

		user_store.set({
			realname: item.title || '佚名',
			gender: gender,
			timestamp: timestamp
		});

		try {
			bazi_store.pull({
				timestamp: timestamp,
				gender: gender
			});
		} catch (pullError: any) {
			uni.hideLoading();
			uni.showToast({
				title: '排盘计算失败：' + (pullError?.message || '未知错误'),
				icon: 'none',
				duration: 2000
			});
			return;
		}

		setTimeout(() => {
			uni.hideLoading();
			if (!bazi_store.solar || !bazi_store.solar.year) {
				uni.showToast({
					title: '排盘数据不完整，请重试',
					icon: 'none',
					duration: 2000
				});
				return;
			}
			uni.navigateTo({
				url: '/pages/index/detail'
			});
		}, 200);
	} catch (e: any) {
		uni.hideLoading();
		uni.showToast({
			title: '打开排盘记录失败：' + (e?.message || '未知错误'),
			icon: 'none',
			duration: 2000
		});
	}
}

function removeChart(item: ChartItem) {
	uni.showModal({
		title: '删除确认',
		content: '确定要删除这条排盘记录吗？',
		success(res) {
			if (res.confirm) {
				doRemove(item);
			}
		}
	});
}

function doRemove(item: ChartItem) {
	if (!user_store.token) return;

	uni.request({
		url: API_BASE_URL + '/api/charts/' + item.id,
		method: 'DELETE',
		header: {
			Authorization: 'Bearer ' + user_store.token
		},
		success(res: any) {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				charts.value = charts.value.filter(c => c.id !== item.id);
				totalCount.value = charts.value.length;
				uni.showToast({
					title: '已删除',
					icon: 'none',
					duration: 1500
				});
			} else {
				error.value = (res.data && res.data.error) || '删除失败，请稍后重试';
			}
		},
		fail() {
			error.value = '网络错误，请检查后端是否已启动';
		}
	});
}

function goToHome() {
	uni.reLaunch({
		url: '/pages/index/index'
	});
}

function goToAdmin() {
	uni.navigateTo({
		url: '/pages/auth/auth'
	});
}

function goLogin() {
	uni.navigateTo({
		url: '/pages/auth/auth?mode=login'
	});
}
</script>

<style scoped>
.history-card {
	display: flex;
	flex-direction: column;
	gap: clamp(16px, 2vw, 20px);
}

.history-header {
	align-items: center;
}

.header-actions {
	display: flex;
	flex-direction: row;
	align-items: center;
	gap: 8px;
	flex-wrap: wrap;
	justify-content: flex-end;
}

.filters-card {
	background: #f9fafb;
	border-radius: 16px;
	border: 1px solid #edf2f7;
}

.filters-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	gap: 12px;
}

.filter-block {
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.search-block {
	grid-column: 1 / -1;
}

.filter-actions {
	display: flex;
	flex-wrap: wrap;
	gap: 8px;
	align-items: center;
}

.filters-count {
	margin-left: auto;
}

.records-list {
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.record-card {
	background: #ffffff;
	transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.record-card:active {
	transform: translateY(1px);
}

.record-card__header {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	gap: 16px;
}

.record-meta {
	flex: 1;
	min-width: 0;
}

.record-meta__row {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-top: 8rpx;
	flex-wrap: wrap;
	gap: 8rpx;
}

.record-actions {
	display: flex;
	flex-direction: column;
	gap: 8px;
	align-items: flex-end;
	justify-content: center;
}

.empty-state {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	padding: 80rpx 40rpx;
	text-align: center;
}

.text-center {
	text-align: center;
}

@media screen and (max-width: 640px) {
	.history-header {
		flex-direction: column;
		align-items: flex-start;
		gap: 12px;
	}

	.header-actions {
		width: 100%;
		justify-content: flex-start;
	}

	.record-card__header {
		flex-direction: column;
		align-items: flex-start;
	}

	.record-actions {
		flex-direction: row;
		align-items: center;
	}
}
</style>
