<template>
	<view class="chat-page-shell">
		<yx-nav-header></yx-nav-header>
		<chat-panel class="chat-panel-wrapper" @send="handleSend" ref="panelRef" />
	</view>
</template>

<script lang="ts" setup>
import { ref } from 'vue';
import ChatPanel from '@/chat/ChatPanel.vue';
import { request } from '@/api/index';
import { getAccessToken } from '@/utils/tokenStore';
import { API_BASE_URL } from '@/config/config';
import { useUserStore } from '@/store/user';
import { useBaziStore } from '@/store/bazi';
import { useYunStore } from '@/store/yun';
import { buildBaziExportPayload } from '@/utils/baziExport';

const panelRef = ref<InstanceType<typeof ChatPanel> | null>(null);
const config = ref<{ provider: string; baseUrl: string; apiKey: string; model: string; extra?: string }>({
	provider: 'openai',
	baseUrl: '',
	apiKey: '',
	model: '',
	extra: ''
});

const userStore = useUserStore();
const baziStore = useBaziStore();
const yunStore = useYunStore();
let firstSendDone = false;

function handleSend(text: string) {
	sendToLLM(text);
}

async function loadConfig() {
	try {
		const res = await request('/api/admin/llm-config', { method: 'GET', needAuth: true });
		if (res?.provider !== undefined) {
			config.value = {
				provider: res.provider || 'openai',
				baseUrl: res.baseUrl || '',
				apiKey: res.apiKey || '',
				model: res.model || '',
				extra: res.extra || ''
			};
		}
	} catch (err) {
		console.warn('加载 LLM 配置失败', err);
	}
}
loadConfig();

function buildMessages(text: string) {
	const messages: Array<{ role: string; content: string }> = [{ role: 'user', content: text }];
	if (!firstSendDone) {
		const payload = buildBaziExportPayload(userStore, baziStore, yunStore);
		const baziJson = payload ? JSON.stringify(payload) : null;
		if (baziJson) {
			messages.unshift({
				role: 'system',
				content: `User Bazi profile (JSON): ${baziJson}`
			});
		}
		firstSendDone = true;
	}
	return messages;
}

async function sendToLLM(text: string) {
	const panel = panelRef.value;
	if (!panel) return;
	panel.setSending(true);

	try {
		// 发送前重新加载配置，确保使用最新的 provider
		await loadConfig();
		console.log('[DEBUG] 当前使用的 provider:', config.value.provider);
		
		const messages = buildMessages(text);
		const token = getAccessToken();
		if (token) {
			try {
				await sendWithWS(messages, token);
			} catch (wsErr) {
				// WebSocket 失败，回退到 HTTP
				console.warn('[DEBUG] WebSocket 失败，回退到 HTTP', wsErr);
				await sendWithHttp(messages);
			}
		} else {
			await sendWithHttp(messages);
		}
	} catch (err: any) {
		console.error('调用大模型接口失败', err);
		const msg = err?.errMsg || err?.message || '调用失败';
		panel.appendAssistant(`调用失败：${msg}`, 'error');
	} finally {
		panel.setSending(false);
	}
}

async function sendWithHttp(messages: Array<{ role: string; content: string }>) {
	console.log('[DEBUG] HTTP 请求开始', { provider: config.value.provider, messagesCount: messages.length });
	const res = await request('/api/llm/chat', {
		method: 'POST',
		needAuth: true,
		data: {
			stream: false,
			messages
		}
	});

	console.log('[DEBUG] HTTP 响应', { success: res?.success, hasData: !!res?.data, data: res?.data });

	if (!res?.success) {
		throw new Error(res?.error || '调用失败');
	}
	const reply = extractReply(config.value.provider, res.data);
	console.log('[DEBUG] 提取的回复', { reply, replyLength: reply?.length, replyType: typeof reply });
	if (!reply || reply.trim() === '') {
		console.warn('[DEBUG] 回复为空，原始数据:', res.data);
		panelRef.value?.appendAssistant('回复为空，请检查后端配置', 'error');
		return;
	}
	panelRef.value?.appendAssistant(String(reply), 'ready');
}

function getWsUrl() {
	const base = API_BASE_URL.replace(/^http/, 'ws').replace(/\/$/, '');
	return `${base}/api/llm/chat/ws`;
}

function cleanHtml(str: string) {
	if (!str) return '';
	const cleaned = String(str).replace(/<[^>]+>/g, '');
	// 如果清理后为空或只有空白，返回原始内容（可能是纯文本）
	if (!cleaned.trim() && str.trim()) {
		console.log('[DEBUG] cleanHtml: 清理后为空，返回原始内容', { originalLength: str.length });
		return str;
	}
	return cleaned;
}

function parseOpenAIChunk(line: string) {
	if (!line.startsWith('data:')) return '';
	const payload = line.replace(/^data:\s*/, '');
	if (payload.trim() === '[DONE]') return '';
	try {
		const json = JSON.parse(payload);
		const delta = json.choices?.[0]?.delta || json.choices?.[0];
		const content = delta?.content || delta?.text || '';
		return typeof content === 'string' ? content : '';
	} catch (e) {
		return '';
	}
}

function parseAnthropicChunk(line: string) {
	if (!line.startsWith('data:')) return '';
	const payload = line.replace(/^data:\s*/, '');
	try {
		const json = JSON.parse(payload);
		// message_delta or content_block_delta
		const delta = json.delta || json;
		const text = delta?.text || delta?.content?.[0]?.text || '';
		return typeof text === 'string' ? text : '';
	} catch (e) {
		return '';
	}
}

function parseGeminiChunk(line: string) {
	// Gemini 流返回 JSON，无 data: 前缀
	const payload = line.trim().replace(/^data:\s*/, '');
	try {
		const json = JSON.parse(payload);
		const text = json?.candidates?.[0]?.content?.parts?.[0]?.text || '';
		return typeof text === 'string' ? text : '';
	} catch (e) {
		return '';
	}
}

function parseJsonReply(provider: string, raw: string) {
	try {
		const json = JSON.parse(raw);
		console.log('[DEBUG] parseJsonReply 解析 JSON', { provider, hasCandidates: !!json.candidates, hasChoices: !!json.choices, hasContent: !!json.content });
		// 严格按照配置的 provider 解析，不自动检测
		return extractReply(provider, json);
	} catch (e) {
		console.warn('[DEBUG] parseJsonReply JSON 解析失败', e);
		return '';
	}
}

function parseStreamChunk(provider: string, rawChunk: string) {
	console.log('[DEBUG] parseStreamChunk 开始', { provider, rawChunkLength: rawChunk?.length, rawChunkPreview: rawChunk?.substring(0, 200) });
	
	// 如果是完整的 JSON 响应（不以 data: 开头），直接解析
	if (rawChunk.trim().startsWith('{') && !rawChunk.includes('data:')) {
		console.log('[DEBUG] 检测到完整 JSON 响应，使用 parseJsonReply');
		const jsonResult = parseJsonReply(provider, rawChunk);
		if (jsonResult) {
			console.log('[DEBUG] JSON 解析成功', { resultLength: jsonResult.length });
			return jsonResult;
		}
	}
	
	// 流式 SSE 格式解析（严格按照 provider）
	const lines = rawChunk.split('\n').map((l) => l.trim()).filter(Boolean);
	console.log('[DEBUG] 流式解析，分割后的行数', lines.length, 'provider:', provider);
	let acc = '';
	for (const line of lines) {
		let piece = '';
		// 严格按照配置的 provider 选择解析方式
		if (provider === 'anthropic') {
			piece = parseAnthropicChunk(line);
		} else if (provider === 'gemini') {
			piece = parseGeminiChunk(line);
		} else {
			// openai / deepseek / qwen 走同一流格式
			piece = parseOpenAIChunk(line);
		}
		if (piece) {
			console.log('[DEBUG] 解析到内容片段', { pieceLength: piece.length, piece: piece.substring(0, 100) });
			acc += piece;
		}
	}
	if (acc) {
		const cleaned = cleanHtml(acc);
		console.log('[DEBUG] 流式内容累积', { accLength: acc.length, cleanedLength: cleaned.length });
		return cleaned;
	}
	
	// 如果流式解析失败，尝试作为完整 JSON 解析（兜底）
	if (rawChunk.trim().startsWith('{')) {
		console.log('[DEBUG] 流式解析失败，尝试作为完整 JSON 解析');
		const jsonResult = parseJsonReply(provider, rawChunk);
		if (jsonResult) {
			return jsonResult;
		}
	}
	
	// 最后兜底：如果是纯文本，返回清理后的文本
	console.warn('[DEBUG] 所有解析方式都失败，尝试作为纯文本处理', { provider, rawChunkPreview: rawChunk?.substring(0, 200) });
	const cleaned = cleanHtml(rawChunk);
	return cleaned || rawChunk; // 如果清理后为空，返回原始文本
}

async function sendWithWS(messages: Array<{ role: string; content: string }>, token: string) {
	const wsUrl = `${getWsUrl()}?token=${encodeURIComponent(token)}`;
	return new Promise<void>((resolve, reject) => {
		const panel = panelRef.value;
		if (!panel) return reject(new Error('no panel'));

		let lineBuffer = ''; // 按行缓冲
		let closed = false;
		
		// uni-app WebSocket 连接
		const socketTask = uni.connectSocket({
			url: wsUrl,
			success: () => {
				console.log('[DEBUG] WebSocket 连接成功');
			},
			fail: (err: any) => {
				reject(new Error(err?.errMsg || '连接失败'));
			}
		});

		// 监听连接打开
		socketTask.onOpen(() => {
			console.log('[DEBUG] WebSocket 已打开');
			// 连接成功后发送消息
			socketTask.send({
				data: JSON.stringify({
					stream: true,
					messages
				}),
				success: () => {
					console.log('[DEBUG] 消息已发送');
				},
				fail: (err: any) => {
					if (!closed) {
						closed = true;
						reject(new Error(err?.errMsg || '发送失败'));
					}
				}
			});
		});

		// 监听消息 - 按行解析 NDJSON
		socketTask.onMessage((evt: any) => {
			const chunk = typeof evt?.data === 'string' ? evt.data : '';
			console.log('[DEBUG] WebSocket 收到消息', { chunkLength: chunk?.length, chunkPreview: chunk?.substring(0, 100) });
			if (!chunk) {
				console.warn('[DEBUG] 消息块为空');
				return;
			}

			// 累积到行缓冲
			lineBuffer += chunk;

			// 按行处理（NDJSON 格式：每行一个 JSON）
			let idx;
			while ((idx = lineBuffer.indexOf('\n')) >= 0) {
				const line = lineBuffer.slice(0, idx).trim();
				lineBuffer = lineBuffer.slice(idx + 1);

				if (!line) continue;

				let msg;
				try {
					msg = JSON.parse(line);
					console.log('[DEBUG] 解析 NDJSON 行', { event: msg.event, hasText: !!msg.text, textLength: msg.text?.length });
				} catch (err) {
					// 这一行还没收完整，放回去等待下一段
					console.warn('[DEBUG] JSON 解析失败，放回缓冲', err);
					lineBuffer = line + '\n' + lineBuffer;
					break;
				}

				// 处理不同事件类型
				if (msg.event === 'delta' && msg.text) {
					// 增量文本
					const cleaned = cleanHtml(msg.text);
					if (cleaned) {
						panel.appendAssistant(cleaned, 'stream');
					}
				} else if (msg.event === 'done') {
					// 完成标记
					console.log('[DEBUG] 收到完成标记');
					panel.appendAssistant('', 'ready');
				} else if (msg.error) {
					// 错误消息
					console.error('[DEBUG] 收到错误', msg.error);
					panel.appendAssistant(`错误：${msg.error}`, 'error');
				}
			}
		});

		// 监听连接关闭
		socketTask.onClose(() => {
			if (closed) return;
			closed = true;
			// 处理剩余的 buffer
			if (lineBuffer.trim()) {
				try {
					const msg = JSON.parse(lineBuffer.trim());
					if (msg.event === 'delta' && msg.text) {
						const cleaned = cleanHtml(msg.text);
						if (cleaned) {
							panel.appendAssistant(cleaned, 'stream');
						}
					}
				} catch (e) {
					console.warn('[DEBUG] 关闭时解析剩余 buffer 失败', e);
				}
			}
			panel.appendAssistant('', 'ready');
			resolve();
		});

		// 监听错误
		socketTask.onError((err: any) => {
			if (closed) return;
			closed = true;
			reject(new Error(err?.errMsg || 'WebSocket 错误'));
		});
	});
}

function extractReply(provider: string, data: any) {
	console.log('[DEBUG] extractReply 开始', { provider, dataType: typeof data, hasData: !!data });
	if (!data) {
		console.warn('[DEBUG] extractReply: 数据为空');
		return '无响应';
	}

	// 后端已统一返回格式：只返回 { reply: text }
	const text = data?.reply || '';
	console.log('[DEBUG] 提取回复', { textLength: text?.length, textPreview: text?.substring(0, 100) });
	if (text) {
		const cleaned = cleanHtml(text);
		console.log('[DEBUG] 清理后', { cleanedLength: cleaned.length });
		return cleaned || text; // 如果清理后为空，返回原始内容
	}
	
	console.warn('[DEBUG] extractReply: 未找到 reply 字段', { data });
	return '无响应';
}
</script>

<style scoped>
.chat-page-shell {
	min-height: 100vh;
	background: #f3f4f6;
	display: flex;
	flex-direction: column;
}

.chat-panel-wrapper {
	flex: 1;
}
</style>
