datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  charts       Chart[]
}

model Chart {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  title         String
  gender        String?
  birthDatetime DateTime
  timezone      String?
  calendarType  String?
  rawPayload    Json
  createdAt     DateTime @default(now())
}


